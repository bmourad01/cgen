module foo

export function $foo(w %x/rdi) {
@2:
  %3 = zext.l %x ; @11
  %0 = sitof.l.s %3 ; @12
  ret xmm0/%0
}

export function $bar(l %x/rdi) {
@4:
  %4 = slt.l %x, 0x0_l ; @16
  br %4, @13, @14
@13:
  %5 = lsr.l %x, 0x1_l ; @17
  %6 = and.l %x, 0x1_l ; @18
  %7 = or.l %5, %6 ; @19
  %8 = sitof.l.s %7 ; @20
  %9 = add.s %8, %8 ; @21
  jmp @15(%9)
@14:
  %10 = sitof.l.s %x ; @22
  jmp @15(%10)
@15(%11):
  ret xmm0/%11
}

export function $baz(h %x/rdi) {
@6:
  %12 = zext.w %x ; @24
  %2 = sitof.w.s %12 ; @25
