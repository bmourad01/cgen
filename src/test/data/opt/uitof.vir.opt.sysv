module foo

export function $foo(w %1/rdi) {
@2:
  %12 = zext.l %1 ; @11
  %9 = sitof.l.s %12 ; @12
  ret xmm0/%9
}

export function $bar(l %3/rdi) {
@4:
  %13 = slt.l %3, 0x0_l ; @16
  br %13, @13, @14
@13:
  %14 = lsr.l %3, 0x1_l ; @17
  %15 = and.l %3, 0x1_l ; @18
  %16 = or.l %14, %15 ; @19
  %17 = sitof.l.s %16 ; @20
  %18 = add.s %17, %17 ; @21
  jmp @15(%18)
@14:
  %19 = sitof.l.s %3 ; @22
  jmp @15(%19)
@15(%20):
  ret xmm0/%20
}

export function $baz(h %5/rdi) {
@6:
  %21 = zext.w %5 ; @24
  %11 = sitof.w.s %21 ; @25
  ret xmm0/%11
}
