module and_test

export function w $foo(w %1, w %4) {
@2:
  %31 = and.w %1, 0x3_w ; @31
  %32 = eq.w %31, 0x0_w ; @32
  %33 = sel.w %32, %4, %1 ; @33
  ret %33
}

export function w $bar(w %6, w %9) {
@10:
  %34 = and.w %6, 0x3_w ; @34
  %35 = eq.w %34, 0x0_w ; @35
  %36 = add.w %9, 0x1_w ; @36
  %37 = add.w %6, 0x1_w ; @37
  %38 = sel.w %35, %36, %37 ; @38
  ret %38
}

export function l $baz(l %11) {
@18:
  %39 = and.l %11, 0x3_l ; @39
  switch.l %39, @19 [0x1_l -> @20,
                     0x2_l -> @21,
                     0x3_l -> @22]
@19:
  %40 = add.l %11, 0x1_l ; @40
  jmp @24(%40)
@20:
  %41 = add.l %11, 0x2_l ; @41
  jmp @24(%41)
@21:
  %42 = add.l %11, 0x3_l ; @42
  jmp @24(%42)
@22:
  %43 = add.l %11, 0x4_l ; @43
  jmp @24(%43)
@24(%24):
  ret %24
}
