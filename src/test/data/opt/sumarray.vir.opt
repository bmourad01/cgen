module foo

export function sw $foo(l %5, w %3) {
@2:
  jmp @3(0x0_w, 0x0_w)
@3(%9, %10):
  %18 = lt.w %9, %3 ; @15
  br %18, @6, @7
@6:
  %19 = zext.l %9 ; @16
  %20 = lsl.l %19, 0x2_l ; @17
  %21 = add.l %20, %5 ; @18
  %15 = ld.w %21 ; @12
  %22 = add.w %15, %10 ; @19
  %23 = add.w %9, 0x1_w ; @20
  jmp @3(%23, %22)
@7:
