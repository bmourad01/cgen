module sel_fcmp

export function $le_f32_rr { ; returns: rax
@2:
  ucomiss xmm0, xmm1 ; @29
  cmovbe esi, edi ; @30
  mov eax, esi ; @27
  ret ; @28
}

export function $ge_f32_const { ; returns: rax
@5:
  .fp32 @39, 10 ; @20
  mov ecx, 0x7b_w ; @40
  mov eax, 0x1c8_w ; @41
  ucomiss xmm0, dword ptr [rip + @39] ; @42
  cmovae eax, ecx ; @43
  ret ; @38
}

export function $lt_f64_rr { ; returns: rax
@8:
  ucomisd xmm0, xmm1 ; @51
  cmovb rsi, rdi ; @52
  mov rax, rsi ; @49
  ret ; @50
}

export function $eq_f64_const { ; returns: rax
@11:
  .fp64 @61, 2.5 ; @24
  mov eax, 0x2a_w ; @62
  ucomisd xmm0, qword ptr [rip + @61] ; @63
  cmove eax, edi ; @64
  ret ; @60
}

export function $gt_f32_const_ir { ; returns: rax
@14:
  .fp32 @73, 0 ; @26
  mov eax, 0x9_w ; @74
  ucomiss xmm0, dword ptr [rip + @73] ; @75
  cmovbe eax, edi ; @76
  ret ; @72
}
