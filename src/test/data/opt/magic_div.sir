module magic_div

// "magic" division and remainder for signed
// and unsigned integers, using the algorithm
// from Hacker's Delight

type :magic_s = {
  w, // multiplier
  w  // shift
}

type :magic_u = {
  w, // multiplier
  w, // add_flag
  w  // shift
}

export function :magic_s $magic_signed(w %d) {
  %res = slot 8, align 4
start:
  %ad = copy.w %d;
  when slt.w %d, 0_w {
    %ad = neg.w %d
  };
  %mins = lsl.w 1_w, 31_w;
  %msb = copy.w 0_w;
  when slt.w %d, 0_w {
    %msb = copy.w 1_w
  };
  %t = add.w %mins, %msb;
  %t1 = sub.w %t, 1_w;
  %trem = urem.w %t, %ad;
  %anc = sub.w %t1, %trem;
  %q1 = udiv.w %mins, %anc;
  %q1anc = mul.w %q1, %anc;
  %r1 = sub.w %mins, %q1anc;
  %q2 = udiv.w %mins, %ad;
  %q2ad = mul.w %q2, %ad;
  %r2 = sub.w %mins, %q2ad;
  %p = copy.w 31_w;
  loop {
    %p = add.w %p, 1_w;
    %q1 = mul.w %q1, 2_w;
    %r1 = mul.w %r1, 2_w;
    when ge.w %r1, %anc {
      %q1 = add.w %q1, 1_w;
      %r1 = sub.w %r1, %anc
    };
    %q2 = mul.w %q2, 2_w;
    %r2 = mul.w %r2, 2_w;
    when ge.w %r2, %ad {
      %q2 = add.w %q2, 1_w;
      %r2 = sub.w %r2, %ad
    };
    %delta = sub.w %ad, %r2;
    unless lt.w %q1, %delta {
      unless eq.w %q1, %delta { break };
      when ne.w %r1, 0_w { break }
    }
  };
  %m = add.w %q2, 1_w;
  when slt.w %d, 0_w {
    %m = neg.w %m
  };
  %sh = sub.w %p, 32_w;
  %off4 = add.l %res, 4_l;
  st.w %m, %res;
  st.w %sh, %off4;
  %result = ld:magic_s %res;
  ret %result
}

export function :magic_u $magic_unsigned(w %d) {
  %res = slot 12, align 4
start:
  %neg_d = neg.w %d;
  %rem_nc = urem.w %neg_d, %d;
  %nc = not.w %rem_nc;
  %mins = lsl.w 1_w, 31_w;
  %maxs = sub.w %mins, 1_w;
  %q1 = udiv.w %mins, %nc;
  %q1nc = mul.w %q1, %nc;
  %r1 = sub.w %mins, %q1nc;
  %q2 = udiv.w %maxs, %d;
  %q2d = mul.w %q2, %d;
  %r2 = sub.w %maxs, %q2d;
  %a = copy.w 0_w;
  %p = copy.w 31_w;
  loop {
    %p = add.w %p, 1_w;
    %nc_r1 = sub.w %nc, %r1;
    if ge.w %r1, %nc_r1 {
      %q1 = mul.w %q1, 2_w;
      %q1 = add.w %q1, 1_w;
      %r1 = mul.w %r1, 2_w;
      %r1 = sub.w %r1, %nc
    } else {
      %q1 = mul.w %q1, 2_w;
      %r1 = mul.w %r1, 2_w
    };
    %r21 = add.w %r2, 1_w;
    %d_r2 = sub.w %d, %r2;
    if ge.w %r21, %d_r2 {
      when ge.w %q2, %maxs {
        %a = copy.w 1_w
      };
      %q2 = mul.w %q2, 2_w;
      %q2 = add.w %q2, 1_w;
      %r2 = mul.w %r2, 2_w;
      %r2 = add.w %r2, 1_w;
      %r2 = sub.w %r2, %d
    } else {
      when ge.w %q2, %mins {
        %a = copy.w 1_w
      };
      %q2 = mul.w %q2, 2_w;
      %r2 = mul.w %r2, 2_w;
      %r2 = add.w %r2, 1_w
    };
    %delta = sub.w %d, 1_w;
    %delta = sub.w %delta, %r2;
    when lt.w %p, 64_w {
      unless lt.w %q1, %delta {
        unless eq.w %q1, %delta { break };
        when ne.w %r1, 0_w { break }
      }
    }
  };
  %m = add.w %q2, 1_w;
  %sh = sub.w %p, 32_w;
  %off4 = add.l %res, 4_l;
  %off8 = add.l %res, 8_l;
  st.w %m, %res;
  st.w %a, %off4;
  st.w %sh, %off8;
  %result = ld:magic_u %res;
  ret %result
}
