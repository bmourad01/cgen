module and_test

export function $foo { ; returns: rax
@2:
  mov eax, edi ; @31
  mov ecx, eax ; @49
  and ecx, 0x3_w ; @50
  cmove eax, esi ; @47
  ret ; @45
}

export function $bar { ; returns: rax
@10:
  mov ecx, edi ; @56
  and ecx, 0x3_w ; @57
  lea edx, qword ptr [rsi + 0x1] ; @36
  lea eax, qword ptr [rdi + 0x1] ; @37
  test ecx, ecx ; @53
  cmove eax, edx ; @54
  ret ; @52
}

export function $baz { ; returns: rax
@18:
  mov eax, edi ; @80
  and eax, 0x3_w ; @81
  je @19 ; @70
  dec rax ; @72
  cmp rax, 0x2_l ; @73
  ja @19 ; @74
  lea rcx, qword ptr [rip + @68] ; @75
  movsxd rax, dword ptr [rcx + rax*4] ; @76
  add rax, rcx ; @77
  jmp rax ; @78
  .tbl @68 [@20, @21, @22] ; @79
@22:
  lea rax, qword ptr [rdi + 0x4] ; @43
  jmp @24 ; @67
@21:
  lea rax, qword ptr [rdi + 0x3] ; @42
  jmp @24 ; @65
@20:
  lea rax, qword ptr [rdi + 0x2] ; @41
  jmp @24 ; @63
@19:
  lea rax, qword ptr [rdi + 0x1] ; @40
@24:
  ret ; @59
}
