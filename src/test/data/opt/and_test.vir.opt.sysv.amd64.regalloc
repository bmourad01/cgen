module and_test

export function $foo { ; returns: rax
@2:
  mov eax, edi ; @31
  mov ecx, eax ; @49
  and ecx, 0x3_w ; @50
  cmove eax, esi ; @47
  ret ; @45
}

export function $bar { ; returns: rax
@10:
  mov ecx, edi ; @56
  and ecx, 0x3_w ; @57
  lea edx, qword ptr [rsi + 0x1] ; @36
  lea eax, qword ptr [rdi + 0x1] ; @37
  test ecx, ecx ; @53
  cmove eax, edx ; @54
  ret ; @52
}

export function $baz { ; returns: rax
@18:
  mov eax, edi ; @82
  and eax, 0x3_w ; @83
  cmp rax, 0x1_l ; @79
  je @20 ; @80
@61:
  cmp rax, 0x2_l ; @76
  je @21 ; @77
@59:
  cmp rax, 0x3_l ; @73
  jne @19 ; @74
@22:
  lea rax, qword ptr [rdi + 0x4] ; @43
  jmp @24 ; @72
@19:
  lea rax, qword ptr [rdi + 0x1] ; @40
  jmp @24 ; @70
@21:
  lea rax, qword ptr [rdi + 0x3] ; @42
  jmp @24 ; @68
@20:
  lea rax, qword ptr [rdi + 0x2] ; @41
@24:
  ret ; @64
}
