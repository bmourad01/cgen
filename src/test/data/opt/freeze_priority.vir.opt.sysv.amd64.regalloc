@3:
  test edx, edx ; @139
  je @19 ; @140
@112:
  mov ecx, dword ptr [rsp + 0xc] ; @165
@21:
  test ecx, ecx ; @133
  jne @23 ; @134
@24:
  dec edx ; @57
