module freeze_priority

export function $freeze_test { ; returns: rax
@2:
  push r12 ; @179
  push r13 ; @180
  push r14 ; @181
  push r15 ; @182
  push rbx ; @183
  sub rsp, 0x10_l ; @184
  mov dword ptr [rsp + 0xc], ecx ; @165
  xor eax, eax ; @151
  xor r13d, r13d ; @152
  xor r12d, r12d ; @153
  xor ebx, ebx ; @154
  xor r11d, r11d ; @155
  xor r10d, r10d ; @156
  xor r9d, r9d ; @157
  xor r8d, r8d ; @158
  xor r14d, r14d ; @159
  xor r15d, r15d ; @160
  mov dword ptr [rsp + 0x8], 0x0_w ; @166
  mov dword ptr [rsp + 0x4], 0x0_w ; @167
  mov dword ptr [rsp], 0x0_w ; @168
@3:
  test edx, edx ; @141
  je @19 ; @142
@112:
  mov ecx, dword ptr [rsp + 0xc] ; @169
@21:
  test ecx, ecx ; @133
  jne @23 ; @134
@24:
  mov ecx, dword ptr [rsp] ; @170
  add ecx, edi ; @57
  mov dword ptr [rsp], ecx ; @171
  mov ecx, dword ptr [rsp + 0x4] ; @172
  add ecx, edi ; @58
  mov dword ptr [rsp + 0x4], ecx ; @173
  mov ecx, dword ptr [rsp + 0x8] ; @174
  add ecx, edi ; @59
  mov dword ptr [rsp + 0x8], ecx ; @175
  add r15d, edi ; @60
  add r14d, edi ; @61
  add r8d, edi ; @62
  add r9d, edi ; @63
  add r10d, edi ; @64
  add r11d, edi ; @65
  add ebx, edi ; @66
  add r12d, edi ; @67
  add r13d, edi ; @68
  dec edx ; @69
  jmp @3 ; @132
@23:
  add eax, esi ; @55
  dec ecx ; @56
  jmp @21 ; @117
@19:
  mov edx, dword ptr [rsp + 0x4] ; @176
  add edx, dword ptr [rsp] ; @70
  mov ecx, dword ptr [rsp + 0x8] ; @178
  add ecx, r15d ; @72
  add edx, ecx ; @73
  lea esi, qword ptr [r14 + r8*1] ; @76
  lea ecx, qword ptr [r9 + r10*1] ; @82
  add esi, ecx ; @83
  lea ecx, qword ptr [r11 + rbx*1] ; @90
  add esi, ecx ; @91
  lea ecx, qword ptr [r12 + r13*1] ; @100
  add eax, ecx ; @106
  add eax, esi ; @107
  add eax, edx ; @108
  add rsp, 0x10_l ; @185
  pop rbx ; @186
  pop r15 ; @187
  pop r14 ; @188
  pop r13 ; @189
  pop r12 ; @190
  ret ; @114
}
