module foo

export function $foo(w %2/rdi) {
@2:
  jmp @3(%2, 0x0_w)
@3(%24, %25):
  %43 = gt.w %24, 0x1_w ; @27
  br %43, @6, @7
@6:
  %44 = and.w %24, 0x1_w ; @28
  %45 = eq.w %44, 0x0_w ; @29
  %47 = lsr.w %24, 0x1_w ; @31
  %48 = lsl.w %24, 0x1_w ; @32
  %49 = add.w %48, %24 ; @33
  %50 = add.w %49, 0x1_w ; @34
  %51 = sel.w %45, %47, %50 ; @35
  %46 = add.w %25, 0x1_w ; @30
  jmp @3(%51, %46)
@7:
  ret rax/%25
}
