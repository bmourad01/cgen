module foo

export function $foo(w %2/rdi) {
@2:
  jmp @3(%2, 0x0_w)
@3(%24, %25):
  %44 = gt.w %24, 0x1_w ; @28
  br %44, @6, @7
@6:
  %45 = and.w %24, 0x1_w ; @29
  %46 = eq.w %45, 0x0_w ; @30
  %47 = lsr.w %24, 0x1_w ; @31
  %48 = lsl.w %24, 0x1_w ; @32
  %49 = add.w %48, %24 ; @33
  %50 = add.w %49, 0x1_w ; @34
  %51 = sel.w %46, %47, %50 ; @35
  %52 = add.w %25, 0x1_w ; @36
  jmp @3(%51, %52)
@7:
  ret rax/%25
}
