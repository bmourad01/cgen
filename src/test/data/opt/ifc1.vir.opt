module ifc1

export function w $simple_diamond(w %1) {
@2:
  %97 = slt.w %1, 0x0_w ; @105
  %98 = add.w %1, 0x5_w ; @106
  %99 = sub.w %1, 0x5_w ; @107
  %100 = sel.w %97, %98, %99 ; @108
  ret %100
}

export function w $right_triangle(w %4) {
@9:
  %101 = slt.w %4, 0x0_w ; @109
  %102 = sub.w %4, 0x5_w ; @110
  %103 = sel.w %101, %4, %102 ; @111
  ret %103
}

export function w $left_triangle(w %6) {
@14:
  %104 = slt.w %6, 0x0_w ; @112
  %105 = add.w %6, 0x5_w ; @113
  %106 = sel.w %104, %105, %6 ; @114
  ret %106
}

export function w $expensive_diamond(w %8) {
@19:
  %107 = slt.w %8, 0x0_w ; @115
  br %107, @20, @21
@20:
  %108 = add.w %8, 0x5_w ; @116
  %109 = lsl.w %108, 0x4_w ; @117
  %110 = lsl.w %108, 0x1_w ; @118
  %111 = sub.w %109, %110 ; @119
  %112 = sub.w %111, %108 ; @120
  jmp @23(%112)
@21:
  %113 = sub.w %8, 0x5_w ; @121
  %114 = mulh.w %113, 0x55555556_w ; @122
  %115 = lsr.w %114, 0x1f_w ; @123
  %116 = add.w %114, %115 ; @124
  jmp @23(%116)
@23(%44):
  ret %44
}

export function w $mixed_cost(w %11) {
@28:
  %117 = slt.w %11, 0x0_w ; @125
  br %117, @29, @30
@29:
  %118 = add.w %11, 0x1_w ; @126
  jmp @32(%118)
@30:
  %119 = lsl.w %11, 0x5_w ; @127
  %120 = sub.w %119, %11 ; @128
  %121 = lsl.w %11, 0x7_w ; @129
  %122 = sub.w %121, %120 ; @130
  %127 = div.w %122, 0x7_w ; @135
  jmp @32(%127)
@32(%50):
  ret %50
}

export function w $nested_tri(w %14) {
@36:
  %128 = slt.w %14, 0x0_w ; @136
  br %128, @37(%14), @38
@38:
  %129 = eq.w %14, 0xa_w ; @137
  br %129, @37(%14), @40
@40:
  %130 = add.w %14, 0x1_w ; @138
  jmp @37(%130)
@37(%55):
  ret %55
}

export function w $chain(w %17) {
@43:
  %131 = slt.w %17, 0x0_w ; @139
  %132 = add.w %17, 0x1_w ; @140
  %133 = sub.w %17, 0x1_w ; @141
  %134 = sel.w %131, %132, %133 ; @142
  %135 = slt.w %134, 0xa_w ; @143
  %136 = add.w %134, 0x2_w ; @144
  %137 = sub.w %134, 0x2_w ; @145
  %138 = sel.w %135, %136, %137 ; @146
  ret %138
}

export function w $redundant_phi(w %20) {
@56:
  ret %20
}

export function w $dead_arm(w %23) {
@63:
  %140 = slt.w %23, 0x0_w ; @148
  %141 = add.w %23, 0x1_w ; @149
  %142 = sel.w %140, %23, %141 ; @150
  ret %142
}

export function w $loop_if(w %25) {
@69:
  jmp @70(%25)
@70(%73):
  %143 = slt.w %73, 0x64_w ; @151
  br %143, @71, @72
@71:
  %144 = slt.w %73, 0x0_w ; @152
  %145 = add.w %73, 0x1_w ; @153
  %146 = sub.w %73, 0x1_w ; @154
  %147 = sel.w %144, %145, %146 ; @155
  jmp @70(%147)
@72:
  ret %73
}

export function w $dominance(w %28) {
@80:
  %148 = slt.w %28, 0x0_w ; @156
  %149 = add.w %28, 0x1_w ; @157
  %150 = add.w %28, 0x2_w ; @158
  %151 = sel.w %148, %149, %150 ; @159
  %152 = mul.w %151, %28 ; @160
  ret %152
}

export function w $switch_like(w %31) {
@88:
  switch.w %31, @89 [0x0_w -> @92(0x1_w),
                     0x1_w -> @92(0x0_w)]
@89:
  %153 = lsl.w %31, 0x1_w ; @161
  jmp @92(%153)
@92(%84):
  ret %84
}
