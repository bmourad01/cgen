module ifc1

export function w $simple_diamond(w %1) {
@2:
  %97 = slt.w %1, 0x0_w ; @105
  %98 = add.w %1, 0x5_w ; @106
  %99 = sub.w %1, 0x5_w ; @107
  %100 = sel.w %97, %98, %99 ; @108
  ret %100
}

export function w $right_triangle(w %4) {
@9:
  %101 = slt.w %4, 0x0_w ; @109
  %102 = sub.w %4, 0x5_w ; @110
  %103 = sel.w %101, %4, %102 ; @111
  ret %103
}

export function w $left_triangle(w %6) {
@14:
  %104 = slt.w %6, 0x0_w ; @112
  %105 = add.w %6, 0x5_w ; @113
  %106 = sel.w %104, %105, %6 ; @114
  ret %106
}

export function w $expensive_diamond(w %8) {
@19:
  %107 = slt.w %8, 0x0_w ; @115
  br %107, @20, @21
@20:
  %108 = add.w %8, 0x5_w ; @116
  %109 = lsl.w %108, 0x4_w ; @117
  %110 = lsl.w %108, 0x1_w ; @118
  %111 = sub.w %109, %110 ; @119
  %112 = sub.w %111, %108 ; @120
  jmp @23(%112)
@21:
  %114 = sub.w %8, 0x5_w ; @122
  %115 = mulh.w %114, 0x55555556_w ; @123
  %116 = lsr.w %115, 0x1f_w ; @124
  %117 = add.w %115, %116 ; @125
  jmp @23(%117)
@23(%44):
  ret %44
}

export function w $mixed_cost(w %11) {
@28:
  %118 = slt.w %11, 0x0_w ; @126
  br %118, @29, @30
@29:
  %119 = add.w %11, 0x1_w ; @127
  jmp @32(%119)
@30:
  %120 = lsl.w %11, 0x7_w ; @128
  %121 = lsl.w %11, 0x5_w ; @129
  %122 = sub.w %121, %11 ; @130
  %123 = sub.w %120, %122 ; @131
  %124 = div.w %123, 0x7_w ; @132
  jmp @32(%124)
@32(%50):
  ret %50
}

export function w $nested_tri(w %14) {
@36:
  %130 = slt.w %14, 0x0_w ; @138
  br %130, @37(%14), @38
@38:
  %131 = eq.w %14, 0xa_w ; @139
  br %131, @37(%14), @40
@40:
  %132 = add.w %14, 0x1_w ; @140
  jmp @37(%132)
@37(%55):
  ret %55
}

export function w $chain(w %17) {
@43:
  %133 = slt.w %17, 0x0_w ; @141
  %134 = add.w %17, 0x1_w ; @142
  %135 = sub.w %17, 0x1_w ; @143
  %136 = sel.w %133, %134, %135 ; @144
  %137 = slt.w %136, 0xa_w ; @145
  %138 = add.w %136, 0x2_w ; @146
  %139 = sub.w %136, 0x2_w ; @147
  %140 = sel.w %137, %138, %139 ; @148
  ret %140
}

export function w $redundant_phi(w %20) {
@56:
  ret %20
}

export function w $dead_arm(w %23) {
@63:
  %142 = slt.w %23, 0x0_w ; @150
  %143 = add.w %23, 0x1_w ; @151
  %144 = sel.w %142, %23, %143 ; @152
  ret %144
}

export function w $loop_if(w %25) {
@69:
  jmp @70(%25)
@70(%73):
  %145 = slt.w %73, 0x64_w ; @153
  br %145, @71, @72
@71:
  %146 = slt.w %73, 0x0_w ; @154
  %147 = add.w %73, 0x1_w ; @155
  %148 = sub.w %73, 0x1_w ; @156
  %149 = sel.w %146, %147, %148 ; @157
  jmp @70(%149)
@72:
  ret %73
}

export function w $dominance(w %28) {
@80:
  %150 = slt.w %28, 0x0_w ; @158
  %151 = add.w %28, 0x1_w ; @159
  %152 = add.w %28, 0x2_w ; @160
  %153 = sel.w %150, %151, %152 ; @161
  %154 = mul.w %153, %28 ; @162
  ret %154
}

export function w $switch_like(w %31) {
@88:
  switch.w %31, @89 [0x0_w -> @92(0x1_w),
                     0x1_w -> @92(0x0_w)]
@89:
  %155 = lsl.w %31, 0x1_w ; @163
  jmp @92(%155)
@92(%84):
  ret %84
}
