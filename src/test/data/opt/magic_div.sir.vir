module magic_div

type :magic_s = {
  w,
  w
}

type :magic_u = {
  w,
  w,
  w
}

export function :magic_s $magic_signed(w %2) {
  %0 = slot 8, align 4
@56:
  %1 = copy.w %2 ; @58
  %52 = slt.w %2, 0x0_w ; @57
  br %52, @54, @50
@54:
  %1 = neg.w %2 ; @55
  jmp @50
@50:
  %3 = lsl.w 0x1_w, 0x1f_w ; @53
  %4 = copy.w 0x0_w ; @52
  %51 = slt.w %2, 0x0_w ; @51
  br %51, @48, @36
@48:
  %4 = copy.w 0x1_w ; @49
  jmp @36
@36:
  %5 = add.w %3, %4 ; @47
  %6 = sub.w %5, 0x1_w ; @46
  %7 = urem.w %5, %1 ; @45
  %8 = sub.w %6, %7 ; @44
  %9 = udiv.w %3, %8 ; @43
  %10 = mul.w %9, %8 ; @42
  %11 = sub.w %3, %10 ; @41
  %12 = udiv.w %3, %1 ; @40
  %13 = mul.w %12, %1 ; @39
  %14 = sub.w %3, %13 ; @38
  %15 = copy.w 0x1f_w ; @37
  jmp @13
@13:
  jmp @31
@31:
  %15 = add.w %15, 0x1_w ; @35
  %9 = mul.w %9, 0x2_w ; @34
  %11 = mul.w %11, 0x2_w ; @33
  %50 = ge.w %11, %8 ; @32
  br %50, @28, @24
@28:
  %9 = add.w %9, 0x1_w ; @30
  %11 = sub.w %11, %8 ; @29
  jmp @24
@24:
  %12 = mul.w %12, 0x2_w ; @27
  %14 = mul.w %14, 0x2_w ; @26
  %49 = ge.w %14, %1 ; @25
  br %49, @21, @18
@21:
  %12 = add.w %12, 0x1_w ; @23
  %14 = sub.w %14, %1 ; @22
  jmp @18
@18:
  %16 = sub.w %1, %14 ; @20
  %46 = lt.w %9, %16 ; @19
  br %46, @13, @16
@16:
  %48 = eq.w %9, %16 ; @17
  br %48, @14, @10
@14:
  %47 = ne.w %11, 0x0_w ; @15
  br %47, @10, @13
@10:
  %17 = add.w %12, 0x1_w ; @12
  %45 = slt.w %2, 0x0_w ; @11
  br %45, @8, @2
@8:
  %17 = neg.w %17 ; @9
  jmp @2
@2:
  %18 = sub.w %15, 0x20_w ; @7
  %19 = add.l %0, 0x4_l ; @6
  st.w %17, %0 ; @5
  st.w %18, %19 ; @4
  %20 = ld:magic_s %0 ; @3
  ret %20
}

export function :magic_u $magic_unsigned(w %23) {
  %21 = slot 12, align 4
@113:
  %22 = neg.w %23 ; @126
  %24 = urem.w %22, %23 ; @125
  %25 = not.w %24 ; @124
  %26 = lsl.w 0x1_w, 0x1f_w ; @123
  %27 = sub.w %26, 0x1_w ; @122
  %28 = udiv.w %26, %25 ; @121
  %29 = mul.w %28, %25 ; @120
  %30 = sub.w %26, %29 ; @119
  %31 = udiv.w %27, %23 ; @118
  %32 = mul.w %31, %23 ; @117
  %33 = sub.w %27, %32 ; @116
  %34 = copy.w 0x0_w ; @115
  %35 = copy.w 0x1f_w ; @114
  jmp @68
@68:
  jmp @109
@109:
  %35 = add.w %35, 0x1_w ; @112
  %36 = sub.w %25, %30 ; @111
  %60 = ge.w %30, %36 ; @110
  br %60, @101, @106
@106:
  %28 = mul.w %28, 0x2_w ; @108
  %30 = mul.w %30, 0x2_w ; @107
  jmp @97
@101:
  %28 = mul.w %28, 0x2_w ; @105
  %28 = add.w %28, 0x1_w ; @104
  %30 = mul.w %30, 0x2_w ; @103
  %30 = sub.w %30, %25 ; @102
  jmp @97
@97:
  %37 = add.w %33, 0x1_w ; @100
  %38 = sub.w %23, %33 ; @99
  %57 = ge.w %37, %38 ; @98
  br %57, @87, @95
@95:
  %59 = ge.w %31, %26 ; @96
  br %59, @93, @89
@93:
  %34 = copy.w 0x1_w ; @94
  jmp @89
@89:
  %31 = mul.w %31, 0x2_w ; @92
  %33 = mul.w %33, 0x2_w ; @91
  %33 = add.w %33, 0x1_w ; @90
  jmp @75
@87:
  %58 = ge.w %31, %27 ; @88
  br %58, @85, @79
@85:
  %34 = copy.w 0x1_w ; @86
  jmp @79
@79:
  %31 = mul.w %31, 0x2_w ; @84
  %31 = add.w %31, 0x1_w ; @83
  %33 = mul.w %33, 0x2_w ; @82
  %33 = add.w %33, 0x1_w ; @81
  %33 = sub.w %33, %23 ; @80
  jmp @75
@75:
  %39 = sub.w %23, 0x1_w ; @78
  %39 = sub.w %39, %33 ; @77
  %53 = lt.w %35, 0x40_w ; @76
  br %53, @73, @68
@73:
  %54 = lt.w %28, %39 ; @74
  br %54, @68, @71
@71:
  %56 = eq.w %28, %39 ; @72
  br %56, @69, @59
@69:
  %55 = ne.w %30, 0x0_w ; @70
  br %55, @59, @68
@59:
  %40 = add.w %31, 0x1_w ; @67
  %41 = sub.w %35, 0x20_w ; @66
  %42 = add.l %21, 0x4_l ; @65
  %43 = add.l %21, 0x8_l ; @64
  st.w %40, %21 ; @63
  st.w %34, %42 ; @62
  st.w %41, %43 ; @61
  %44 = ld:magic_u %21 ; @60
  ret %44
}
