module brind

export function $foo(w %1) {
@2:
  %11 = slt.w %1, 0x0_w ; @10
  br %11, 0x1234, @3
@3:
  ret
}

export function $bar(w %3, l %4) {
@5:
  %12 = slt.w %3, 0x0_w ; @11
  br %12, %4, @6
@6:
  ret
}

export function $baz(w %6, l %7) {
@8:
  %13 = slt.w %6, 0x0_w ; @12
