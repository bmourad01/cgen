module prime_main_licm

const data $fmt = {
  "prime(%d) = %d\n",
  0x0_b
}

export function w $main(w %8, l %1) {
start:
  %26 = add.l %1, 0x8_l;
  %10 = ld.l %26;
  %11 = call.w $atoi(%10);
  %14 = copy.w 0x1_w;
  %15 = copy.w 0x1_w;
  %16 = copy.w %11;
  while sgt.w %16, 0x0_w {
    %18 = copy.w %14;
    loop {
      %19 = call.w $is_prime(%18);
      %28 = eq.w %19, 0x0_w;
      %29 = add.w %18, 0x1_w;
      if %28 {
        %18 = copy.w %29
      } else {
        break
      }
    };
    %22 = call.w $printf($fmt, ..., %15, %18);
    %30 = sub.w %16, 0x1_w;
    %31 = add.w %15, 0x1_w;
    %14 = copy.w %29;
    %15 = copy.w %31;
    %16 = copy.w %30
  };
  ret 0x0_w
}
