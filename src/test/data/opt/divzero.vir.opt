module divzero

export function w $u_div3(w %1) {
@2:
  %40 = mul.w %1, 0xaaaaaaab_w ; @27
  %41 = le.w %40, 0x55555555_w ; @28
  %42 = flag.w %41 ; @29
  ret %42
}

export function w $s_div4(w %5) {
@6:
  %48 = and.w %5, 0x3_w ; @35
  %49 = eq.w %48, 0x0_w ; @36
  %50 = flag.w %49 ; @37
  ret %50
}

export function w $s_div100(w %9) {
@10:
  %62 = mul.w %9, 0xc28f5c29_w ; @49
  %63 = add.w %62, 0x51eb850_w ; @50
  %64 = ror.w %63, 0x2_w ; @51
  %65 = le.w %64, 0x28f5c28_w ; @52
  %66 = flag.w %65 ; @53
  ret %66
}

export function w $s_ndiv7(w %13) {
@14:
  %76 = mul.w %13, 0xb6db6db7_w ; @63
  %77 = add.w %76, 0x12492492_w ; @64
  %78 = gt.w %77, 0x24924924_w ; @65
  %79 = flag.w %78 ; @66
  ret %79
