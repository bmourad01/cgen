export function l $u_div6(l %17) {
@18:
  %87 = mul.l %17, 0xaaaaaaaaaaaaaaab_l ; @74
  %88 = ror.l %87, 0x1_l ; @75
  %89 = le.l %88, 0x2aaaaaaaaaaaaaaa_l ; @76
  %90 = flag.l %89 ; @77
