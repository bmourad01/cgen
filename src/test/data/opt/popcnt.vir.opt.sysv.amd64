module popcnt

export function $popcnt8 { ; returns: rax
@2:
  mov %1:b, dil ; @10
  movzx %16:w, %1:b ; @16
  popcnt %17:w, %16:w ; @17
  mov %12:w, %17:w ; @18
  mov al, %12:b ; @14
  ret ; @15
}

export function $popcnt16 { ; returns: rax
@4:
  mov %3:h, di ; @11
  movzx %18:w, %3:h ; @21
  popcnt %19:w, %18:w ; @22
  mov %13:w, %19:w ; @23
  mov ax, %13:h ; @19
  ret ; @20
}

export function $popcnt32 { ; returns: rax
@6:
  mov %5:w, edi ; @12
  mov %20:w, %5:w ; @26
  popcnt %21:w, %20:w ; @27
  mov %14:w, %21:w ; @28
  mov eax, %14:w ; @24
  ret ; @25
}

export function $popcnt64 { ; returns: rax
@8:
  mov %7:l, rdi ; @13
  mov %22:l, %7:l ; @31
  popcnt %23:l, %22:l ; @32
  mov %15:l, %23:l ; @33
  mov rax, %15:l ; @29
  ret ; @30
}
