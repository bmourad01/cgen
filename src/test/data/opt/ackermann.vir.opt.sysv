module foo

export function $foo(w %1/rdi, w %3/rsi) {
@22:
  jmp @2(%1, %3)
@2(%16, %17):
  %18 = eq.w %16, 0x0_w ; @23
  br %18, @3, @4
@3:
  %19 = add.w %17, 0x1_w ; @24
  ret rax/%19
@4:
  %20 = eq.w %17, 0x0_w ; @25
  %21 = sub.w %16, 0x1_w ; @26
  br %20, @2(%21, 0x1_w), @8
@8:
  %22 = ne.w %17, 0x0_w ; @27
  br %22, @14, @15
@14:
  %23 = sub.w %17, 0x1_w ; @28
  %9/w/rax = call $foo(%16/rdi, %23/rsi) ; @18
  jmp @2(%21, %9)
@15:
  hlt
}
