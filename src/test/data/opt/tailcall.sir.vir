module tailcall

export function w $ping(w %0) {
@6:
  %48 = sle.w %0, 0x0_w ; @7
  br %48, @5, @2
@5:
  ret 0x0_w
@2:
  %1 = sub.w %0, 0x1_w ; @4
  %2 = call.w $pong(%1) ; @3
  ret %2
}

export function w $pong(w %3) {
@12:
  %49 = sle.w %3, 0x0_w ; @13
  br %49, @11, @8
@11:
  ret 0x1_w
@8:
  %4 = sub.w %3, 0x1_w ; @10
  %5 = call.w $ping(%4) ; @9
  ret %5
}

export function w $ping_nontail(w %6) {
@18:
  %50 = sle.w %6, 0x0_w ; @19
  br %50, @17, @14
@17:
  ret 0x0_w
@14:
  %7 = sub.w %6, 0x1_w ; @16
  %8 = call.w nontail $pong(%7) ; @15
  ret %8
}

export function w $call_and_ignore(w %9) {
@24:
  %51 = sle.w %9, 0x0_w ; @25
  br %51, @23, @20
@23:
  ret %9
@20:
  %10 = sub.w %9, 0x1_w ; @22
  %11 = call.w $pong(%10) ; @21
  ret %9
}

export function w $dispatch(w %12, w %13) {
@30:
  %52 = slt.w %12, %13 ; @31
  br %52, @28, @26
@28:
  %14 = call.w $ping(%12) ; @29
  ret %14
@26:
  %14 = call.w $pong(%13) ; @27
  ret %14
}

export function w $mixed_tail(w %15, w %17) {
@37:
  %53 = eq.w %15, 0x0_w ; @38
  br %53, @35, @32
@35:
  %16 = call.w nontail $pong(%17) ; @36
  ret %16
@32:
  %18 = sub.w %15, 0x1_w ; @34
  %16 = call.w $ping(%18) ; @33
  ret %16
}

export function w $gcd_tc(w %20, w %19) {
@43:
  %54 = eq.w %19, 0x0_w ; @44
  br %54, @42, @39
@42:
  ret %20
@39:
  %21 = rem.w %20, %19 ; @41
  %22 = call.w $gcd_tc(%19, %21) ; @40
  ret %22
}

export function w $sum7(w %24, w %25, w %27, w %28, w %30, w %31, w %35) {
@45:
  %23 = add.w %24, %25 ; @51
  %26 = add.w %27, %28 ; @50
  %29 = add.w %30, %31 ; @49
  %32 = add.w %23, %26 ; @48
  %33 = add.w %32, %29 ; @47
  %34 = add.w %33, %35 ; @46
  ret %34
}

export function w $tail_sum7_stk(w %37, w %38, w %39, w %40, w %41, w %42, w %43) {
@52:
  %36 = call.w $sum7(%37, %38, %39, %40, %41, %42, %43) ; @53
  ret %36
}

export function w $gcd_nt(w %45, w %44) {
@58:
  %55 = eq.w %44, 0x0_w ; @59
  br %55, @57, @54
@57:
  ret %45
@54:
  %46 = rem.w %45, %44 ; @56
  %47 = call.w nontail $gcd_nt(%44, %46) ; @55
  ret %47
}
