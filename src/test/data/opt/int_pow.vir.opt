module int_pow

export function l $int_pow(l %3, l %7) {
@2:
  jmp @3(%7, 0x1_l, %3, 0x1_l)
@3(%27, %28, %29, %30):
  %62 = ne.l %27, 0x0_l ; @55
  br %62, @9, @10
@9:
  %63 = mul.l %29, %28 ; @56
  %64 = mul.l %63, %63 ; @57
  %65 = mul.l %64, %63 ; @58
  %66 = and.l %27, 0x3_l ; @59
  switch.l %66, @21(%30) [0x1_l -> @14,
                          0x2_l -> @15,
                          0x3_l -> @16]
@14:
  %68 = mul.l %30, %63 ; @61
  jmp @21(%68)
@15:
  %69 = mul.l %30, %63 ; @62
  %70 = mul.l %69, %63 ; @63
  jmp @21(%70)
@16:
  %71 = mul.l %30, %63 ; @64
  %72 = mul.l %71, %64 ; @65
  jmp @21(%72)
@21(%36):
  %67 = asr.l %27, 0x2_l ; @60
  jmp @3(%67, %65, %63, %36)
@10:
  ret %30
}

export function l $int_pow_alt(l %12, l %15) {
  %9 = slot 32, align 8
@27:
  st.l 0x1_l, %9 ; @30
  %74 = add.l %9, 0x8_l ; @67
  st.l %12, %74 ; @32
  %75 = add.l %9, 0x18_l ; @68
  st.l 0x1_l, %75 ; @34
  %76 = add.l %9, 0x10_l ; @69
  jmp @28(%15, 0x1_l)
@28(%45, %46):
  %77 = ne.l %45, 0x0_l ; @70
  br %77, @35, @36
@35:
  %51 = ld.l %74 ; @41
  %52 = ld.l %75 ; @42
  %78 = mul.l %51, %52 ; @71
  st.l %78, %74 ; @44
  %79 = mul.l %78, %78 ; @72
  st.l %79, %76 ; @46
  %80 = mul.l %79, %78 ; @73
  st.l %80, %75 ; @48
  %81 = and.l %45, 0x3_l ; @74
  %82 = lsl.l %81, 0x3_l ; @75
  %83 = add.l %9, %82 ; @76
  %59 = ld.l %83 ; @52
  %84 = mul.l %46, %59 ; @77
  %85 = asr.l %45, 0x2_l ; @78
  jmp @28(%85, %84)
@36:
  ret %46
}
