module qsort

function $swap(l %1/rdi, l %3/rsi) {
@2:
  %25 = ld.w %1 ; @3
  %26 = ld.w %3 ; @4
  st.w %25, %3 ; @5
  st.w %26, %1 ; @6
  ret
}

function $partition(l %6/rdi, l %9/rsi, l %5/rdx) {
@7:
  %60 = lsl.l %5, 0x2_l ; @49
  %61 = add.l %6, %60 ; @50
  %29 = ld.w %61 ; @11
  %62 = sub.l %9, 0x1_l ; @51
  %63 = sub.l %5, 0x1_l ; @52
  jmp @8(%9, %62)
@8(%32, %33):
  %64 = sle.l %32, %63 ; @53
  br %64, @14, @15
@14:
  %65 = lsl.l %32, 0x2_l ; @54
  %66 = add.l %6, %65 ; @55
  %38 = ld.w %66 ; @22
  %67 = sle.w %38, %29 ; @56
  br %67, @18, @19(%33)
@19(%40):
  %68 = add.l %32, 0x1_l ; @57
  jmp @8(%68, %40)
@18:
  %69 = add.l %33, 0x1_l ; @58
  %70 = lsl.l %69, 0x2_l ; @59
  %71 = add.l %6, %70 ; @60
  call $swap(%71/rdi, %66/rsi) ; @30
  jmp @19(%69)
@15:
  %72 = add.l %33, 0x1_l ; @61
  %73 = lsl.l %72, 0x2_l ; @62
  %74 = add.l %6, %73 ; @63
  call $swap(%74/rdi, %61/rsi) ; @36
  ret rax/%72
}

export function $qsort(l %22/rdi, l %19/rsi, l %20/rdx) {
@48:
  jmp @38(%22, %19, %20)
@38(%57, %58, %59):
  %75 = slt.l %58, %59 ; @64
  br %75, @39, @47
@39:
  %54/l/rax = call $partition(%57/rdi, %58/rsi, %59/rdx) ; @42
  %76 = sub.l %54, 0x1_l ; @65
  call $qsort(%57/rdi, %58/rsi, %76/rdx) ; @44
  %77 = add.l %54, 0x1_l ; @66
  jmp @38(%57, %77, %59)
@47:
  ret
}
