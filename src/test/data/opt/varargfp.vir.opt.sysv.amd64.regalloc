@58:
  lea rdx, qword ptr [rax + 0x8] ; @71
  mov rsi, rax ; @87
  jmp @59 ; @88
@57:
  lea rsi, qword ptr [rbp + rcx*1 - 0xb0] ; @66
  add ecx, 0x10_w ; @67
  mov rdx, rax ; @81
@59:
  movsd xmm1, qword ptr [rsi] ; @73
  addsd xmm0, xmm1 ; @79
