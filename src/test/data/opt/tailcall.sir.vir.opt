module tailcall

export function w $ping(w %1) {
@2:
  %98 = sle.w %1, 0x0_w ; @69
  br %98, @60(0x0_w), @4
@4:
  %99 = sub.w %1, 0x1_w ; @70
  %58 = call.w $pong(%99) ; @7
  jmp @60(%58)
@60(%88):
  ret %88
}

export function w $pong(w %5) {
@8:
  %100 = sle.w %5, 0x0_w ; @71
  br %100, @61(0x1_w), @10
@10:
  %101 = sub.w %5, 0x1_w ; @72
  %61 = call.w $ping(%101) ; @13
  jmp @61(%61)
@61(%89):
  ret %89
}

export function w $ping_nontail(w %9) {
@14:
  %102 = sle.w %9, 0x0_w ; @73
  br %102, @62(0x0_w), @16
@16:
  %103 = sub.w %9, 0x1_w ; @74
  %64 = call.w nontail $pong(%103) ; @19
  jmp @62(%64)
@62(%90):
  ret %90
}

export function w $call_and_ignore(w %13) {
@20:
  %104 = sle.w %13, 0x0_w ; @75
  br %104, @63, @22
@22:
  %105 = sub.w %13, 0x1_w ; @76
  %67 = call.w $pong(%105) ; @25
  jmp @63
@63:
  ret %13
}

export function w $dispatch(w %17, w %18) {
@26:
  %106 = slt.w %17, %18 ; @77
  br %106, @27, @28
@27:
  %69 = call.w $ping(%17) ; @30
  jmp @64(%69)
@28:
  %70 = call.w $pong(%18) ; @31
  jmp @64(%70)
@64(%92):
  ret %92
}

export function w $mixed_tail(w %21, w %23) {
@32:
  %107 = eq.w %21, 0x0_w ; @78
  br %107, @33, @34
@33:
  %72 = call.w nontail $pong(%23) ; @36
  jmp @65(%72)
@34:
  %108 = sub.w %21, 0x1_w ; @79
  %74 = call.w $ping(%108) ; @38
  jmp @65(%74)
@65(%93):
  ret %93
}

export function w $gcd_tc(w %27, w %26) {
@67:
  jmp @39(%27, %26)
@39(%95, %96):
  %109 = eq.w %96, 0x0_w ; @80
  br %109, @66, @41
@41:
  %76 = rem.w %95, %96 ; @43
  jmp @39(%96, %76)
@66:
  ret %95
}

export function w $sum7(w %31, w %32, w %34, w %35, w %37, w %38, w %42) {
@45:
  %110 = add.w %31, %32 ; @81
  %111 = add.w %34, %35 ; @82
  %112 = add.w %37, %38 ; @83
  %113 = add.w %110, %111 ; @84
  %116 = add.w %112, %42 ; @87
  %117 = add.w %113, %116 ; @88
  ret %117
}

export function w $tail_sum7_stk(w %44, w %45, w %46, w %47, w %48, w %49, w %50) {
@52:
  %84 = call.w $sum7(%44, %45, %46, %47, %48, %49, %50) ; @53
  ret %84
}

export function w $gcd_nt(w %53, w %52) {
@54:
  %119 = eq.w %52, 0x0_w ; @90
  br %119, @68(%53), @56
@56:
  %86 = rem.w %53, %52 ; @58
  %87 = call.w nontail $gcd_nt(%52, %86) ; @59
  jmp @68(%87)
@68(%97):
  ret %97
}
