module tailcall

export function w $ping(w %n) {
@2:
  %18 = sle.w %n, 0x0_w ; @69
  br %18, @60(0x0_w), @4
@4:
  %19 = sub.w %n, 0x1_w ; @70
  %r.1 = call.w $pong(%19) ; @7
  jmp @60(%r.1)
@60(%8):
  ret %8
}

export function w $pong(w %n) {
@8:
  %20 = sle.w %n, 0x0_w ; @71
  br %20, @61(0x1_w), @10
@10:
  %21 = sub.w %n, 0x1_w ; @72
  %r.1 = call.w $ping(%21) ; @13
  jmp @61(%r.1)
@61(%9):
  ret %9
}

export function w $ping_nontail(w %n) {
@14:
  %22 = sle.w %n, 0x0_w ; @73
  br %22, @62(0x0_w), @16
@16:
  %23 = sub.w %n, 0x1_w ; @74
  %r.1 = call.w nontail $pong(%23) ; @19
  jmp @62(%r.1)
@62(%10):
  ret %10
}

export function w $call_and_ignore(w %n) {
@20:
  %24 = sle.w %n, 0x0_w ; @75
  br %24, @63, @22
@22:
  %25 = sub.w %n, 0x1_w ; @76
  %ignored.1 = call.w $pong(%25) ; @25
  jmp @63
@63:
  ret %n
}

export function w $dispatch(w %x, w %y) {
@26:
  %26 = slt.w %x, %y ; @77
  br %26, @27, @28
@27:
  %r.1 = call.w $ping(%x) ; @30
  jmp @64(%r.1)
@28:
  %r.2 = call.w $pong(%y) ; @31
  jmp @64(%r.2)
@64(%12):
  ret %12
}

export function w $mixed_tail(w %x, w %y) {
@32:
  %27 = eq.w %x, 0x0_w ; @78
  br %27, @33, @34
@33:
  %r.1 = call.w nontail $pong(%y) ; @36
  jmp @65(%r.1)
@34:
  %28 = sub.w %x, 0x1_w ; @79
  %r.2 = call.w $ping(%28) ; @38
  jmp @65(%r.2)
@65(%13):
  ret %13
}

export function w $gcd_tc(w %a, w %b) {
@67:
  jmp @39(%a, %b)
@39(%15, %16):
  %29 = eq.w %16, 0x0_w ; @80
  br %29, @66, @41
@41:
  %r.1 = rem.w %15, %16 ; @43
  jmp @39(%16, %r.1)
@66:
  ret %15
}

export function w $sum7(w %a, w %b, w %c, w %d, w %e, w %f, w %g) {
@45:
  %30 = add.w %a, %b ; @81
  %31 = add.w %c, %d ; @82
  %32 = add.w %e, %f ; @83
  %33 = add.w %30, %31 ; @84
  %36 = add.w %32, %g ; @87
  %37 = add.w %33, %36 ; @88
  ret %37
}

export function w $tail_sum7_stk(w %a, w %b, w %c, w %d, w %e, w %f, w %g) {
@52:
  %r.1 = call.w $sum7(%a, %b, %c, %d, %e, %f, %g) ; @53
  ret %r.1
}

export function w $gcd_nt(w %a, w %b) {
@54:
  %39 = eq.w %b, 0x0_w ; @90
  br %39, @68(%a), @56
@56:
  %r.1 = rem.w %a, %b ; @58
  %s.1 = call.w nontail $gcd_nt(%b, %r.1) ; @59
  jmp @68(%s.1)
@68(%17):
  ret %17
}
