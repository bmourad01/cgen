module foo

export function sw $foo(l %1, l %3) {
@2:
  jmp @3(%3, %1)
@3(%8, %9):
  %10 = ld.b %9 ; @5
  %11 = ld.b %8 ; @6
  %18 = ne.b %10, 0x0_b ; @16
  br %18, @7, @8
@7:
  %21 = eq.b %10, %11 ; @19
  br %21, @10, @8
@10:
  %22 = add.l %9, 0x1_l ; @20
  %23 = add.l %8, 0x1_l ; @21
  jmp @3(%23, %22)
@8:
  %19 = sub.b %10, %11 ; @17
  %20 = sext.w %19 ; @18
  ret %20
}
