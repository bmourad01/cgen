module qsort

function $swap(l %1, l %3) {
start:
  %25 = ld.w %1;
  %26 = ld.w %3;
  st.w %25, %3;
  st.w %26, %1;
  ret
}

function l $partition(l %6, l %9, l %5) {
start:
  %60 = lsl.l %5, 0x2_l;
  %61 = add.l %6, %60;
  %29 = ld.w %61;
  %62 = sub.l %9, 0x1_l;
  %63 = sub.l %5, 0x1_l;
  %32 = copy.l %9;
  %33 = copy.l %62;
  while sle.l %32, %63 {
    %65 = lsl.l %32, 0x2_l;
    %66 = add.l %6, %65;
    %38 = ld.w %66;
    if sle.w %38, %29 {
      %69 = add.l %33, 0x1_l;
      %70 = lsl.l %69, 0x2_l;
      %71 = add.l %6, %70;
      call $swap(%71, %66);
      %40 = copy.l %69
    } else {
      %40 = copy.l %33
    };
    %68 = add.l %32, 0x1_l;
    %32 = copy.l %68;
    %33 = copy.l %40
  };
  %72 = add.l %33, 0x1_l;
  %73 = lsl.l %72, 0x2_l;
  %74 = add.l %6, %73;
  call $swap(%74, %61);
  ret %72
}

export function $qsort(l %22, l %19, l %20) {
start:
  %57 = copy.l %22;
  %58 = copy.l %19;
  %59 = copy.l %20;
  while slt.l %58, %59 {
    %54 = call.l $partition(%57, %58, %59);
    %76 = sub.l %54, 0x1_l;
    call $qsort(%57, %58, %76);
    %77 = add.l %54, 0x1_l;
    %58 = copy.l %77
  };
  ret
}
