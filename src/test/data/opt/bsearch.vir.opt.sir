module bsearch

export function w $intcmp(l %1, l %3) {
start:
  %16 = ld.w %1;
  %17 = ld.w %3;
  %34 = sub.w %16, %17;
  ret %34
}

export function l $bsearch(l %14, l %11, l %6, l %9, l %13) {
start:
  %19 = copy.l %11;
  %20 = copy.l %6;
  loop {
    if ne.l %20, 0x0_l {
      %36 = lsr.l %20, 0x1_l;
      %37 = mul.l %9, %36;
      %38 = add.l %19, %37;
      %25 = call.w %13(%14, %38);
      if slt.w %25, 0x0_w {
        %20 = copy.l %36
      } else {
        if sgt.w %25, 0x0_w {
          %41 = add.l %38, %9;
          %42 = add.l %36, 0x1_l;
          %43 = sub.l %20, %42;
          %19 = copy.l %41;
          %20 = copy.l %43
        } else {
          %33 = copy.l %38;
          break
        }
      }
    } else {
      %33 = copy.l 0x0_l;
      break
    }
  };
  ret %33
}
