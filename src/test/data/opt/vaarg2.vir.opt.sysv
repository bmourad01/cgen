module vaarg2

export function $foo(b %27/rax, l %8/rdi, ...) {
  %21 = slot 176, align 16
  %92 = slot 8, align 8
@18:
  %102 = add.l %21, 0x8_l ; @19
  regstore rsi, %102 ; @20
  %103 = add.l %21, 0x10_l ; @21
  regstore rdx, %103 ; @22
  %104 = add.l %21, 0x18_l ; @23
  regstore rcx, %104 ; @24
  %105 = add.l %21, 0x20_l ; @25
  regstore r8, %105 ; @26
  %106 = add.l %21, 0x28_l ; @27
  regstore r9, %106 ; @28
  %107 = eq.b %27, 0x0_b ; @29
  br %107, @2, @17
@17:
  %143 = add.l %21, 0x30_l ; @30
  regstore xmm0, %143 ; @31
  %144 = add.l %21, 0x40_l ; @32
  regstore xmm1, %144 ; @33
  %145 = add.l %21, 0x50_l ; @34
  regstore xmm2, %145 ; @35
  %146 = add.l %21, 0x60_l ; @36
  regstore xmm3, %146 ; @37
  %147 = add.l %21, 0x70_l ; @38
  regstore xmm4, %147 ; @39
  %148 = add.l %21, 0x80_l ; @40
  regstore xmm5, %148 ; @41
  %149 = add.l %21, 0x90_l ; @42
  regstore xmm6, %149 ; @43
  %150 = add.l %21, 0xa0_l ; @44
  regstore xmm7, %150 ; @45
  jmp @2
@2:
  st.w 0x8_w, %92 ; @52
  %109 = add.l %92, 0x4_l ; @139
  st.w 0x30_w, %109 ; @54
  %110 = stkargs ; @55
  jmp @61
@61:
  %115 = ld.w %92 ; @65
  %116 = le.w %115, 0x20_w ; @66
  br %116, @62, @63
@62:
  %136 = zext.l %115 ; @69
  %137 = add.l %21, %136 ; @70
  %138 = add.w %115, 0x10_w ; @71
  st.w %138, %92 ; @72
  jmp @64(%137)
@63:
  jmp @64(%110)
@64(%117):
  %118 = ld.l %117 ; @77
  %120 = add.l %117, 0x8_l ; @79
  %121 = ld.l %120 ; @80
  jmp @60
@60:
  st.l %118, %92 ; @47
  %132 = add.l %118, %121 ; @15
  %133 = add.l %132, %8 ; @16
  ret rax/%133
}

export function $bar(b %67/rax, ...) {
  %61 = slot 176, align 16
@84:
  regstore rdi, %61 ; @85
  %151 = add.l %61, 0x8_l ; @86
  regstore rsi, %151 ; @87
  %152 = add.l %61, 0x10_l ; @88
  regstore rdx, %152 ; @89
  %153 = add.l %61, 0x18_l ; @90
  regstore rcx, %153 ; @91
  %154 = add.l %61, 0x20_l ; @92
  regstore r8, %154 ; @93
  %155 = add.l %61, 0x28_l ; @94
  regstore r9, %155 ; @95
  %156 = eq.b %67, 0x0_b ; @96
  br %156, @11, @83
@83:
  %179 = add.l %61, 0x30_l ; @97
  regstore xmm0, %179 ; @98
  %180 = add.l %61, 0x40_l ; @99
  regstore xmm1, %180 ; @100
  %181 = add.l %61, 0x50_l ; @101
  regstore xmm2, %181 ; @102
  %182 = add.l %61, 0x60_l ; @103
  regstore xmm3, %182 ; @104
  %183 = add.l %61, 0x70_l ; @105
  regstore xmm4, %183 ; @106
  %184 = add.l %61, 0x80_l ; @107
  regstore xmm5, %184 ; @108
  %185 = add.l %61, 0x90_l ; @109
  regstore xmm6, %185 ; @110
  %186 = add.l %61, 0xa0_l ; @111
  regstore xmm7, %186 ; @112
  jmp @11
@11:
  jmp @122
@122:
  jmp @123
@123:
  %172 = add.l %61, 0x0_l ; @131
  jmp @125
@125:
  %168 = ld.b %172 ; @138
  jmp @121
@121:
  ret rax/%168
}
