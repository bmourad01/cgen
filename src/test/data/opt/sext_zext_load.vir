@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
  %h = ld.h %q
  %r = zext.l %h
  ret %r
}

;; base + index*scale - disp

export function l $sext_b_l_add_mul_disp_neg(l %p, l %i) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = sub.l %a, 16_l
  %b = ld.b %q
  %r = sext.l %b
  ret %r
}

export function l $sext_h_l_add_mul_disp_neg(l %p, l %i) {
@start:
