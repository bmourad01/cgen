  cmp edi, 0x1_w ; @34
  je @9 ; @35
@10:
  lea eax, qword ptr [rdi + rdi*4 + 0x6] ; @25
  jmp @7 ; @33
@9:
  lea eax, qword ptr [rdi + rdi*4 + 0x5] ; @24
  jmp @7 ; @31
@3:
  lea eax, qword ptr [rdi + rdi*4 + 0x1] ; @20
@7:
