module bsearch

export function $intcmp { ; returns: rax
@2:
  mov eax, dword ptr [rdi] ; @41
  sub eax, dword ptr [rsi] ; @39
  ret ; @38
}

export function $bsearch { ; returns: rax
@6:
  push rbp ; @83
  mov rbp, rsp ; @84
  sub rsp, 0x18_l ; @85
  push r12 ; @86
  push r13 ; @87
  push r14 ; @88
  push r15 ; @89
  push rbx ; @90
  mov qword ptr [rbp - 0x10], rdi ; @79
  mov r13, rsi ; @72
  mov r12, rdx ; @73
  mov r15, rcx ; @74
  mov qword ptr [rbp - 0x18], r8 ; @80
@7:
  test r12, r12 ; @68
  jne @8 ; @69
@42:
  xor eax, eax ; @66
  jmp @26 ; @67
@8:
  mov rbx, r12 ; @29
  shr rbx, 0x1_b ; @65
  mov rax, r15 ; @30
  imul rax, rbx ; @64
  lea r14, qword ptr [r13 + rax*1] ; @31
  mov rdi, qword ptr [rbp - 0x10] ; @81
  mov rsi, r14 ; @61
  call qword ptr [rbp - 0x18] ; rdi rsi ; @62
  test eax, eax ; @58
  jns @12 ; @59
@43:
  mov r12, rbx ; @56
  jmp @7 ; @57
@12:
  cmp eax, 0x0_w ; @53
  jg @19 ; @54
@44:
  mov rax, r14 ; @51
@26:
  pop rbx ; @91
  pop r15 ; @92
  pop r14 ; @93
  pop r13 ; @94
  pop r12 ; @95
  leave ; @96
  ret ; @50
@19:
  lea rax, qword ptr [rbx + 0x1] ; @34
  lea r13, qword ptr [r14 + r15*1] ; @35
  sub r12, rax ; @48
  jmp @7 ; @47
}
