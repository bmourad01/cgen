module foo

export function sw $foo(l %1, l %3) {
@2:
  jmp @3(%3, %1)
@3(%8, %9):
  %10 = ld.b %9 ; @5
  %11 = ld.b %8 ; @6
  %20 = ne.b %10, 0x0_b ; @18
  br %20, @7, @8
@7:
  %23 = eq.b %10, %11 ; @21
  br %23, @10, @8
@10:
  %24 = add.l %9, 0x1_l ; @22
  %25 = add.l %8, 0x1_l ; @23
  jmp @3(%25, %24)
@8:
  %21 = sub.b %10, %11 ; @19
  %22 = sext.w %21 ; @20
  ret %22
}
