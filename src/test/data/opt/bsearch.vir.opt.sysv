module bsearch

export function $intcmp(l %1/rdi, l %3/rsi) {
@2:
  %16 = ld.w %1 ; @3
  %17 = ld.w %3 ; @4
  %34 = sub.w %16, %17 ; @27
  ret rax/%34
}

export function $bsearch(l %14/rdi, l %11/rsi, l %6/rdx, l %9/rcx, l %13/r8) {
@6:
  jmp @7(%11, %6)
@7(%19, %20):
  %35 = ne.l %20, 0x0_l ; @28
  br %35, @8, @26(0x0_l)
@8:
  %36 = lsr.l %20, 0x1_l ; @29
  %37 = mul.l %9, %36 ; @30
  %38 = add.l %19, %37 ; @31
  %25/w/rax = call %13(%14/rdi, %38/rsi) ; @16
  %39 = slt.w %25, 0x0_w ; @32
  br %39, @7(%19, %36), @12
@12:
  %40 = sgt.w %25, 0x0_w ; @33
  br %40, @19, @26(%38)
@19:
  %41 = add.l %38, %9 ; @34
  %42 = add.l %36, 0x1_l ; @35
  %43 = sub.l %20, %42 ; @36
  jmp @7(%41, %43)
@26(%33):
  ret rax/%33
}
