module evenodd

function $abs { ; returns: rax
@2:
  mov eax, edi ; @25
  mov ecx, eax ; @26
  neg ecx ; @36
  test eax, eax ; @34
  cmovs eax, ecx ; @35
  ret ; @33
}

export function $even { ; returns: rax
@7:
  push rbp ; @60
  mov rbp, rsp ; @61
  call $abs ; rdi ; @48
  test eax, eax ; @44
  jne @9 ; @45
@23:
  mov eax, 0x1_w ; @42
  leave ; @62
  ret ; @43
@9:
  lea edi, qword ptr [rax - 0x1] ; @29
  leave ; @63
  tailcall $odd ; rdi ; @41
}

export function $odd { ; returns: rax
@14:
  push rbp ; @64
  mov rbp, rsp ; @65
  call $abs ; rdi ; @58
  test eax, eax ; @54
  jne @16 ; @55
@24:
  xor eax, eax ; @52
  leave ; @66
  ret ; @53
@16:
  lea edi, qword ptr [rax - 0x1] ; @31
  leave ; @67
  tailcall $even ; rdi ; @51
}
