module evenodd

function $abs { ; returns: rax
@2:
  mov eax, edi ; @25
  mov ecx, eax ; @26
  neg ecx ; @36
  test eax, eax ; @34
  cmovs eax, ecx ; @35
  ret ; @33
}

export function $even { ; returns: rax
@7:
  push rbp ; @64
  mov rbp, rsp ; @65
  call $abs ; rdi ; @50
  test eax, eax ; @44
  jne @9 ; @45
@23:
  mov al, 0x1_b ; @42
  leave ; @66
  ret ; @43
@9:
  lea edi, qword ptr [rax - 0x1] ; @29
  leave ; @67
  tailcall $odd ; rdi ; @41
}

export function $odd { ; returns: rax
@14:
  push rbp ; @68
  mov rbp, rsp ; @69
  call $abs ; rdi ; @62
  test eax, eax ; @56
  jne @16 ; @57
@24:
  xor al, al ; @54
  leave ; @70
  ret ; @55
@16:
  lea edi, qword ptr [rax - 0x1] ; @31
  leave ; @71
  tailcall $even ; rdi ; @53
}
