module imm32_boundary

export function w $sge_branch(l %x) {
@start:
  %c = sge.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $sgt_branch(l %x) {
@start:
  %c = sgt.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $sle_branch(l %x) {
@start:
  %c = sle.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $slt_branch(l %x) {
@start:
  %c = slt.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $eq_branch(l %x) {
@start:
  %c = eq.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $ne_branch(l %x) {
@start:
  %c = ne.l %x, 2147483648_l
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
