module vasum

export function $sum(b %25/rax, w %4/rdi, ...) {
  %19 = slot 176, align 16
@19:
  %54 = add.l %19, 0x8_l ; @20
  regstore rsi, %54 ; @21
  %55 = add.l %19, 0x10_l ; @22
  regstore rdx, %55 ; @23
  %56 = add.l %19, 0x18_l ; @24
  regstore rcx, %56 ; @25
  %57 = add.l %19, 0x20_l ; @26
  regstore r8, %57 ; @27
  %58 = add.l %19, 0x28_l ; @28
  regstore r9, %58 ; @29
  %59 = eq.b %25, 0x0_b ; @30
  br %59, @2, @18
@18:
  %91 = add.l %19, 0x30_l ; @31
  regstore xmm0, %91 ; @32
  %92 = add.l %19, 0x40_l ; @33
  regstore xmm1, %92 ; @34
  %93 = add.l %19, 0x50_l ; @35
  regstore xmm2, %93 ; @36
  %94 = add.l %19, 0x60_l ; @37
  regstore xmm3, %94 ; @38
  %95 = add.l %19, 0x70_l ; @39
  regstore xmm4, %95 ; @40
  %96 = add.l %19, 0x80_l ; @41
  regstore xmm5, %96 ; @42
  %97 = add.l %19, 0x90_l ; @43
  regstore xmm6, %97 ; @44
  %98 = add.l %19, 0xa0_l ; @45
  regstore xmm7, %98 ; @46
  jmp @2
@2:
  %63 = stkargs ; @50
  jmp @3(%63, 0x8_w, 0x0_w, 0x0_w)
@3(%68, %69, %70, %71):
  %72 = lt.w %71, %4 ; @15
  br %72, @7, @8
@7:
  jmp @56
@56:
  %74 = le.w %69, 0x28_w ; @61
  br %74, @57, @58
@57:
  %83 = zext.l %69 ; @64
  %84 = add.l %19, %83 ; @65
  %85 = add.w %69, 0x8_w ; @66
  jmp @59(%68, %85, %84)
@58:
  %89 = add.l %68, 0x8_l ; @70
  jmp @59(%89, %69, %68)
@59(%75, %76, %77):
  %78 = ld.w %77 ; @72
  jmp @55
@55:
  %79 = add.w %70, %78 ; @16
  %80 = add.w %71, 0x1_w ; @17
  jmp @3(%75, %76, %79, %80)
@8:
  ret rax/%70
}

export function $twenty_eight() {
@13:
  %15/w/rax = call $sum(0x7_w/rdi, 0x1_w/rsi, 0x2_w/rdx, 0x3_w/rcx, 0x4_w/r8, 0x5_w/r9, 0x6_w/+0, 0x7_w/+8, 0x0_b/rax)
  ; @14
  ret rax/%15
}
