module esc1

export function w $foo(w %3) {
  %0 = slot 8, align 8
  %1 = slot 8, align 8
@2:
  %22 = add.w %3, 0x1_w ; @20
  %23 = add.w %3, 0x2_w ; @21
  %24 = add.w %3, 0x3_w ; @22
  st.w %3, %0 ; @8
  %25 = add.l %0, 0x4_l ; @23
  st.w %22, %25 ; @10
  st.w %23, %1 ; @11
  %26 = add.l %1, 0x4_l ; @24
  st.w %24, %26 ; @13
  %27 = slt.w %3, 0x0_w ; @25
  %28 = sel.l %27, %26, %25 ; @26
  %18 = ld.w %28 ; @18
  ret %18
}
