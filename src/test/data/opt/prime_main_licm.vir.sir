module prime_main_licm

const data $fmt = {
  "prime(%d) = %d\n",
  0x0_b
}

export function w $main(w %8, l %1) {
start:
  %9 = add.l %1, 0x8_l;
  %10 = ld.l %9;
  %11 = call.w $atoi(%10);
  %12 = copy.w 0x1_w;
  %13 = copy.w 0x1_w;
  %14 = copy.w %13;
  %15 = copy.w %12;
  %16 = copy.w %11;
  while sgt.w %16, 0x0_w {
    %18 = copy.w %14;
    loop {
      %19 = call.w $is_prime(%18);
      if eq.w %19, 0x0_w {
        %21 = add.w %18, 0x1_w;
        %18 = copy.w %21
      } else {
        break
      }
    };
    %22 = call.w $printf($fmt, ..., %15, %18);
    %23 = sub.w %16, 0x1_w;
    %24 = add.w %18, 0x1_w;
    %25 = add.w %15, 0x1_w;
    %14 = copy.w %24;
    %15 = copy.w %25;
    %16 = copy.w %23
  };
  ret 0x0_w
}
