module popcnt

export function b $popcnt8(b %1) {
@2:
  %12 = popcnt.b %1 ; @10
  ret %12
}

export function h $popcnt16(h %3) {
@4:
  %13 = popcnt.h %3 ; @11
  ret %13
}

export function w $popcnt32(w %5) {
@6:
  %14 = popcnt.w %5 ; @12
  ret %14
}

export function l $popcnt64(l %7) {
@8:
  %15 = popcnt.l %7 ; @13
  ret %15
}
