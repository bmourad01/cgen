module vasum

export function $sum { ; returns: rax
@19:
  push rbp ; @121
  mov rbp, rsp ; @122
  sub rsp, 0xc0_l ; @123
  mov qword ptr [rbp - 0xb8], rsi ; @21
  mov qword ptr [rbp - 0xb0], rdx ; @23
  mov qword ptr [rbp - 0xa8], rcx ; @25
  mov qword ptr [rbp - 0xa0], r8 ; @27
  mov qword ptr [rbp - 0x98], r9 ; @29
  test al, al ; @102
  je @2 ; @103
@18:
  movdqa xmmword ptr [rbp - 0x90], xmm0 ; @32
  movdqa xmmword ptr [rbp - 0x80], xmm1 ; @34
  movdqa xmmword ptr [rbp - 0x70], xmm2 ; @36
  movdqa xmmword ptr [rbp - 0x60], xmm3 ; @38
  movdqa xmmword ptr [rbp - 0x50], xmm4 ; @40
  movdqa xmmword ptr [rbp - 0x40], xmm5 ; @42
  movdqa xmmword ptr [rbp - 0x30], xmm6 ; @44
  movdqa xmmword ptr [rbp - 0x20], xmm7 ; @46
@2:
  lea rcx, qword ptr [rbp + 0x10] ; @50
  mov edx, 0x8_w ; @97
  xor eax, eax ; @98
  xor r9d, r9d ; @99
@3:
  cmp r9d, edi ; @93
  jb @56 ; @94
@8:
  leave ; @124
  ret ; @92
@56:
  cmp edx, 0x28_w ; @87
  jbe @57 ; @88
@58:
  lea rsi, qword ptr [rcx + 0x8] ; @70
  mov r8, rcx ; @85
  jmp @59 ; @86
@57:
  lea r8, qword ptr [rbp + rdx*1 - 0xc0] ; @65
  add edx, 0x8_w ; @66
  mov rsi, rcx ; @79
@59:
  add eax, dword ptr [r8] ; @16
  inc r9d ; @17
  mov rcx, rsi ; @73
  jmp @3 ; @77
}

export function $twenty_eight { ; returns: rax
@13:
  push rbp ; @125
  mov rbp, rsp ; @126
  mov edi, 0x7_w ; @14
  mov esi, 0x1_w ; @109
  mov edx, 0x2_w ; @110
  mov ecx, 0x3_w ; @111
  mov r8d, 0x4_w ; @112
  mov r9d, 0x5_w ; @113
  sub rsp, 0x10_l ; @114
  mov dword ptr [rsp], 0x6_w ; @115
  mov dword ptr [rsp + 0x8], 0x7_w ; @116
  xor eax, eax ; @117
  call $sum ; r8 r9 rax rcx rdi rdx rsi ; @118
  leave ; @127
  ret ; @108
}
