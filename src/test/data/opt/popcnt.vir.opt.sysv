module popcnt

export function $popcnt8(b %1/rdi) {
@2:
  %12 = popcnt.b %1 ; @10
  ret rax/%12
}

export function $popcnt16(h %3/rdi) {
@4:
  %13 = popcnt.h %3 ; @11
  ret rax/%13
}

export function $popcnt32(w %5/rdi) {
@6:
  %14 = popcnt.w %5 ; @12
  ret rax/%14
}

export function $popcnt64(l %7/rdi) {
@8:
  %15 = popcnt.l %7 ; @13
  ret rax/%15
}
