  jmp @34 ; @60
@39:
  cmp %0:w, 0xffffffff_w ; @56
  jae @48 ; @57
  jmp @49 ; @58
@48:
  mov %3:w, 0x63_w ; @54
  jmp @34 ; @55
@49:
  xor %3:w, %3:w ; @52
  jmp @34 ; @53
@34:
  mov eax, %3:w ; @50
  ret ; @51
}

