module switchlower

export function $scan { ; returns: rax
@2:
  mov %0:w, edi ; @76
  cmp %0:w, 0x30_w ; @77
  jb @39 ; @78
  mov %9:w, %0:w ; zx ; @79
  sub %9:l, 0x30_l ; @80
  cmp %9:l, 0x7_l ; @81
  ja @39 ; @82
  lea %8:l, qword ptr [rip + @75] ; @83
  movsxd %10:l, dword ptr [%8 + %9*4] ; @84
