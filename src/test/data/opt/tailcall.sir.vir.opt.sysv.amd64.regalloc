module tailcall

export function $ping { ; returns: rax
@2:
  cmp edi, 0x0_w ; @95
  jg @4 ; @96
@60:
  xor eax, eax ; @93
  ret ; @94
@4:
  dec edi ; @70
  tailcall $pong ; rdi ; @92
}

export function $pong { ; returns: rax
@8:
  cmp edi, 0x0_w ; @105
  jg @10 ; @106
@61:
  mov eax, 0x1_w ; @103
  ret ; @104
@10:
  dec edi ; @72
