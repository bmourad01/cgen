export function $sum7 { ; returns: rax
@45:
  push rbp ; @241
  mov rbp, rsp ; @242
  mov eax, dword ptr [rbp + 0x10] ; @81
  add esi, edi ; @188
  add ecx, edx ; @82
  lea edx, qword ptr [r8 + r9*1] ; @83
  add ecx, esi ; @84
  add eax, edx ; @87
  add eax, ecx ; @88
  leave ; @243
  ret ; @181
}

export function $tail_sum7_stk { ; returns: rax
@52:
  push rbp ; @244
  mov rbp, rsp ; @245
