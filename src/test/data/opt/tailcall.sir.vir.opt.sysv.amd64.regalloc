  push rbx ; @234
  mov ebx, edi ; @75
  cmp ebx, 0x0_w ; @131
  jle @63 ; @132
@22:
  lea edi, qword ptr [rbx - 0x1] ; @76
  call $pong ; rdi ; @129
@63:
  mov eax, ebx ; @126
  pop rbx ; @235
  leave ; @236
  ret ; @127
}

export function $dispatch {
@26:
  mov eax, edi ; @77
  mov edi, esi ; @144
  cmp eax, esi ; @141
  jl @27 ; @142
@28:
  tailcall $pong ; rdi ; @140
@27:
  mov edi, eax ; @137
