module addcalls

export function $foo() {
@2:
  %3/w/rax = call $bar() ; @4
  %5/w/rax = call $bar() ; @6
  %7/w/rax = call $bar() ; @8
  %20 = add.w %5, %7 ; @21
  %9/w/rax = call $bar() ; @10
  %11/w/rax = call $bar() ; @12
  %24 = add.w %9, %11 ; @25
  %26 = add.w %20, %24 ; @27
  %13/w/rax = call $bar() ; @14
  %15/w/rax = call $bar() ; @16
  %30 = add.w %13, %15 ; @31
  %17/w/rax = call $bar() ; @18
  %34 = add.w %30, %17 ; @35
  %35 = add.w %26, %34 ; @36
  %36 = add.w %3, %35 ; @37
  ret rax/%36
}
