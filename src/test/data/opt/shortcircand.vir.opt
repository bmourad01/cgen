module foo

export function w $foo(l %3, l %1) {
@2:
  %12 = slt.l %1, 0x3_l ; @13
  br %12, @3, @12(0xffffffff_w)
@3:
  %13 = sge.l %1, 0x0_l ; @14
  br %13, @7, @12(0xffffffff_w)
@7:
  %14 = lsl.l %1, 0x2_l ; @15
  %15 = add.l %3, %14 ; @16
  %9 = ld.w %15 ; @11
  jmp @12(%9)
@12(%11):
  ret %11
}
