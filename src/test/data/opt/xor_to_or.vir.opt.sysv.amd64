module xor_to_or

export function $foo { ; returns: rax
@2:
  mov %1:w, edi ; @12
  mov %2:w, esi ; @18
  mov %18:w, %1:w ; @19
  or %18:w, %2:w ; @20
  mov eax, %18:w ; @16
  ret ; @17
}

export function $bar { ; returns: rax
@6:
  mov %6:w, edi ; @15
  mov %7:w, esi ; @23
  mov %21:w, %6:w ; @24
  or %21:w, %7:w ; @25
  mov eax, %21:w ; @21
  ret ; @22
}
