module palindrome

export function b $palindrome(w %2) {
@2:
  jmp @3(%2, 0x0_w)
@3(%8, %9):
  %17 = ne.w %8, 0x0_w ; @15
  br %17, @6, @7
@6:
  %18 = mulh.w %8, 0x66666667_w ; @16
  %19 = asr.w %18, 0x2_w ; @17
  %20 = lsr.w %18, 0x1f_w ; @18
  %21 = add.w %19, %20 ; @19
  %22 = mul.w %21, 0xa_w ; @20
  %23 = sub.w %8, %22 ; @21
  %29 = lsl.w %9, 0x3_w ; @27
  %30 = lsl.w %9, 0x1_w ; @28
  %31 = add.w %29, %30 ; @29
  %32 = add.w %31, %23 ; @30
  jmp @3(%21, %32)
@7:
  %35 = eq.w %2, %9 ; @33
  %36 = flag.b %35 ; @34
  ret %36
}
