module union

export function $getint(l %1/rdi) {
  %109 = slot 8, align 8
@2:
  st.l %1, %109 ; @80
  %210 = ld.w %109 ; @81
  ret rax/%210
}

export function $mkfloat(s %4/xmm0) {
  %111 = slot 8, align 8
@5:
  %214 = ifbits.w %4 ; @83
  st.w %214, %111 ; @84
  %215 = ld.l %111 ; @85
  ret rax/%215
}

export function $struct_with_union(l %7/rdi) {
  %6 = slot 8, align 8
@8:
  st.l %7, %6 ; @88
  %218 = add.l %6, 0x4_l ; @67
  %219 = ld.w %218 ; @11
  ret rax/%219
}

export function $get_sse_d(d %11/xmm0) {
  %116 = slot 8, align 8
@12:
  st.d %11, %116 ; @89
  ret xmm0/%11
}

export function $mk_sse_d(d %14/xmm0) {
  %118 = slot 8, align 8
@15:
  st.d %14, %118 ; @16
  ret xmm0/%14
}

export function $sum_u2(l %122/rdi, l %123/rsi) {
@18:
  %232 = add.l %122, %123 ; @69
  ret rax/%232
}

export function $mk_u2(l %23/rdi, l %25/rsi) {
@24:
  ret rax/%23, rdx/%25
}

export function $sum_big(l %138/+0, l %139/+8, l %141/+16) {
@29:
  %265 = add.l %138, %139 ; @73
  %266 = add.l %265, %141 ; @74
  ret rax/%266
}

export function $mk_big(l %150/rdi, l %37/rsi, l %39/rdx, l %41/rcx) {
@38:
  st.l %37, %150 ; @129
  %275 = add.l %150, 0x8_l ; @132
  st.l %39, %275 ; @133
  %278 = add.l %150, 0x10_l ; @136
  st.l %41, %278 ; @137
  ret rax/%150
}

export function $s2_union_l(l %159/rdi, l %160/rsi) {
@45:
  ret rax/%159
}

export function $s2_w(l %167/rdi, l %168/rsi) {
  %207 = slot 8, align 8
@48:
  st.l %168, %207 ; @155
  %298 = ld.w %207 ; @51
  ret rax/%298
}

export function $us_first(l %51/rdi) {
  %50 = slot 8, align 8
@52:
  st.l %51, %50 ; @158
  %301 = ld.w %50 ; @54
  ret rax/%301
}

export function $us_second(l %54/rdi) {
  %53 = slot 8, align 8
@55:
  st.l %54, %53 ; @161
  %304 = add.l %53, 0x4_l ; @78
  %305 = ld.w %304 ; @58
  ret rax/%305
}

export function $mk_us_pair(w %58/rdi, w %60/rsi) {
  %57 = slot 8, align 8
@59:
  st.w %58, %57 ; @60
  %306 = add.l %57, 0x4_l ; @79
  st.w %60, %306 ; @62
  %307 = ld.l %57 ; @162
  ret rax/%307
}

export function $us_as_d(l %63/rdi) {
@64:
  %313 = fibits.d %63 ; @66
  ret xmm0/%313
}
