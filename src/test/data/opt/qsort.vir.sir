module qsort

function $swap(l %1, l %3) {
start:
  %25 = ld.w %1;
  %26 = ld.w %3;
  st.w %25, %3;
  st.w %26, %1;
  ret
}

function l $partition(l %6, l %9, l %5) {
start:
  %27 = mul.l %5, 0x4_l;
  %28 = add.l %6, %27;
  %29 = ld.w %28;
  %30 = sub.l %9, 0x1_l;
  %31 = copy.l %9;
  %32 = copy.l %31;
  %33 = copy.l %30;
  loop {
    %34 = sub.l %5, 0x1_l;
    if sle.l %32, %34 {
      %36 = mul.l %32, 0x4_l;
      %37 = add.l %6, %36;
      %38 = ld.w %37;
      if sle.w %38, %29 {
        %42 = add.l %33, 0x1_l;
        %43 = mul.l %42, 0x4_l;
        %44 = add.l %6, %43;
        %45 = mul.l %32, 0x4_l;
        %46 = add.l %6, %45;
        call $swap(%44, %46);
        %40 = copy.l %42
      } else {
        %40 = copy.l %33
      };
      %41 = add.l %32, 0x1_l;
      %32 = copy.l %41;
      %33 = copy.l %40
    } else {
      break
    }
  };
  %47 = mul.l %5, 0x4_l;
  %48 = add.l %6, %47;
  %49 = add.l %33, 0x1_l;
  %50 = mul.l %49, 0x4_l;
  %51 = add.l %6, %50;
  call $swap(%51, %48);
  %52 = add.l %33, 0x1_l;
  ret %52
}

export function $qsort(l %22, l %19, l %20) {
start:
  if slt.l %19, %20 {
    %54 = call.l $partition(%22, %19, %20);
    %55 = sub.l %54, 0x1_l;
    call $qsort(%22, %19, %55);
    %56 = add.l %54, 0x1_l;
    call $qsort(%22, %56, %20);
    ret
  } else {
    ret
  }
}
