;; conditional move

export function s $sel_f32(s %x, s %y, s %yes, s %no) {
@start:
  %c = lt.s %x, %y
  %r = sel.s %c, %yes, %no
  ret %r
}

export function d $sel_f64(d %x, d %y, d %yes, d %no) {
@start:
  %c = lt.d %x, %y
  %r = sel.d %c, %yes, %no
  ret %r
}

export function s $sel_f32_const_cmp(s %x, s %yes, s %no) {
@start:
  %c = lt.s %x, 0.0_s
  %r = sel.s %c, %yes, %no
  ret %r
}

export function s $sel_f32_const_cmp_lhs(s %x, s %yes, s %no) {
@start:
  %c = lt.s 0.0_s, %x
  %r = sel.s %c, %yes, %no
  ret %r
}

export function d $sel_f64_const_val(d %x, d %y, d %yes) {
@start:
  %c = lt.d %x, %y
  %r = sel.d %c, %yes, 0.0_d
  ret %r
}

export function d $sel_f64_const_cmp_lhs(d %x, d %yes, d %no) {
@start:
  %c = lt.d 0.0_d, %x
  %r = sel.d %c, %yes, %no
  ret %r
}

;; bit representation

export function w $ifbits_f32(s %x) {
@start:
  %r = ifbits.w %x
  ret %r
}

export function l $ifbits_f64(d %x) {
@start:
  %r = ifbits.l %x
  ret %r
}

export function s $fibits_f32(w %x) {
@start:
  %r = fibits.s %x
  ret %r
}

export function d $fibits_f64(l %x) {
@start:
  %r = fibits.d %x
  ret %r
}
