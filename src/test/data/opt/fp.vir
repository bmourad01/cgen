module fp

;; arithmetic

export function s $fadd_f32(s %x, s %y) {
@start:
  %r = add.s %x, %y
  ret %r
}

export function d $fadd_f64(d %x, d %y) {
@start:
  %r = add.d %x, %y
  ret %r
}

export function s $fsub_f32(s %x, s %y) {
@start:
  %r = sub.s %x, %y
  ret %r
}

export function d $fsub_f64(d %x, d %y) {
@start:
  %r = sub.d %x, %y
  ret %r
}

export function s $fmul_f32(s %x, s %y) {
@start:
  %r = mul.s %x, %y
  ret %r
}

export function d $fmul_f64(d %x, d %y) {
@start:
  %r = mul.d %x, %y
  ret %r
}

export function s $fdiv_f32(s %x, s %y) {
@start:
  %r = div.s %x, %y
  ret %r
}

export function d $fdiv_f64(d %x, d %y) {
@start:
  %r = div.d %x, %y
  ret %r
}

export function s $fneg_f32(s %x) {
@start:
  %r = neg.s %x
  ret %r
}

export function d $fneg_f64(d %x) {
@start:
  %r = neg.d %x
  ret %r
}

;; arithmetic with constant operands (constant as RHS)

export function s $fadd_f32_const(s %x) {
@start:
  %r = add.s %x, 1.5_s
  ret %r
}

export function d $fadd_f64_const(d %x) {
@start:
  %r = add.d %x, 1.5_d
  ret %r
}

export function s $fsub_f32_const(s %x) {
@start:
  %r = sub.s %x, 1.5_s
  ret %r
}

export function d $fsub_f64_const(d %x) {
@start:
  %r = sub.d %x, 1.5_d
  ret %r
}

export function s $fmul_f32_const(s %x) {
@start:
  %r = mul.s %x, 2.0_s
  ret %r
}

export function d $fmul_f64_const(d %x) {
@start:
  %r = mul.d %x, 2.0_d
  ret %r
}

export function s $fdiv_f32_const(s %x) {
@start:
  %r = div.s %x, 2.0_s
  ret %r
}

export function d $fdiv_f64_const(d %x) {
@start:
  %r = div.d %x, 2.0_d
  ret %r
}

export function s $fneg_f32_const() {
@start:
  %r = neg.s 1.5_s
  ret %r
}

export function d $fneg_f64_const() {
@start:
  %r = neg.d 1.5_d
  ret %r
}

;; arithmetic with constant operands (constant as LHS)

export function s $fadd_f32_const_lhs(s %x) {
@start:
  %r = add.s 1.5_s, %x
  ret %r
}

export function d $fadd_f64_const_lhs(d %x) {
@start:
  %r = add.d 1.5_d, %x
  ret %r
}

export function s $fsub_f32_const_lhs(s %x) {
@start:
  %r = sub.s 1.5_s, %x
  ret %r
}

export function d $fsub_f64_const_lhs(d %x) {
@start:
  %r = sub.d 1.5_d, %x
  ret %r
}

export function s $fmul_f32_const_lhs(s %x) {
@start:
  %r = mul.s 2.0_s, %x
  ret %r
}

export function d $fmul_f64_const_lhs(d %x) {
@start:
  %r = mul.d 2.0_d, %x
  ret %r
}

export function s $fdiv_f32_const_lhs(s %x) {
@start:
  %r = div.s 2.0_s, %x
  ret %r
}

export function d $fdiv_f64_const_lhs(d %x) {
@start:
  %r = div.d 2.0_d, %x
  ret %r
}

;; comparisons

export function w $flt_f32(s %x, s %y) {
@start:
  %c = lt.s %x, %y
  %r = flag.w %c
  ret %r
}

export function w $flt_f64(d %x, d %y) {
@start:
  %c = lt.d %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fle_f32(s %x, s %y) {
@start:
  %c = le.s %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fle_f64(d %x, d %y) {
@start:
  %c = le.d %x, %y
  %r = flag.w %c
  ret %r
}

export function w $feq_f32(s %x, s %y) {
@start:
  %c = eq.s %x, %y
  %r = flag.w %c
  ret %r
}

export function w $feq_f64(d %x, d %y) {
@start:
  %c = eq.d %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fne_f32(s %x, s %y) {
@start:
  %c = ne.s %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fne_f64(d %x, d %y) {
@start:
  %c = ne.d %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fuo_f32(s %x, s %y) {
@start:
  %c = uo.s %x, %y
  %r = flag.w %c
  ret %r
}

export function w $fo_f64(d %x, d %y) {
@start:
  %c = o.d %x, %y
  %r = flag.w %c
  ret %r
}

;; comparisons with constants (constant as RHS)

export function w $flt_f32_const(s %x) {
@start:
  %c = lt.s %x, 0.0_s
  %r = flag.w %c
  ret %r
}

export function w $flt_f64_const(d %x) {
@start:
  %c = lt.d %x, 0.0_d
  %r = flag.w %c
  ret %r
}

export function w $feq_f32_const(s %x) {
@start:
  %c = eq.s %x, 1.0_s
  %r = flag.w %c
  ret %r
}

export function w $feq_f64_const(d %x) {
@start:
  %c = eq.d %x, 1.0_d
  %r = flag.w %c
  ret %r
}

;; comparisons with constants (constant as LHS)

export function w $flt_f32_const_lhs(s %x) {
@start:
  %c = lt.s 0.0_s, %x
  %r = flag.w %c
  ret %r
}

export function w $flt_f64_const_lhs(d %x) {
@start:
  %c = lt.d 0.0_d, %x
  %r = flag.w %c
  ret %r
}

export function w $feq_f32_const_lhs(s %x) {
@start:
  %c = eq.s 1.0_s, %x
  %r = flag.w %c
  ret %r
}

export function w $feq_f64_const_lhs(d %x) {
@start:
  %c = eq.d 1.0_d, %x
  %r = flag.w %c
  ret %r
}

;; branch on FP comparison

export function w $br_flt_f32(s %x, s %y) {
@start:
  %c = lt.s %x, %y
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $br_flt_f64(d %x, d %y) {
@start:
  %c = lt.d %x, %y
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $br_flt_f32_const(s %x) {
@start:
  %c = lt.s %x, 0.0_s
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $br_flt_f64_const(d %x) {
@start:
  %c = lt.d %x, 0.0_d
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $br_flt_f32_const_lhs(s %x) {
@start:
  %c = lt.s 0.0_s, %x
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

export function w $br_flt_f64_const_lhs(d %x) {
@start:
  %c = lt.d 0.0_d, %x
  br %c, @yes, @no
@yes:
  ret 1_w
@no:
  ret 0_w
}

