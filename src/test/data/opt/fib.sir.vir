module fib

export function w $fib_rec(w %0) {
@9:
  %11 = le.w %0, 0x1_w ; @10
  br %11, @8, @2
@8:
  ret %0
@2:
  %1 = sub.w %0, 0x1_w ; @7
  %2 = sub.w %0, 0x2_w ; @6
  %3 = call.w $fib_rec(%1) ; @5
  %4 = call.w $fib_rec(%2) ; @4
  %5 = add.w %3, %4 ; @3
  ret %5
}

export function w $fib_iter(w %6) {
@25:
  %13 = le.w %6, 0x1_w ; @26
  br %13, @24, @20
@24:
  ret %6
@20:
  %7 = copy.w 0x0_w ; @23
  %8 = copy.w 0x1_w ; @22
  %9 = copy.w 0x2_w ; @21
  jmp @12
@12:
  jmp @18
@18:
  %12 = le.w %9, %6 ; @19
  br %12, @13, @11
@13:
  %10 = add.w %7, %8 ; @17
  %7 = copy.w %8 ; @16
  %8 = copy.w %10 ; @15
  %9 = add.w %9, 0x1_w ; @14
  jmp @12
@11:
  ret %8
}
