module mindiv2

export function s $f(s %6, s %7) {
  %0 = slot 4, align 4
  %1 = slot 4, align 4
  %2 = slot 4, align 4
  %3 = slot 4, align 4
  %4 = slot 4, align 4
  %5 = slot 4, align 4
@33:
  st.s %6, %0 ; @42
  st.s %7, %1 ; @41
  %8 = ld.s %1 ; @40
  %9 = call.s $fabsf(%8) ; @39
  st.s %9, %5 ; @38
  %10 = ld.s %5 ; @37
  %11 = lt.s %10, 1_s ; @36
  %12 = flag.w %11 ; @35
  %32 = ne.w %12, 0x0_w ; @34
  br %32, @26, @31
@31:
  st.w 0x0_w, %2 ; @32
  jmp @2
@26:
  %13 = ld.s %1 ; @30
  %14 = eq.s %13, 0_s ; @29
  %15 = flag.w %14 ; @28
  %33 = ne.w %15, 0x0_w ; @27
  br %33, @8, @10
@10:
  %16 = ld.s %0 ; @25
  %17 = mul.s 1.77636e-15_s, %16 ; @24
  %18 = ld.s %1 ; @23
  %19 = mul.s 1.26765e+30_s, %18 ; @22
  %20 = div.s %17, %19 ; @21
  %21 = call.s $fabsf(%20) ; @20
  st.s %21, %4 ; @19
  %22 = ld.s %4 ; @18
  %23 = mul.s 1.77636e-15_s, 3.40282e+38_s ; @17
  %24 = mul.s 7.88861e-31_s, %23 ; @16
  %25 = gt.s %22, %24 ; @15
  %26 = flag.w %25 ; @14
  %27 = ne.w %26, 0x0_w ; @13
  %28 = flag.w %27 ; @12
  st.w %28, %3 ; @11
  jmp @3
@8:
  st.w 0x1_w, %3 ; @9
  jmp @3
@3:
  %29 = ld.w %3 ; @7
  %30 = ne.w %29, 0x0_w ; @6
  %31 = flag.w %30 ; @5
  st.w %31, %2 ; @4
  jmp @2
@2:
  hlt
}
