module collatz_rec

export function w $foo(w %1, w %2) {
start:
  if eq.w %1, 0x1_w {
    ret %2
  } else {
    %6 = urem.w %1, 0x2_w;
    if eq.w %6, 0x0_w {
      %8 = add.w %2, 0x1_w;
      %9 = udiv.w %1, 0x2_w;
      %10 = call.w $foo(%9, %8);
      ret %10
    } else {
      %11 = add.w %2, 0x1_w;
      %12 = mul.w %1, 0x3_w;
      %13 = add.w %12, 0x1_w;
      %14 = call.w $foo(%13, %11);
      ret %14
    }
  }
}
