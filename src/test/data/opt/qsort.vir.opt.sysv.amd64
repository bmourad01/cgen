module qsort

function $swap {
@2:
  mov %1:l, rdi ; @3
  mov %3:l, rsi ; @68
  mov %25:w, dword ptr [%1] ; @69
  mov %26:w, dword ptr [%3] ; @4
  mov dword ptr [%3], %25:w ; @5
  mov dword ptr [%1], %26:w ; @6
  ret ; @67
}

function $partition { ; returns: rax
@7:
  mov %6:l, rdi ; @49
  mov %9:l, rsi ; @100
  mov %5:l, rdx ; @101
  lea %61:l, qword ptr [%6 + %5*4] ; @50
  mov %29:w, dword ptr [%6 + %5*4] ; @11
