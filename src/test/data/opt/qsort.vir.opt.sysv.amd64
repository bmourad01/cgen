@47:
  ret ; @106
@39:
  mov rdi, %57:l ; @42
  mov rsi, %58:l ; @102
  mov rdx, %59:l ; @103
  call $partition ; rdi rdx rsi ; @104
  mov %54:l, rax ; @105
  lea %76:l, qword ptr [%54 - 0x1] ; @65
  mov rdi, %57:l ; @44
  mov rsi, %58:l ; @99
  mov rdx, %76:l ; @100
  call $qsort ; rdi rdx rsi ; @101
