  lea %72:l, qword ptr [%33 + 0x1] ; @61
  lea %74:l, qword ptr [%6 + %72*4] ; @63
  mov rdi, %74:l ; @36
  mov rsi, %61:l ; @89
  call $swap ; rdi rsi ; @90
  mov rax, %72:l ; @87
  ret ; @88
@14:
  lea %66:l, qword ptr [%6 + %32*4] ; @55
  mov %38:w, dword ptr [%6 + %32*4] ; @22
  cmp %38:w, %29:w ; @81
  jle @18 ; @82
  jmp @70 ; @83
@70:
  mov %40:l, %33:l ; @79
  jmp @19 ; @80
@18:
  lea %69:l, qword ptr [%33 + 0x1] ; @58
  lea %71:l, qword ptr [%6 + %69*4] ; @60
  mov rdi, %71:l ; @30
  mov rsi, %66:l ; @76
  call $swap ; rdi rsi ; @77
  mov %40:l, %69:l ; @74
  jmp @19 ; @75
@19:
  lea %68:l, qword ptr [%32 + 0x1] ; @57
  mov %32:l, %68:l ; @71
  mov %33:l, %40:l ; @72
  jmp @8 ; @73
}

export function $qsort {
@48:
  mov %22:l, rdi ; @119
  mov %19:l, rsi ; @120
  mov %20:l, rdx ; @121
  mov %57:l, %22:l ; @122
  mov %58:l, %19:l ; @123
