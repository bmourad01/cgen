  lea %63:l, qword ptr [%9 - 0x1] ; @52
  mov %32:l, %9:l ; @90
  mov %33:l, %63:l ; @91
  jmp @8 ; @92
@8:
  cmp %32:l, %62:l ; @87
  jle @14 ; @88
  jmp @15 ; @89
@15:
  lea %72:l, qword ptr [%33 + 0x1] ; @61
  lea %74:l, qword ptr [%6 + %72*4] ; @63
  mov rdi, %74:l ; @36
  mov rsi, %61:l ; @85
  call $swap ; rdi rsi ; @86
  mov rax, %72:l ; @83
  ret ; @84
@14:
  lea %66:l, qword ptr [%6 + %32*4] ; @55
  mov %38:w, dword ptr [%6 + %32*4] ; @22
  cmp %38:w, %29:w ; @80
  jle @18 ; @81
  jmp @70 ; @82
@70:
  mov %40:l, %33:l ; @78
  jmp @19 ; @79
@18:
  lea %69:l, qword ptr [%33 + 0x1] ; @58
  lea %71:l, qword ptr [%6 + %69*4] ; @60
  mov rdi, %71:l ; @30
  mov rsi, %66:l ; @76
  call $swap ; rdi rsi ; @77
  mov %40:l, %69:l ; @74
  jmp @19 ; @75
@19:
  lea %68:l, qword ptr [%32 + 0x1] ; @57
  mov %32:l, %68:l ; @71
  mov %33:l, %40:l ; @72
  jmp @8 ; @73
}

export function $qsort {
@48:
  mov %22:l, rdi ; @110
  mov %19:l, rsi ; @111
  mov %20:l, rdx ; @112
  mov %57:l, %22:l ; @113
  mov %58:l, %19:l ; @114
  mov %59:l, %20:l ; @115
  jmp @38 ; @116
