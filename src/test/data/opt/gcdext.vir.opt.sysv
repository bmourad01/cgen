module gcdext

export function $gcd(w %3/rdi, w %4/rsi) {
  %58 = slot 8, align 8
  %61 = slot 8, align 8
@2:
  %65 = eq.w %3, 0x0_w ; @30
  br %65, @3, @4
@3:
  st.w %4, %58 ; @6
  %72 = add.l %58, 0x4_l ; @61
  st.w 0x0_w, %72 ; @8
  %74 = ld.l %58 ; @37
  st.w 0x1_w, %61 ; @42
  jmp @29(%74)
@4:
  %79 = rem.w %4, %3 ; @12
  %80/l/rax, %81/l/rdx = call $gcd(%79/rdi, %3/rsi) ; @13
  st.l %81, %61 ; @60
  st.l %80, %58 ; @44
  %86 = ld.w %61 ; @46
  %91 = add.l %58, 0x4_l ; @62
  %92 = ld.w %91 ; @17
  %95 = div.w %4, %3 ; @21
  %96 = mul.w %95, %92 ; @35
  %97 = sub.w %86, %96 ; @36
  st.w %97, %91 ; @25
  %100 = ld.l %58 ; @49
  st.w %92, %61 ; @54
  jmp @29(%100)
@29(%68):
  %71 = ld.l %61 ; @57
  ret rax/%68, rdx/%71
}
