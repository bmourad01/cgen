module gcdext

export function $gcd(w %3/rdi, w %4/rsi) {
  %58 = slot 8, align 8
  %59 = slot 8, align 8
  %61 = slot 8, align 8
@2:
  %67 = eq.w %3, 0x0_w ; @30
  br %67, @3, @4
@3:
  st.w %4, %58 ; @6
  %75 = add.l %58, 0x4_l ; @61
  st.w 0x0_w, %75 ; @8
  st.w 0x1_w, %59 ; @10
  %76 = ld.l %58 ; @37
  %79 = ld.l %59 ; @40
  jmp @29(%79, %76)
@4:
  %82 = rem.w %4, %3 ; @12
  %83/l/rax, %84/l/rdx = call $gcd(%82/rdi, %3/rsi) ; @13
  st.l %83, %58 ; @44
  st.l %84, %61 ; @48
  %92 = ld.w %58 ; @15
  %94 = add.l %58, 0x4_l ; @62
  %95 = ld.w %94 ; @17
  %97 = ld.w %61 ; @19
  st.w %92, %58 ; @20
  %98 = div.w %4, %3 ; @21
  %99 = mul.w %98, %95 ; @35
  %100 = sub.w %97, %99 ; @36
  st.w %100, %94 ; @25
  st.w %95, %59 ; @27
  %102 = ld.l %58 ; @49
  %105 = ld.l %59 ; @52
  jmp @29(%105, %102)
@29(%70, %71):
  ret rax/%71, rdx/%70
}
