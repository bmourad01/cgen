module foo

export function w $foo(w %2, w %4, w %5) {
@2:
  jmp @3(%2)
@3(%10):
  %25 = add.w %4, %5 ; @20
  %26 = sub.w %10, 0x1_w ; @21
  %27 = ne.w %26, 0x0_w ; @22
  br %27, @3(%26), @11(%2, 0x0_w)
@11(%18, %19):
  %29 = sub.w %18, 0x1_w ; @24
  %30 = add.w %19, 0x1_w ; @25
  %31 = add.w %30, %25 ; @26
  %32 = ne.w %29, 0x0_w ; @27
  br %32, @11(%29, %31), @14
@14:
  %33 = add.w %31, %25 ; @28
  ret %33
}
