module foo

export function w $foo(w %2, w %4, w %5) {
@2:
  jmp @3(%2, 0x0_w)
@3(%10, %11):
  %25 = add.w %4, %5 ; @20
  %26 = sub.w %10, 0x1_w ; @21
  %27 = add.w %11, 0x1_w ; @22
  %28 = ne.w %26, 0x0_w ; @23
  br %28, @3(%26, %27), @11(%2, 0x0_w)
@11(%18, %19):
  %30 = sub.w %18, 0x1_w ; @25
  %31 = add.w %19, 0x1_w ; @26
  %32 = add.w %31, %25 ; @27
  %33 = ne.w %30, 0x0_w ; @28
  br %33, @11(%30, %32), @14
@14:
  %34 = add.w %25, %32 ; @29
  ret %34
}
