module foo

export function w $foo(w %2) {
  %0 = slot 4, align 4
  %1 = slot 4, align 4
start:
  st.w 0x0_w, %0;
  st.w %2, %1;
  loop {
    %9 = ld.w %1;
    if gt.w %9, 0x1_w {
      %11 = ld.w %1;
      %12 = urem.w %11, 0x2_w;
      if eq.w %12, 0x0_w {
        %16 = ld.w %1;
        %17 = udiv.w %16, 0x2_w;
        st.w %17, %1
      } else {
        %18 = ld.w %1;
        %19 = mul.w %18, 0x3_w;
        %20 = add.w %19, 0x1_w;
        st.w %20, %1
      };
      %14 = ld.w %0;
      %15 = add.w %14, 0x1_w;
      st.w %15, %0
    } else {
      break
    }
  };
  %21 = ld.w %0;
  ret %21
}
