module qsort

function $swap {
@2:
  mov ecx, dword ptr [rdi] ; @69
  mov eax, dword ptr [rsi] ; @4
  mov dword ptr [rsi], ecx ; @5
  mov dword ptr [rdi], eax ; @6
  ret ; @67
}

function $partition { ; returns: rax
@7:
  push rbp ; @128
  mov rbp, rsp ; @129
  sub rsp, 0x18_l ; @130
  push r12 ; @131
  push r13 ; @132
  push r14 ; @133
  push r15 ; @134
  push rbx ; @135
  mov r13, rdi ; @49
  lea rax, qword ptr [r13 + rdx*4] ; @50
  mov qword ptr [rbp - 0x10], rax ; @126
  mov r14d, dword ptr [r13 + rdx*4] ; @11
  lea rbx, qword ptr [rsi - 0x1] ; @51
  lea r15, qword ptr [rdx - 0x1] ; @52
  mov r12, rsi ; @97
@8:
  cmp r12, r15 ; @92
  jle @14 ; @93
@15:
  inc rbx ; @61
  lea rdi, qword ptr [r13 + rbx*4] ; @63
  mov rsi, qword ptr [rbp - 0x10] ; @127
  call $swap ; rdi rsi ; @90
  mov rax, rbx ; @87
  pop rbx ; @136
  pop r15 ; @137
  pop r14 ; @138
  pop r13 ; @139
  pop r12 ; @140
  leave ; @141
  ret ; @88
@14:
  lea rsi, qword ptr [r13 + r12*4] ; @55
  mov eax, dword ptr [rsi] ; @22
  cmp eax, r14d ; @81
  jg @19 ; @82
@18:
  inc rbx ; @58
  lea rdi, qword ptr [r13 + rbx*4] ; @60
  call $swap ; rdi rsi ; @77
@19:
  inc r12 ; @57
  jmp @8 ; @73
}

export function $qsort {
@48:
  push rbp ; @142
  mov rbp, rsp ; @143
  push r12 ; @144
  push r13 ; @145
  push r14 ; @146
  push rbx ; @147
  mov r13, rdi ; @119
  mov r12, rsi ; @120
  mov rbx, rdx ; @121
@38:
  cmp r12, rbx ; @114
  jl @39 ; @115
@47:
  pop rbx ; @148
  pop r14 ; @149
  pop r13 ; @150
  pop r12 ; @151
  leave ; @152
  ret ; @113
@39:
  mov rdi, r13 ; @42
  mov rsi, r12 ; @109
  mov rdx, rbx ; @110
  call $partition ; rdi rdx rsi ; @111
  mov r14, rax ; @112
  lea rdx, qword ptr [r14 - 0x1] ; @65
  mov rdi, r13 ; @44
  mov rsi, r12 ; @106
  call $qsort ; rdi rdx rsi ; @108
  lea r12, qword ptr [r14 + 0x1] ; @66
  jmp @38 ; @105
}
