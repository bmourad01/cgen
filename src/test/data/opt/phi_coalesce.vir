module phi_coalesce

;; similar example to `spill1`, but the `%inc` prevents
;; any clever constant folding from extending the live
;; ranges of `@loop`'s parameters
export function w $foo(w %inc, w %n) {
@start:
  jmp @loop(0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, 0_w, %n)
@loop(%p0, %p1, %p2, %p3, %p4, %p5, %p6, %p7, %p8, %p9, %pa, %pb, %pc, %pd, %pe, %cnt):
  %r0 = add.w %p0, %inc
  %r1 = add.w %p1, %inc
  %r2 = add.w %p2, %inc
  %r3 = add.w %p3, %inc
  %r4 = add.w %p4, %inc
  %r5 = add.w %p5, %inc
  %r6 = add.w %p6, %inc
  %r7 = add.w %p7, %inc
  %r8 = add.w %p8, %inc
  %r9 = add.w %p9, %inc
  %ra = add.w %pa, %inc
  %rb = add.w %pb, %inc
  %rc = add.w %pc, %inc
  %rd = add.w %pd, %inc
  %re = add.w %pe, %inc
  %cnt1 = sub.w %cnt, 1_w
  %c = ne.w %cnt1, 0_w
  br %c, @loop(%r0, %r1, %r2, %r3, %r4, %r5, %r6, %r7, %r8, %r9, %ra, %rb, %rc, %rd, %re, %cnt1), @end
@end:
  %s0 = add.w %r0, %r1
  %s1 = add.w %s0, %r2
  %s2 = add.w %s1, %r3
  %s3 = add.w %s2, %r4
  %s4 = add.w %s3, %r5
  %s5 = add.w %s4, %r6
  %s6 = add.w %s5, %r7
  %s7 = add.w %s6, %r8
  %s8 = add.w %s7, %r9
  %s9 = add.w %s8, %ra
  %sa = add.w %s9, %rb
  %sb = add.w %sa, %rc
  %sc = add.w %sb, %rd
  %sd = add.w %sc, %re
  ret %sd
}
