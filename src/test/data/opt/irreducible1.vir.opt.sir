module irreducible1

export function w $foo(w %2) {
start:
  %16 = and.w %2, 0x1_w;
  %17 = eq.w %16, 0x0_w;
  %5 = copy.w 0x0_w;
  loop {
    if slt.w %5, %2 {
      %13 = copy.w %5;
      @5:
        %21 = add.w %13, 0x1_w;
        if eq.w %21, %2 {
          %7 = copy.w %21
        } else {
          %10 = copy.w %21;
          %19 = sub.w %10, 0x1_w;
          if eq.w %19, 0x0_w {
            %7 = copy.w %19
          } else {
            %13 = copy.w %19;
            goto @5
          }
        }
    } else {
      %10 = copy.w %5;
      %19 = sub.w %10, 0x1_w;
      if eq.w %19, 0x0_w {
        %7 = copy.w %19
      } else {
        %13 = copy.w %19;
        goto @5
      }
    };
    if %17 {
      break
    } else {
      %5 = copy.w %7
    }
  };
  ret %7
}
