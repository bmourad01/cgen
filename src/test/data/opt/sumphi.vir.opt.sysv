module sumphi

function $sum(l %1/rdi) {
  %0 = slot 8, align 8
@2:
  st.l %1, %0 ; @22
  %14 = ld.w %0 ; @4
  %23 = add.l %0, 0x4_l ; @19
  %16 = ld.w %23 ; @6
  %24 = add.w %14, %16 ; @20
  ret rax/%24
}

export function $sumphi(l %8/rdi, l %9/rsi, w %11/rdx) {
@8:
  %42 = slt.w %11, 0x0_w ; @21
  br %42, @9, @10
@9:
  jmp @14(%8)
@10:
  jmp @14(%9)
@14(%43):
  tailcall $sum(%43/rdi)
}
