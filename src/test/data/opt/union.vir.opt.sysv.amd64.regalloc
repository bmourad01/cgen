}

export function $sum_big { ; returns: rax
@29:
  push rbp ; @234
  mov rbp, rsp ; @235
  mov rdx, qword ptr [rbp + 0x10] ; @73
  mov rax, qword ptr [rbp + 0x18] ; @194
  mov rcx, qword ptr [rbp + 0x20] ; @195
  add rax, rdx ; @196
  add rax, rcx ; @74
  leave ; @236
  ret ; @193
}

export function $mk_big { ; returns: rax
@38:
  mov qword ptr [rdi], rsi ; @202
  mov qword ptr [rdi + 0x8], rdx ; @133
  mov qword ptr [rdi + 0x10], rcx ; @137
  mov rax, rdi ; @197
  ret ; @198
}

