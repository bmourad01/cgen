module union

export function $getint { ; returns: rax
@2:
  sub rsp, 0x8_l ; @182
  mov qword ptr [rsp], rdi ; @141
  mov eax, dword ptr [rsp] ; @4
  add rsp, 0x8_l ; @183
  ret ; @140
}

export function $mkfloat { ; returns: rax
@5:
  sub rsp, 0x8_l ; @184
  movss dword ptr [rsp], xmm0 ; @144
  mov rax, qword ptr [rsp] ; @66
  add rsp, 0x8_l ; @185
  ret ; @143
}

export function $struct_with_union { ; returns: rax
@8:
  sub rsp, 0x8_l ; @186
  mov qword ptr [rsp], rdi ; @147
  mov eax, dword ptr [rsp + 0x4] ; @11
  add rsp, 0x8_l ; @187
  ret ; @146
}

export function $get_sse_d { ; returns: xmm0
@12:
  sub rsp, 0x8_l ; @188
  movsd qword ptr [rsp], xmm0 ; @150
  add rsp, 0x8_l ; @189
  ret ; @149
}

export function $mk_sse_d { ; returns: xmm0
@15:
  sub rsp, 0x8_l ; @190
  movsd qword ptr [rsp], xmm0 ; @153
  add rsp, 0x8_l ; @191
  ret ; @152
}

export function $sum_u2 { ; returns: rax
@18:
  lea rax, qword ptr [rdi + rsi*1] ; @157
  ret ; @155
}

export function $mk_u2 { ; returns: rax rdx
@24:
  mov rax, rdi ; @158
  mov rdx, rsi ; @159
  ret ; @162
}

export function $sum_big { ; returns: rax
@29:
  push rbp ; @192
  mov rbp, rsp ; @193
  mov rdx, qword ptr [rbp + 0x10] ; @58
  mov rax, qword ptr [rbp + 0x18] ; @165
  mov rcx, qword ptr [rbp + 0x20] ; @166
  add rax, rdx ; @167
  add rax, rcx ; @59
  leave ; @194
  ret ; @164
}

export function $mk_big { ; returns: rax
@38:
  mov qword ptr [rdi], rsi ; @173
  mov qword ptr [rdi + 0x8], rdx ; @116
  mov qword ptr [rdi + 0x10], rcx ; @120
  mov rax, rdi ; @168
  ret ; @169
}

export function $s2_union_l { ; returns: rax
@45:
  mov rax, rdi ; @174
  ret ; @177
}

export function $s2_w { ; returns: rax
@48:
  sub rsp, 0x8_l ; @195
  mov qword ptr [rsp], rsi ; @181
  mov eax, dword ptr [rsp] ; @51
  add rsp, 0x8_l ; @196
  ret ; @179
}
