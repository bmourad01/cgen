module nosink

export function w $foo(w %1) {
@2:
  %12 = lsl.w %1, 0x2_w ; @16
  %13 = add.w %12, %1 ; @17
  %14 = eq.w %1, 0x0_w ; @18
  br %14, @3, @4
@3:
  %16 = add.w %13, 0x1_w ; @20
  jmp @7(%16)
@4:
  %18 = eq.w %1, 0x1_w ; @22
  br %18, @9, @10
@9:
  %19 = add.w %13, 0x5_w ; @23
  jmp @7(%19)
@10:
  %20 = add.w %13, 0x6_w ; @24
  jmp @7(%20)
@7(%5):
  %15 = sub.w %5, 0x1_w ; @19
  ret %15
}
