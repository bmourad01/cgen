module nosink

export function w $foo(w %1) {
@2:
  %12 = lsl.w %1, 0x2_w ; @16
  %13 = eq.w %1, 0x0_w ; @17
  br %13, @3, @4
@3:
  %15 = add.w %12, %1 ; @19
  %16 = add.w %15, 0x1_w ; @20
  jmp @7(%16)
@4:
  %17 = add.w %12, %1 ; @21
  %19 = eq.w %1, 0x1_w ; @23
  br %19, @9, @10
@9:
  %20 = add.w %17, 0x5_w ; @24
  jmp @7(%20)
@10:
  %21 = add.w %17, 0x6_w ; @25
  jmp @7(%21)
@7(%5):
  %14 = sub.w %5, 0x1_w ; @18
  ret %14
}
