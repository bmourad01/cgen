module foo

export function w $foo(w %1) {
start:
  if le.w %1, 0x1_w {
    ret 0x0_w
  } else {
    if le.w %1, 0x3_w {
      ret 0x1_w
    } else {
      %8 = urem.w %1, 0x2_w;
      if eq.w %8, 0x0_w {
        ret 0x0_w
      } else {
        %10 = urem.w %1, 0x3_w;
        if eq.w %10, 0x0_w {
          ret 0x0_w
        } else {
          %12 = copy.w 0x5_w;
          %13 = copy.w %12;
          loop {
            %14 = mul.w %13, %13;
            if le.w %14, %1 {
              %16 = urem.w %1, %13;
              if eq.w %16, 0x0_w {
                ret 0x0_w
              } else {
                %18 = add.w %13, 0x2_w;
                %19 = urem.w %1, %18;
                if eq.w %19, 0x0_w {
                  ret 0x0_w
                } else {
                  %21 = add.w %13, 0x6_w;
                  %13 = copy.w %21;
                  continue
                }
              }
            } else {
              ret 0x1_w
            }
          }
        }
      }
    }
  }
}
