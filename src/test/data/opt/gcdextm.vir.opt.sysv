module gcdextm

export function $gcdext(w %3/rdi, w %6/rsi, l %4/rdx, l %5/rcx) {
  %0 = slot 8, align 8
  %1 = slot 8, align 8
@2:
  %21 = eq.w %3, 0x0_w ; @18
  br %21, @3, @4
@3:
  st.w 0x0_w, %4 ; @6
  st.w 0x1_w, %5 ; @7
  jmp @17(%6)
@4:
  %13 = rem.w %6, %3 ; @8
  %14/w/rax = call $gcdext(%13/rdi, %3/rsi, %0/rdx, %1/rcx) ; @9
  %15 = ld.w %0 ; @10
  %16 = ld.w %1 ; @11
  %17 = div.w %6, %3 ; @12
  %22 = mul.w %17, %15 ; @19
  %23 = sub.w %16, %22 ; @20
  st.w %23, %4 ; @15
  st.w %15, %5 ; @16
  jmp @17(%14)
@17(%20):
  ret rax/%20
}
