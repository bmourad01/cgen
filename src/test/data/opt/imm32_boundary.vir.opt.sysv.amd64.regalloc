@39:
  mov rax, 0x80000001_l ; @181
  sub rdi, rax ; @183
  mov rax, rdi ; @179
  ret ; @180
}

export function $add_ptr_max32 { ; returns: rax
@41:
  lea rax, qword ptr [rdi + 0x7fffffff] ; @186
  ret ; @185
}

export function $or_hi { ; returns: rax
@43:
  mov rax, 0x80000000_l ; @189
