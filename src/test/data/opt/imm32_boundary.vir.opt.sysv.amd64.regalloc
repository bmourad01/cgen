export function $load_with_disp { ; returns: rax
@58:
  mov rax, qword ptr [rdi + 0x8] ; @60
  ret ; @216
}

export function $store_with_disp {
@61:
  mov qword ptr [rsi + 0x8], rdi ; @63
  ret ; @218
}
