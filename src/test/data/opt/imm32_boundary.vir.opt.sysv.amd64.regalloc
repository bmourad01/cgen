export function $sel_sge { ; returns: rax
@32:
  mov rax, 0x80000000_l ; @95
  cmp rdi, rax ; @162
  cmovge rdx, rsi ; @163
  mov rax, rdx ; @159
  ret ; @160
}

export function $mul_boundary { ; returns: rax
@35:
  shl rdi, 0x1f_b ; @173
  mov rax, rdi ; @170
  ret ; @171
}

export function $add_ptr_hi { ; returns: rax
@37:
  mov rax, 0x80000000_l ; @176
  add rdi, rax ; @178
  mov rax, rdi ; @174
  ret ; @175
}

