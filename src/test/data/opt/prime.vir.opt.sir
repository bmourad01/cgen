module foo

export function w $foo(w %1) {
start:
  if le.w %1, 0x1_w {
    %22 = copy.w 0x0_w
  } else {
    if le.w %1, 0x3_w {
      %22 = copy.w 0x1_w
    } else {
      %25 = and.w %1, 0x1_w;
      if eq.w %25, 0x0_w {
        %22 = copy.w 0x0_w
      } else {
        %27 = umulh.w %1, 0xaaaaaaab_w;
        %28 = lsr.w %27, 0x1_w;
        %29 = lsl.w %28, 0x1_w;
        %30 = add.w %29, %28;
        %31 = sub.w %1, %30;
        if eq.w %31, 0x0_w {
          %22 = copy.w 0x0_w
        } else {
          %13 = copy.w 0x5_w;
          loop {
            %33 = mul.w %13, %13;
            if le.w %33, %1 {
              %16 = urem.w %1, %13;
              if eq.w %16, 0x0_w {
                %22 = copy.w 0x0_w;
                break
              } else {
                %36 = add.w %13, 0x2_w;
                %19 = urem.w %1, %36;
                if eq.w %19, 0x0_w {
                  %22 = copy.w 0x0_w;
                  break
                } else {
                  %38 = add.w %13, 0x6_w;
                  %13 = copy.w %38;
                  continue
                }
              }
            } else {
              %22 = copy.w 0x1_w;
