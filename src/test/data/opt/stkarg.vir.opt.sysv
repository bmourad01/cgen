module stkarg

export function $foo(l %1/rdi, l %2/rsi, l %3/rdx, l %4/rcx, l %5/r8, l %6/r9, w %8/+0, w %9/+8) {
@2:
  %21 = add.l %1, %2 ; @14
  %23 = add.l %3, %4 ; @16
  %24 = add.l %21, %23 ; @17
  %27 = add.l %5, %6 ; @20
  %30 = sext.l %8 ; @23
  %34 = sext.l %9 ; @27
  %35 = add.l %30, %34 ; @28
  %36 = add.l %27, %35 ; @29
  %37 = add.l %24, %36 ; @30
  ret rax/%37
}

export function $bar() {
@12:
  %20/l/rax = call $foo(0x0_l/rdi, 0x1_l/rsi, 0x2_l/rdx, 0x3_l/rcx, 0x4_l/r8, 0x5_l/r9, 0x6_w/+0, 0x7_w/+8)
  ; @13
  ret rax/%20
}
