;; base + index*scale - disp

export function b $load_b_add_mul_disp_neg(l %p, l %i) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = sub.l %a, 16_l
  %r = ld.b %q
  ret %r
}

export function h $load_h_add_mul_disp_neg(l %p, l %i) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = sub.l %a, 16_l
  %r = ld.h %q
  ret %r
}

export function w $load_w_add_mul_disp_neg(l %p, l %i) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = sub.l %a, 16_l
  %r = ld.w %q
  ret %r
}

export function l $load_l_add_mul_disp_neg(l %p, l %i) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = sub.l %a, 16_l
  %r = ld.l %q
  ret %r
}

