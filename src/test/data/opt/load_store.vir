@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
  %r = ld.l %q
  ret %r
}

export function $store_b_add_mul_disp(l %p, l %i, b %v) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
  st.b %v, %q
  ret
}

export function $store_h_add_mul_disp(l %p, l %i, h %v) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
