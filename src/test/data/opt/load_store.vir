}

export function $store_w_add_mul_disp(l %p, l %i, w %v) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
  st.w %v, %q
  ret
}

export function $store_l_add_mul_disp(l %p, l %i, l %v) {
@start:
  %m = mul.l %i, 4_l
  %a = add.l %p, %m
  %q = add.l %a, 16_l
  st.l %v, %q
