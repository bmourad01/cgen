module foo

export function w $foo(w %m, w %n) {
@22:
  jmp @2(%m, %n)
@2(%1, %2):
  %3 = eq.w %1, 0x0_w ; @23
  br %3, @3, @4
@3:
  %4 = add.w %2, 0x1_w ; @24
  ret %4
@4:
  %5 = eq.w %2, 0x0_w ; @25
  %6 = sub.w %1, 0x1_w ; @26
  br %5, @2(%6, 0x1_w), @8
@8:
  %7 = ne.w %2, 0x0_w ; @27
  br %7, @14, @15
@14:
  %8 = sub.w %2, 0x1_w ; @28
  %r.2 = call.w $foo(%1, %8) ; @18
  jmp @2(%6, %r.2)
@15:
  hlt
