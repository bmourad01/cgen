module evenodd

function w $abs(w %1) {
@2:
  %22 = slt.w %1, 0x0_w ; @25
  %23 = neg.w %1 ; @26
  %24 = sel.w %22, %23, %1 ; @27
  ret %24
}

export function b $even(w %2) {
@7:
  %10 = call.w $abs(%2) ; @10
  %25 = eq.w %10, 0x0_w ; @28
  br %25, @23(0x1_b), @9
@9:
  %26 = sub.w %10, 0x1_w ; @29
  %13 = call.b $odd(%26) ; @13
  jmp @23(%13)
@23(%20):
  ret %20
}

export function b $odd(w %5) {
@14:
  %14 = call.w $abs(%5) ; @17
  %27 = eq.w %14, 0x0_w ; @30
  br %27, @24(0x0_b), @16
@16:
  %28 = sub.w %14, 0x1_w ; @31
  %17 = call.b $even(%28) ; @20
  jmp @24(%17)
@24(%21):
  ret %21
}
