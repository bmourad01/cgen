module coalesce1

export function w $f(w %3, w %5, w %7) {
  %1 = slot 8, align 8
  %2 = slot 8, align 8
@2:
  st.w %3, %2 ; @4
  jmp @3
@3:
  %11 = ld.w %2 ; @6
  jmp @5
@5:
  jmp @7
@7:
  st.w %5, %1 ; @9
  jmp @8
@8:
  %12 = ld.w %1 ; @11
  jmp @10
@10:
  st.w %7, %2 ; @13
  jmp @12
@12:
  %13 = ld.w %2 ; @15
  jmp @14
@14:
  %14 = ld.w %1 ; @17
  jmp @16
@16:
  %15 = add.w %11, %12 ; @18
  %16 = add.w %15, %13 ; @19
  %17 = add.w %16, %14 ; @20
  ret %17
}
