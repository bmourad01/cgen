@14:
  imul rax, rdi ; @89
@21:
  sar rsi, 0x2_b ; @86
  imul rcx, rdi ; @85
  jmp @3 ; @84
}

export function $int_pow_alt { ; returns: rax
@27:
  sub rsp, 0x28_l ; @146
