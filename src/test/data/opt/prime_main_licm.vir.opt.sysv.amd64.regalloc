module prime_main_licm

const data $fmt = {
  "prime(%d) = %d\n",
  0x0_b
}

export function $main { ; returns: rax
@2:
  push rbp ; @60
  mov rbp, rsp ; @61
  push r12 ; @62
  push r13 ; @63
  push r14 ; @64
  push rbx ; @65
  mov rdi, qword ptr [rsi + 0x8] ; @5
  call $atoi ; rdi ; @56
  mov r14d, eax ; @57
  mov ebx, 0x1_w ; @52
  mov r13d, 0x1_w ; @53
@3:
  cmp r14d, 0x0_w ; @49
  jle @9 ; @50
@27:
  mov r12d, ebx ; @47
@10:
  mov edi, r12d ; @14
  call $is_prime ; rdi ; @45
  lea ebx, qword ptr [r12 + 0x1] ; @24
  test eax, eax ; @42
  jne @13 ; @43
@28:
  mov r12d, ebx ; @40
  jmp @10 ; @41
@13:
  lea rdi, qword ptr [rip + $fmt] ; @16
  mov esi, r13d ; @35
  mov edx, r12d ; @36
  xor eax, eax ; @37
  call $printf ; rax rdi rdx rsi ; @38
  inc r13d ; @25
  dec r14d ; @26
  jmp @3 ; @34
@9:
  xor eax, eax ; @29
  pop rbx ; @66
  pop r14 ; @67
  pop r13 ; @68
  pop r12 ; @69
  leave ; @70
  ret ; @30
}
