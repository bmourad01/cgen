module prime_main_licm

const data $fmt = {
  "prime(%d) = %d\n",
  0x0_b
}

export function $main { ; returns: rax
@2:
  push rbp ; @64
  mov rbp, rsp ; @65
  push r12 ; @66
  push r13 ; @67
  push r14 ; @68
  push rbx ; @69
  mov rdi, qword ptr [rsi + 0x8] ; @5
  call $atoi ; rdi ; @60
  mov r13d, eax ; @61
  mov r14d, 0x1_w ; @57
  mov ebx, 0x1_w ; @58
@3:
  cmp r13d, 0x0_w ; @51
  jle @9 ; @52
@27:
  mov r12d, ebx ; @49
@10:
  mov edi, r12d ; @14
  call $is_prime ; rdi ; @47
  lea ebx, qword ptr [r12 + 0x1] ; @24
  test eax, eax ; @42
  jne @13 ; @43
@28:
  mov r12d, ebx ; @40
  jmp @10 ; @41
@13:
  lea rdi, qword ptr [rip + $fmt] ; @16
  mov esi, r14d ; @35
  mov edx, r12d ; @36
  xor al, al ; @37
  call $printf ; rax rdi rdx rsi ; @38
  dec r13d ; @25
  inc r14d ; @26
  jmp @3 ; @34
@9:
  xor eax, eax ; @29
  pop rbx ; @70
  pop r14 ; @71
  pop r13 ; @72
  pop r12 ; @73
  leave ; @74
  ret ; @30
}
