module unref

function $sum(l %1/rdi) {
  %0 = slot 8, align 8
@2:
  st.l %1, %0 ; @22
  %18 = ld.w %0 ; @4
  %28 = add.l %0, 0x4_l ; @19
  %20 = ld.w %28 ; @6
  %29 = add.w %18, %20 ; @20
  ret rax/%29
}

export function $sump(l %7/rdi) {
@8:
  %42 = ld.l %7 ; @25
  tailcall $sum(%42/rdi)
}

export function $mkt(w %10/rdi, w %12/rsi) {
  %9 = slot 8, align 8
@11:
  st.w %10, %9 ; @12
  %30 = add.l %9, 0x4_l ; @21
  st.w %12, %30 ; @14
  %37 = ld.l %9 ; @28
  ret rax/%37
}

export function $sumt(w %15/rdi, w %16/rsi) {
@16:
  %45/l/rax = call $mkt(%15/rdi, %16/rsi) ; @17
  tailcall $sum(%45/rdi)
}
