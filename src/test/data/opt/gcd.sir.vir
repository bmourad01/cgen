module gcd

export function w $gcd(w %0, w %1) {
@18:
  %5 = slt.w %0, 0x0_w ; @19
  br %5, @16, @14
@16:
  %0 = neg.w %0 ; @17
  jmp @14
@14:
  %4 = slt.w %1, 0x0_w ; @15
  br %4, @12, @10
@12:
  %1 = neg.w %1 ; @13
  jmp @10
@10:
  %2 = copy.w 0x1_w ; @11
  jmp @3
@3:
  jmp @8
@8:
  %3 = ne.w %1, 0x0_w ; @9
  br %3, @4, @2
@4:
  %2 = copy.w %1 ; @7
  %1 = rem.w %0, %1 ; @6
  %0 = copy.w %2 ; @5
  jmp @3
@2:
  ret %2
}
