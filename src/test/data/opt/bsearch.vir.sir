module bsearch

export function w $intcmp(l %1, l %3) {
start:
  %16 = ld.w %1;
  %17 = ld.w %3;
  %18 = sub.w %16, %17;
  ret %18
}

export function l $bsearch(l %14, l %11, l %6, l %9, l %13) {
start:
  %19 = copy.l %11;
  %20 = copy.l %6;
  loop {
    if gt.l %20, 0x0_l {
      %22 = udiv.l %20, 0x2_l;
      %23 = mul.l %9, %22;
      %24 = add.l %19, %23;
      %25 = call.w %13(%14, %24);
      if slt.w %25, 0x0_w {
        %27 = udiv.l %20, 0x2_l;
        %20 = copy.l %27;
        continue
      } else {
        if sgt.w %25, 0x0_w {
          %29 = add.l %24, %9;
          %30 = udiv.l %20, 0x2_l;
          %31 = add.l %30, 0x1_l;
          %32 = sub.l %20, %31;
          %19 = copy.l %29;
          %20 = copy.l %32;
          continue
        } else {
          ret %24
        }
      }
    } else {
      ret 0x0_l
    }
  }
}
