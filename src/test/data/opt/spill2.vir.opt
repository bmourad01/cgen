module spill2

export function w $foo(l %6, l %8, l %10, l %12, w %3) {
@2:
  jmp @3(0x0_w, 0x0_w)
@3(%32, %33):
  %65 = slt.w %32, %3 ; @40
  br %65, @6, @7
@6:
  %66 = zext.l %32 ; @41
  %67 = lsl.l %66, 0x2_l ; @42
  %68 = add.l %6, %67 ; @43
  %69 = add.l %8, %67 ; @44
  %70 = add.l %10, %67 ; @45
  %71 = add.l %12, %67 ; @46
  %41 = ld.w %68 ; @16
  %42 = ld.w %69 ; @17
  %43 = ld.w %70 ; @18
  %44 = ld.w %71 ; @19
  jmp @9(0x0_w, %33)
@9(%46, %47):
  %72 = slt.w %46, %3 ; @47
  br %72, @21, @22
@21:
  %73 = add.w %41, %46 ; @48
  %74 = add.w %42, %46 ; @49
  %75 = add.w %43, %46 ; @50
  %76 = add.w %44, %46 ; @51
  %77 = mul.w %73, %74 ; @52
  %78 = mul.w %75, %76 ; @53
  %79 = add.w %77, %75 ; @54
  %80 = add.w %78, %76 ; @55
  %81 = xor.w %79, %80 ; @56
  %82 = add.w %47, %81 ; @57
  %83 = add.w %46, 0x1_w ; @58
  jmp @9(%83, %82)
@22:
  %84 = add.w %41, %42 ; @59
  %85 = add.w %43, %44 ; @60
  %86 = mul.w %84, %85 ; @61
  %87 = add.w %47, %86 ; @62
  %88 = add.w %32, 0x1_w ; @63
  jmp @3(%88, %87)
@7:
  ret %33
}
