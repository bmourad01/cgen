module vasum

export function $sum { ; returns: rax
  %19 = slot 176, align 16
@19:
  mov %25:b, al ; @20
  mov %4:w, edi ; @111
  mov qword ptr [%19 + 0x8], rsi ; @21
  mov qword ptr [%19 + 0x10], rdx ; @23
  mov qword ptr [%19 + 0x18], rcx ; @25
  mov qword ptr [%19 + 0x20], r8 ; @27
  mov qword ptr [%19 + 0x28], r9 ; @29
  test %25:b, %25:b ; @106
  je @2 ; @107
  jmp @18 ; @108
@18:
  movdqa xmmword ptr [%19 + 0x30], xmm0 ; @32
  movdqa xmmword ptr [%19 + 0x40], xmm1 ; @34
  movdqa xmmword ptr [%19 + 0x50], xmm2 ; @36
  movdqa xmmword ptr [%19 + 0x60], xmm3 ; @38
  movdqa xmmword ptr [%19 + 0x70], xmm4 ; @40
  movdqa xmmword ptr [%19 + 0x80], xmm5 ; @42
  movdqa xmmword ptr [%19 + 0x90], xmm6 ; @44
  movdqa xmmword ptr [%19 + 0xa0], xmm7 ; @46
  jmp @2 ; @105
@2:
  lea %63:l, qword ptr [rbp + 0x10] ; @50
  mov %68:l, %63:l ; @100
  mov %69:w, 0x8_w ; @101
  xor %70:w, %70:w ; @102
  xor %71:w, %71:w ; @103
  jmp @3 ; @104
@3:
  cmp %71:w, %4:w ; @95
  jb @7 ; @96
  jmp @8 ; @97
@8:
  mov eax, %70:w ; @93
  ret ; @94
@7:
  jmp @56 ; @92
@56:
  cmp %69:w, 0x28_w ; @87
  jbe @57 ; @88
  jmp @58 ; @89
@58:
  lea %89:l, qword ptr [%68 + 0x8] ; @70
  mov %75:l, %89:l ; @83
  mov %76:w, %69:w ; @84
  mov %77:l, %68:l ; @85
  jmp @59 ; @86
@57:
  mov %83:w, %69:w ; @64
  lea %84:l, qword ptr [%19 + %83*1] ; @65
  lea %85:w, qword ptr [%69 + 0x8] ; @66
  mov %75:l, %68:l ; @79
  mov %76:w, %85:w ; @80
  mov %77:l, %84:l ; @81
  jmp @59 ; @82
@59:
  mov %78:w, dword ptr [%77] ; @72
  jmp @55 ; @78
@55:
  lea %79:w, qword ptr [%70 + %78*1] ; @16
  lea %80:w, qword ptr [%71 + 0x1] ; @17
  mov %68:l, %75:l ; @73
  mov %69:w, %76:w ; @74
  mov %70:w, %79:w ; @75
  mov %71:w, %80:w ; @76
  jmp @3 ; @77
}

export function $twenty_eight { ; returns: rax
@13:
  mov edi, 0x7_w ; @14
  mov esi, 0x1_w ; @115
  mov edx, 0x2_w ; @116
  mov ecx, 0x3_w ; @117
  mov r8d, 0x4_w ; @118
  mov r9d, 0x5_w ; @119
  sub rsp, 0x10_l ; @120
  mov dword ptr [rsp], 0x6_w ; @121
  mov dword ptr [rsp + 0x8], 0x7_w ; @122
  xor al, al ; @123
  call $sum ; r8 r9 rax rcx rdi rdx rsi ; @124
  add rsp, 0x10_l ; @125
  mov %15:w, eax ; @126
  mov eax, %15:w ; @113
  ret ; @114
}
