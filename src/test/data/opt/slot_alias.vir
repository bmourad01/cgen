  %73 = sext.l %72 ; @105
  %74 = mul.l %73, 0x1c_l ; @104
  %75 = add.l %71, %74 ; @103
  %76 = add.l %75, 0x4_l ; @102
  %77 = ld.w %76 ; @101
  %78 = zext.l %77 ; @100
  %79 = add.l %67, %78 ; @99
  st.l %79, $sum ; @98
  %80 = ld.l $sum ; @97
  st.l %80, %9 ; @96
  %81 = ld.l %9 ; @95
  %82 = ld.w %15 ; @94
  %83 = sext.l %82 ; @93
  %84 = mul.l %83, 0xc4_l ; @92
  %85 = add.l $tab, %84 ; @91
