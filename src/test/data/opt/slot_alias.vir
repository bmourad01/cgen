module slot_alias

export data $sum = {
  z 8
}

export data $k = {
  z 4
}

export data $flag = {
  z 4
}

const data $.str0 = {
  "",
  z 1
}

export function $sink(l %2, w %3) {
  %0 = slot 8, align 8
  %1 = slot 4, align 4
@2:
  st.l %2, %0 ; @4
  st.w %3, %1 ; @3
  ret
}

export function l $run() {
