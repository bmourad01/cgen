  %104 = mul.l %103, 0x1c_l ; @70
  %105 = add.l %101, %104 ; @69
  %106 = add.l %105, 0x10_l ; @68
  %107 = ld.w %106 ; @67
  %108 = lsl.w %107, 0x17_w ; @66
  %109 = lsr.w %108, 0x17_w ; @65
  %110 = sext.l %109 ; @64
  %111 = add.l %97, %110 ; @63
  st.l %111, $sum ; @62
  %112 = ld.l $sum ; @61
  st.l %112, %11 ; @60
  %113 = ld.l %11 ; @59
  %114 = ld.w %15 ; @58
  %115 = sext.l %114 ; @57
  %116 = mul.l %115, 0xc4_l ; @56
  %117 = add.l $tab, %116 ; @55
  %118 = ld.w %16 ; @54
  %119 = sext.l %118 ; @53
  %120 = mul.l %119, 0x1c_l ; @52
  %121 = add.l %117, %120 ; @51
  %122 = add.l %121, 0x14_l ; @50
  %123 = ld.w %122 ; @49
  %124 = lsl.w %123, 0x4_w ; @48
  %125 = lsr.w %124, 0x4_w ; @47
  %126 = sext.l %125 ; @46
  %127 = add.l %113, %126 ; @45
  st.l %127, $sum ; @44
  %128 = ld.l $sum ; @43
  st.l %128, %12 ; @42
  %129 = ld.l %12 ; @41
  %130 = ld.w %15 ; @40
  %131 = sext.l %130 ; @39
  %132 = mul.l %131, 0xc4_l ; @38
  %133 = add.l $tab, %132 ; @37
  %134 = ld.w %16 ; @36
  %135 = sext.l %134 ; @35
  %136 = mul.l %135, 0x1c_l ; @34
  %137 = add.l %133, %136 ; @33
  %138 = add.l %137, 0x18_l ; @32
  %139 = ld.w %138 ; @31
  %140 = lsl.w %139, 0x1a_w ; @30
  %141 = lsr.w %140, 0x1a_w ; @29
  %142 = sext.l %141 ; @28
  %143 = add.l %129, %142 ; @27
