module foo

function w $foo(l %1, l %7, w %2) {
@2:
  %8 = ld.w %1 ; @5
  st.w %2, %1 ; @6
  %16 = add.w %8, 0x1_w ; @15
  st.w %16, %1 ; @8
  %17 = eq.w %8, 0x0_w ; @16
  br %17, @3, @4
@3:
  %18 = zext.l %16 ; @17
  %14 = ld.w %18 ; @13
  jmp @10(%14)
@4:
  %15 = ld.w %7 ; @14
  jmp @10(%15)
@10(%11):
  ret %11
}
