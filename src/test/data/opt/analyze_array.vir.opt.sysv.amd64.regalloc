module analyze_array

function $max { ; returns: rax
@2:
  cmp edi, esi ; @99
  cmovg esi, edi ; @100
  mov eax, esi ; @97
  ret ; @98
}

function $min { ; returns: rax
@6:
  cmp edi, esi ; @107
  cmovl esi, edi ; @108
  mov eax, esi ; @105
  ret ; @106
}

function $square { ; returns: rax
@10:
  imul edi, edi ; @116
  mov eax, edi ; @113
  ret ; @114
}

export function $analyze_array { ; returns: rax
@12:
  push rbp ; @176
  mov rbp, rsp ; @177
  sub rsp, 0x18_l ; @178
  push r12 ; @179
  push r13 ; @180
  push r14 ; @181
  push r15 ; @182
  push rbx ; @183
  mov qword ptr [rbp - 0x18], rdi ; @171
  mov dword ptr [rbp - 0x10], esi ; @172
  mov rax, qword ptr [rbp - 0x18] ; @173
  mov edi, dword ptr [rax] ; @145
  xor r13d, r13d ; @139
  mov r12d, edi ; @140
  xor ebx, ebx ; @142
@13:
  cmp r13d, dword ptr [rbp - 0x10] ; @136
  jl @18 ; @137
@19:
  sub edi, r12d ; @135
  call $square ; rdi ; @133
  add eax, ebx ; @79
  pop rbx ; @184
  pop r15 ; @185
  pop r14 ; @186
  pop r13 ; @187
  pop r12 ; @188
  leave ; @189
  ret ; @132
@18:
  mov rax, qword ptr [rbp - 0x18] ; @175
  mov r14d, dword ptr [rax + r13*4] ; @24
  mov esi, r14d ; @128
  call $max ; rdi rsi ; @129
  mov r15d, eax ; @130
  mov edi, r12d ; @26
  mov esi, r14d ; @125
  call $min ; rdi rsi ; @126
  mov r12d, eax ; @127
  mov edi, r14d ; @27
  call $square ; rdi ; @123
  mov ecx, r15d ; @73
  sub ecx, r12d ; @122
  add eax, ebx ; @75
  inc r13d ; @76
  lea ebx, qword ptr [rax + rcx*1] ; @77
  mov edi, r15d ; @119
  jmp @13 ; @121
}

export function $analyze_array_inl { ; returns: rax
@35:
  mov ecx, dword ptr [rdi] ; @170
  xor r10d, r10d ; @164
  mov eax, ecx ; @166
  xor r9d, r9d ; @167
@36:
  cmp r10d, esi ; @161
  jl @41 ; @162
@42:
  sub eax, ecx ; @160
  imul eax, eax ; @159
  add eax, r9d ; @96
  ret ; @158
@41:
  mov edx, dword ptr [rdi + r10*4] ; @47
  mov r8d, edx ; @85
  cmp eax, edx ; @155
  cmovg r8d, eax ; @156
  mov eax, edx ; @87
  cmp ecx, edx ; @153
  cmovl eax, ecx ; @154
  imul edx, edx ; @152
  mov ecx, r8d ; @89
  sub ecx, eax ; @151
  add edx, r9d ; @91
  inc r10d ; @92
  lea r9d, qword ptr [rdx + rcx*1] ; @93
  mov ecx, eax ; @147
  mov eax, r8d ; @148
  jmp @36 ; @150
}
