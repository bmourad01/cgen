module analyze_array

function $max { ; returns: rax
@2:
  cmp edi, esi ; @99
  cmovg esi, edi ; @100
  mov eax, esi ; @97
  ret ; @98
}

function $min { ; returns: rax
@6:
  cmp edi, esi ; @107
  cmovl esi, edi ; @108
  mov eax, esi ; @105
  ret ; @106
}

function $square { ; returns: rax
@10:
  imul edi, edi ; @116
  mov eax, edi ; @113
  ret ; @114
}

export function $analyze_array { ; returns: rax
@12:
  push rbp ; @186
  mov rbp, rsp ; @187
  sub rsp, 0x18_l ; @188
  push r12 ; @189
  push r13 ; @190
  push r14 ; @191
  push r15 ; @192
  push rbx ; @193
  mov qword ptr [rbp - 0x10], rdi ; @181
  mov dword ptr [rbp - 0x8], esi ; @182
  mov rax, qword ptr [rbp - 0x10] ; @183
  mov edi, dword ptr [rax] ; @148
  xor r13d, r13d ; @142
  mov r12d, edi ; @143
  xor ebx, ebx ; @145
@13:
  cmp r13d, dword ptr [rbp - 0x8] ; @137
  jl @18 ; @138
@19:
  sub edi, r12d ; @136
  call $square ; rdi ; @134
  add eax, ebx ; @79
  pop rbx ; @194
  pop r15 ; @195
  pop r14 ; @196
  pop r13 ; @197
  pop r12 ; @198
  leave ; @199
  ret ; @133
@18:
  mov rax, qword ptr [rbp - 0x10] ; @185
  mov r14d, dword ptr [rax + r13*4] ; @24
  mov esi, r14d ; @128
  call $max ; rdi rsi ; @129
  mov r15d, eax ; @130
  mov edi, r12d ; @26
  mov esi, r14d ; @125
  call $min ; rdi rsi ; @126
  mov r12d, eax ; @127
  mov edi, r14d ; @27
  call $square ; rdi ; @123
  mov ecx, r15d ; @73
  sub ecx, r12d ; @122
  add eax, ebx ; @75
  lea ebx, qword ptr [rax + rcx*1] ; @76
  inc r13d ; @77
  mov edi, r15d ; @119
  jmp @13 ; @121
}

export function $analyze_array_inl { ; returns: rax
@35:
  mov ecx, dword ptr [rdi] ; @180
  xor r10d, r10d ; @174
  mov eax, ecx ; @176
  xor r9d, r9d ; @177
@36:
  cmp r10d, esi ; @169
  jl @41 ; @170
@42:
  sub eax, ecx ; @168
  imul eax, eax ; @167
  add eax, r9d ; @96
  ret ; @166
@41:
  mov edx, dword ptr [rdi + r10*4] ; @47
  mov r8d, edx ; @85
  cmp eax, edx ; @160
  cmovg r8d, eax ; @161
  mov eax, edx ; @87
  cmp ecx, edx ; @156
  cmovl eax, ecx ; @157
  imul edx, edx ; @155
  mov ecx, r8d ; @89
  sub ecx, eax ; @154
  add edx, r9d ; @91
  lea r9d, qword ptr [rdx + rcx*1] ; @92
  inc r10d ; @93
  mov ecx, eax ; @150
  mov eax, r8d ; @151
  jmp @36 ; @153
}
