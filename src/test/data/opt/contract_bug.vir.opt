module contract_bug

export function w $f(w %3, w %4, w %7, w %1, w %6) {
@2:
  %16 = ne.w %1, 0x0_w ; @15
  %17 = add.w %3, 0x1_w ; @16
  %18 = add.w %4, 0x2_w ; @17
  jmp @9(%6)
@9(%10):
  %19 = slt.w %10, %7 ; @18
  br %19, @10, @11
@10:
  %20 = sel.w %16, %17, %18 ; @19
  %21 = add.w %10, %20 ; @20
  jmp @9(%21)
@11:
  ret %10
}
