module magic_div

export function $magic_signed(w %d/rdi) {
  %res = slot 8, align 8
@2:
  %27 = slt.w %d, 0x0_w ; @138
  %28 = neg.w %d ; @139
  %29 = sel.w %27, %28, %d ; @140
  %30 = flag.w %27 ; @141
  %31 = sub.w %30, 0x80000000_w ; @142
  %32 = add.w %30, 0x7fffffff_w ; @143
  %trem.1 = urem.w %31, %29 ; @17
  %33 = sub.w %32, %trem.1 ; @144
  %q1.1 = udiv.w 0x80000000_w, %33 ; @19
  %36 = mul.w %q1.1, %33 ; @147
  %37 = sub.w 0x80000000_w, %36 ; @148
  %q2.1 = udiv.w 0x80000000_w, %29 ; @22
  %38 = mul.w %q2.1, %29 ; @149
  %39 = sub.w 0x80000000_w, %38 ; @150
  jmp @14(%39, %37, %q2.1, %q1.1, 0x1f_w)
@14(%r2.2, %r1.2, %q2.2, %q1.2, %p.2):
  %40 = add.w %p.2, 0x1_w ; @151
  %41 = lsl.w %q1.2, 0x1_w ; @152
  %42 = lsl.w %r1.2, 0x1_w ; @153
  %43 = ge.w %42, %33 ; @154
  %44 = add.w %41, 0x1_w ; @155
  %45 = sub.w %42, %33 ; @156
  %47 = sel.w %43, %45, %42 ; @158
  %48 = sel.w %43, %44, %41 ; @159
  %49 = lsl.w %q2.2, 0x1_w ; @160
  %50 = lsl.w %r2.2, 0x1_w ; @161
  %51 = ge.w %50, %29 ; @162
  %52 = add.w %49, 0x1_w ; @163
  %53 = sub.w %50, %29 ; @164
  %54 = sel.w %51, %53, %50 ; @165
  %55 = sel.w %51, %52, %49 ; @166
  %56 = sub.w %29, %54 ; @167
  %57 = lt.w %48, %56 ; @168
  br %57, @14(%54, %47, %55, %48, %40), @42
@42:
  %58 = eq.w %48, %56 ; @169
  br %58, @45, @46
@45:
  %64 = ne.w %47, 0x0_w ; @175
  br %64, @46, @14(%54, %47, %55, %48, %40)
@46:
  %59 = add.w %55, 0x1_w ; @170
  %60 = neg.w %59 ; @171
  %61 = sel.w %27, %60, %59 ; @172
  %62 = sub.w %p.2, 0x1f_w ; @173
  %63 = add.l %res, 0x4_l ; @174
  st.w %61, %res ; @56
  st.w %62, %63 ; @57
  %105 = ld.l %res ; @215
  st.l %105, %res ; @216
  ret rax/%105
}

export function $magic_unsigned(w %d/rdi) {
  %117 = slot 8, align 8
  %118 = slot 8, align 8
@59:
  %65.1 = neg.w %d ; @176
  %rem_nc.1 = urem.w %65.1, %d ; @62
  %66.1 = not.w %rem_nc.1 ; @177
  %q1.1 = udiv.w 0x80000000_w, %66.1 ; @66
  %67.1 = mul.w %q1.1, %66.1 ; @178
  %68.1 = sub.w 0x80000000_w, %67.1 ; @179
  %q2.1 = udiv.w 0x7fffffff_w, %d ; @69
  %69.1 = mul.w %q2.1, %d ; @180
  %70.1 = sub.w 0x7fffffff_w, %69.1 ; @181
  %72.1 = sub.w 0x1_w, %d ; @183
  jmp @60(%70.1, %68.1, %q2.1, %q1.1, 0x1f_w, 0x0_w)
@60(%r2.1, %r1.1, %q2.2, %q1.2, %p.1, %a.1):
  %73.1 = add.w %p.1, 0x1_w ; @184
  %74.1 = sub.w %66.1, %r1.1 ; @185
  %75.1 = ge.w %r1.1, %74.1 ; @186
  %76.1 = lsl.w %q1.2, 0x1_w ; @187
  %77.1 = add.w %76.1, 0x1_w ; @188
  %78.1 = lsl.w %r1.1, 0x1_w ; @189
  %79.1 = sub.w %78.1, %66.1 ; @190
  %80.1 = sel.w %75.1, %79.1, %78.1 ; @191
  %81.1 = sel.w %75.1, %77.1, %76.1 ; @192
  %82.1 = add.w %r2.1, 0x1_w ; @193
  %83.1 = sub.w %d, %r2.1 ; @194
  %84.1 = ge.w %82.1, %83.1 ; @195
  %85.1 = lsl.w %r2.1, 0x1_w ; @196
  %86.1 = add.w %85.1, 0x1_w ; @197
  %87.1 = lsl.w %q2.2, 0x1_w ; @198
  br %84.1, @87, @88
@88:
  %102.1 = ge.w %q2.2, 0x80000000_w ; @213
  %103.1 = sel.w %102.1, 0x1_w, %a.1 ; @214
  jmp @96(%86.1, %87.1, %103.1)
@87:
  %98.1 = ge.w %q2.2, 0x7fffffff_w ; @209
  %99.1 = sel.w %98.1, 0x1_w, %a.1 ; @210
  %100.1 = add.w %87.1, 0x1_w ; @211
  %101.1 = add.w %85.1, %72.1 ; @212
  jmp @96(%101.1, %100.1, %99.1)
@96(%r2.2, %q2.3, %a.2):
  %88.1 = add.w %r2.2, 0x1_w ; @199
  %89.1 = lt.w %73.1, 0x40_w ; @200
  br %89.1, @109, @60(%r2.2, %80.1, %q2.3, %81.1, %73.1, %a.2)
@109:
  %90.1 = sub.w %d, %88.1 ; @201
  %91.1 = lt.w %81.1, %90.1 ; @202
  br %91.1, @60(%r2.2, %80.1, %q2.3, %81.1, %73.1, %a.2), @113
@113:
  %92.1 = eq.w %81.1, %90.1 ; @203
  br %92.1, @115, @116
@115:
  %97.1 = ne.w %80.1, 0x0_w ; @208
  br %97.1, @116, @60(%r2.2, %80.1, %q2.3, %81.1, %73.1, %a.2)
@116:
  %93.1 = add.w %q2.3, 0x1_w ; @204
  %94.1 = sub.w %p.1, 0x1f_w ; @205
  st.w %93.1, %117 ; @123
  %119.1 = add.l %117, 0x4_l ; @227
  st.w %a.2, %119.1 ; @124
  st.w %94.1, %118 ; @125
  %108.1 = ld.l %117 ; @218
  %110.1 = ld.l %118 ; @221
  ret rax/%108.1, rdx/%110.1
}
