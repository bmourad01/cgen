module magic_div

export function $magic_signed(w %2/rdi) {
  %0 = slot 8, align 8
@2:
  %276 = slt.w %2, 0x0_w ; @138
  %277 = neg.w %2 ; @139
  %278 = sel.w %276, %277, %2 ; @140
  %279 = flag.w %276 ; @141
  %280 = sub.w %279, 0x80000000_w ; @142
  %281 = urem.w %280, %278 ; @17
  %282 = add.w %279, 0x7fffffff_w ; @143
  %283 = sub.w %282, %281 ; @144
  %284 = udiv.w 0x80000000_w, %283 ; @19
  %285 = mul.w %284, %283 ; @146
  %286 = udiv.w 0x80000000_w, %278 ; @22
  %287 = mul.w %286, %278 ; @147
  %288 = sub.w 0x80000000_w, %287 ; @148
  %289 = sub.w 0x80000000_w, %285 ; @149
  jmp @14(0x1f_w, %288, %286, %289, %284)
@14(%290, %291, %292, %293, %294):
  %295 = lsl.w %293, 0x1_w ; @150
  %296 = ge.w %295, %283 ; @151
  %297 = lsl.w %294, 0x1_w ; @152
  %298 = add.w %297, 0x1_w ; @153
  %299 = sub.w %295, %283 ; @154
  %300 = sel.w %296, %298, %297 ; @156
  %301 = lsl.w %291, 0x1_w ; @157
  %302 = ge.w %301, %278 ; @158
  %303 = lsl.w %292, 0x1_w ; @159
  %304 = add.w %303, 0x1_w ; @160
  %305 = sub.w %301, %278 ; @161
  %306 = sel.w %302, %305, %301 ; @162
  %307 = sub.w %278, %306 ; @163
  %308 = lt.w %300, %307 ; @164
  %309 = add.w %290, 0x1_w ; @165
  %310 = sel.w %302, %304, %303 ; @166
  %311 = sel.w %296, %299, %295 ; @167
  br %308, @14(%309, %306, %310, %311, %300), @42
@42:
  %312 = eq.w %300, %307 ; @168
  br %312, @45, @46
@45:
  %321 = ne.w %311, 0x0_w ; @174
  br %321, @46, @14(%309, %306, %310, %311, %300)
@46:
  %313 = add.w %310, 0x1_w ; @169
  %314 = neg.w %313 ; @170
  %315 = sel.w %276, %314, %313 ; @171
  %316 = add.l %0, 0x4_l ; @172
  st.w %315, %0 ; @56
  %317 = sub.w %290, 0x1f_w ; @173
  st.w %317, %316 ; @57
  %318 = ld.l %0 ; @214
  ret rax/%318
}

export function $magic_unsigned(w %31/rdi) {
  %271 = slot 8, align 8
  %274 = slot 8, align 8
@59:
  %322 = neg.w %31 ; @175
  %323 = urem.w %322, %31 ; @62
  %324 = not.w %323 ; @176
  %325 = udiv.w 0x80000000_w, %324 ; @66
  %326 = mul.w %325, %324 ; @177
  %327 = udiv.w 0x7fffffff_w, %31 ; @69
  %328 = mul.w %327, %31 ; @178
  %329 = sub.w 0x7fffffff_w, %328 ; @181
  %330 = sub.w 0x80000000_w, %326 ; @182
  jmp @60(0x1f_w, 0x0_w, %329, %327, %330, %325)
@60(%331, %332, %333, %334, %335, %336):
  %337 = add.w %331, 0x1_w ; @183
  %338 = sub.w %324, %335 ; @184
  %339 = ge.w %335, %338 ; @185
  %340 = lsl.w %336, 0x1_w ; @186
  %341 = add.w %340, 0x1_w ; @187
  %342 = lsl.w %335, 0x1_w ; @188
  %343 = sub.w %342, %324 ; @189
  %344 = add.w %333, 0x1_w ; @190
  %345 = sub.w %31, %333 ; @191
  %346 = ge.w %344, %345 ; @192
  %347 = lsl.w %333, 0x1_w ; @193
  %348 = add.w %347, 0x1_w ; @194
  %349 = lsl.w %334, 0x1_w ; @195
  br %346, @87, @88
@87:
  %375 = ge.w %334, 0x7fffffff_w ; @208
  %376 = sel.w %375, 0x1_w, %332 ; @209
  %377 = sub.w %348, %31 ; @210
  %378 = add.w %349, 0x1_w ; @211
