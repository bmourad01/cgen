  %208 = sel.w %204, %207, %203 ; @162
  %209 = sub.w %186, %208 ; @163
  %210 = lt.w %202, %209 ; @164
  %211 = add.w %79, 0x1_w ; @165
  %212 = sel.w %204, %206, %205 ; @166
  %213 = sel.w %197, %200, %196 ; @167
  br %210, @14(%211, %208, %212, %213, %202), @42
@42:
  %214 = eq.w %202, %209 ; @168
  br %214, @45, @46
@45:
  %220 = ne.w %213, 0x0_w ; @174
  br %220, @46, @14(%211, %208, %212, %213, %202)
@46:
  %215 = add.w %212, 0x1_w ; @169
  %216 = neg.w %215 ; @170
  %217 = sel.w %184, %216, %215 ; @171
  %218 = add.l %0, 0x4_l ; @172
  st.w %217, %0 ; @56
  %219 = sub.w %79, 0x1f_w ; @173
  st.w %219, %218 ; @57
  %261 = ld.l %0 ; @214
  ret rax/%261
}

export function $magic_unsigned(w %31/rdi) {
  %271 = slot 8, align 8
  %274 = slot 8, align 8
@59:
  %276 = neg.w %31 ; @175
  %277 = urem.w %276, %31 ; @62
