  %213 = sub.w %186, %211 ; @167
  %214 = lt.w %205, %213 ; @168
  br %214, @14(%197, %211, %212, %204, %205), @42
@42:
  %215 = eq.w %205, %213 ; @169
  br %215, @45, @46
@45:
  %221 = ne.w %204, 0x0_w ; @175
  br %221, @46, @14(%197, %211, %212, %204, %205)
@46:
  %216 = add.w %212, 0x1_w ; @170
  %217 = neg.w %216 ; @171
  %218 = sel.w %184, %217, %216 ; @172
  %219 = sub.w %79, 0x1f_w ; @173
  %220 = add.l %0, 0x4_l ; @174
  st.w %218, %0 ; @56
  st.w %219, %220 ; @57
  %262 = ld.l %0 ; @215
  ret rax/%262
}

export function $magic_unsigned(w %31/rdi) {
  %272 = slot 8, align 8
  %273 = slot 8, align 8
@59:
  %277 = neg.w %31 ; @176
