@88:
  %379 = ge.w %334, 0x80000000_w ; @212
  %380 = sel.w %379, 0x1_w, %332 ; @213
  jmp @96(%380, %348, %349)
@96(%350, %351, %352):
  %353 = add.w %351, 0x1_w ; @196
  %354 = lt.w %337, 0x40_w ; @197
  %355 = sel.w %339, %343, %342 ; @198
  %356 = sel.w %339, %341, %340 ; @199
  br %354, @109, @60(%337, %350, %351, %352, %355, %356)
@109:
  %357 = sub.w %31, %353 ; @200
  %358 = lt.w %356, %357 ; @201
  br %358, @60(%337, %350, %351, %352, %355, %356), @113
@113:
  %359 = eq.w %356, %357 ; @202
  br %359, @115, @116
@115:
  %374 = ne.w %355, 0x0_w ; @207
  br %374, @116, @60(%337, %350, %351, %352, %355, %356)
@116:
  %360 = add.w %352, 0x1_w ; @203
  st.w %360, %271 ; @123
  %363 = add.l %271, 0x4_l ; @226
  st.w %350, %363 ; @124
  %364 = sub.w %331, 0x1f_w ; @206
  %366 = ld.l %271 ; @217
  st.w %364, %274 ; @222
  %373 = ld.l %274 ; @225
  ret rax/%366, rdx/%373
}
