module magic_div

type :magic_s = {
  w,
  w
}

type :magic_u = {
  w,
  w,
  w
}

export function :magic_s $magic_signed(w %d) {
  %res = slot 8, align 4
@2:
  %27 = slt.w %d, 0x0_w ; @138
  %28 = neg.w %d ; @139
  %29 = sel.w %27, %28, %d ; @140
  %30 = flag.w %27 ; @141
  %31 = sub.w %30, 0x80000000_w ; @142
  %32 = add.w %30, 0x7fffffff_w ; @143
  %trem.1 = urem.w %31, %29 ; @17
  %33 = sub.w %32, %trem.1 ; @144
  %q1.1 = udiv.w 0x80000000_w, %33 ; @19
  %36 = mul.w %q1.1, %33 ; @147
  %37 = sub.w 0x80000000_w, %36 ; @148
  %q2.1 = udiv.w 0x80000000_w, %29 ; @22
  %38 = mul.w %q2.1, %29 ; @149
  %39 = sub.w 0x80000000_w, %38 ; @150
  jmp @14(%39, %37, %q2.1, %q1.1, 0x1f_w)
@14(%r2.2, %r1.2, %q2.2, %q1.2, %p.2):
  %40 = add.w %p.2, 0x1_w ; @151
  %41 = lsl.w %q1.2, 0x1_w ; @152
  %42 = lsl.w %r1.2, 0x1_w ; @153
  %43 = ge.w %42, %33 ; @154
  %44 = add.w %41, 0x1_w ; @155
  %45 = sub.w %42, %33 ; @156
  %47 = sel.w %43, %45, %42 ; @158
  %48 = sel.w %43, %44, %41 ; @159
  %49 = lsl.w %q2.2, 0x1_w ; @160
  %50 = lsl.w %r2.2, 0x1_w ; @161
  %51 = ge.w %50, %29 ; @162
  %52 = add.w %49, 0x1_w ; @163
  %53 = sub.w %50, %29 ; @164
  %54 = sel.w %51, %53, %50 ; @165
  %55 = sel.w %51, %52, %49 ; @166
  %56 = sub.w %29, %54 ; @167
  %57 = lt.w %48, %56 ; @168
  br %57, @14(%54, %47, %55, %48, %40), @42
@42:
  %58 = eq.w %48, %56 ; @169
  br %58, @45, @46
@45:
  %64 = ne.w %47, 0x0_w ; @175
  br %64, @46, @14(%54, %47, %55, %48, %40)
@46:
  %59 = add.w %55, 0x1_w ; @170
  %60 = neg.w %59 ; @171
  %61 = sel.w %27, %60, %59 ; @172
  %62 = sub.w %p.2, 0x1f_w ; @173
  %63 = add.l %res, 0x4_l ; @174
  st.w %61, %res ; @56
  st.w %62, %63 ; @57
  %result.1 = ld:magic_s %res ; @58
  ret %result.1
}

export function :magic_u $magic_unsigned(w %d) {
  %res = slot 12, align 4
@59:
  %65 = neg.w %d ; @176
  %rem_nc.1 = urem.w %65, %d ; @62
  %66 = not.w %rem_nc.1 ; @177
  %q1.1 = udiv.w 0x80000000_w, %66 ; @66
  %67 = mul.w %q1.1, %66 ; @178
  %68 = sub.w 0x80000000_w, %67 ; @179
  %q2.1 = udiv.w 0x7fffffff_w, %d ; @69
  %69 = mul.w %q2.1, %d ; @180
  %70 = sub.w 0x7fffffff_w, %69 ; @181
  %72 = sub.w 0x1_w, %d ; @183
  jmp @60(%70, %68, %q2.1, %q1.1, 0x1f_w, 0x0_w)
@60(%r2.2, %r1.2, %q2.2, %q1.2, %p.2, %a.2):
  %73 = add.w %p.2, 0x1_w ; @184
  %74 = sub.w %66, %r1.2 ; @185
  %75 = ge.w %r1.2, %74 ; @186
  %76 = lsl.w %q1.2, 0x1_w ; @187
  %77 = add.w %76, 0x1_w ; @188
  %78 = lsl.w %r1.2, 0x1_w ; @189
  %79 = sub.w %78, %66 ; @190
  %80 = sel.w %75, %79, %78 ; @191
  %81 = sel.w %75, %77, %76 ; @192
  %82 = add.w %r2.2, 0x1_w ; @193
  %83 = sub.w %d, %r2.2 ; @194
  %84 = ge.w %82, %83 ; @195
  %85 = lsl.w %r2.2, 0x1_w ; @196
  %86 = add.w %85, 0x1_w ; @197
  %87 = lsl.w %q2.2, 0x1_w ; @198
  br %84, @87, @88
@88:
  %102 = ge.w %q2.2, 0x80000000_w ; @213
  %103 = sel.w %102, 0x1_w, %a.2 ; @214
  jmp @96(%86, %87, %103)
@87:
  %98 = ge.w %q2.2, 0x7fffffff_w ; @209
  %99 = sel.w %98, 0x1_w, %a.2 ; @210
  %100 = add.w %87, 0x1_w ; @211
  %101 = add.w %85, %72 ; @212
  jmp @96(%101, %100, %99)
@96(%r2.3, %q2.3, %a.3):
  %88 = add.w %r2.3, 0x1_w ; @199
  %89 = lt.w %73, 0x40_w ; @200
  br %89, @109, @60(%r2.3, %80, %q2.3, %81, %73, %a.3)
@109:
  %90 = sub.w %d, %88 ; @201
  %91 = lt.w %81, %90 ; @202
  br %91, @60(%r2.3, %80, %q2.3, %81, %73, %a.3), @113
@113:
  %92 = eq.w %81, %90 ; @203
  br %92, @115, @116
@115:
  %97 = ne.w %80, 0x0_w ; @208
  br %97, @116, @60(%r2.3, %80, %q2.3, %81, %73, %a.3)
@116:
  %93 = add.w %q2.3, 0x1_w ; @204
  %94 = sub.w %p.2, 0x1f_w ; @205
  %95 = add.l %res, 0x4_l ; @206
  %96 = add.l %res, 0x8_l ; @207
  st.w %93, %res ; @123
  st.w %a.3, %95 ; @124
  st.w %94, %96 ; @125
  %result.1 = ld:magic_u %res ; @126
  ret %result.1
}
