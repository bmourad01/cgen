  add r15d, edi ; @47
  mov esi, dword ptr [rsp + 0xc] ; @205
  add esi, edi ; @48
  mov dword ptr [rsp + 0xc], esi ; @206
  mov esi, dword ptr [rsp + 0x8] ; @195
  add esi, edi ; @49
  mov dword ptr [rsp + 0x8], esi ; @196
  mov esi, dword ptr [rsp + 0x4] ; @197
  add esi, edi ; @50
  mov dword ptr [rsp + 0x4], esi ; @198
  mov esi, dword ptr [rsp] ; @199
  dec esi ; @51
  mov dword ptr [rsp], esi ; @200
  test esi, esi ; @168
  jne @3 ; @169
@4:
  lea esi, qword ptr [r13 + r12*1] ; @53
  add r11d, ebx ; @56
  lea edi, qword ptr [r10 + r9*1] ; @63
  add edi, r11d ; @64
  add ecx, edx ; @81
