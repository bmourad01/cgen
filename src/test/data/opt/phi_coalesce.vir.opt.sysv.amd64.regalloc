  xor ecx, ecx ; @183
  xor eax, eax ; @184
  xor r14d, r14d ; @185
  xor r15d, r15d ; @186
  mov dword ptr [rsp + 0xc], 0x0_w ; @204
  mov dword ptr [rsp + 0x8], 0x0_w ; @192
  mov dword ptr [rsp + 0x4], 0x0_w ; @193
  mov dword ptr [rsp], esi ; @194
@3:
  add r13d, edi ; @36
  add r12d, edi ; @37
  add ebx, edi ; @38
  add r11d, edi ; @39
  add r10d, edi ; @40
  add r9d, edi ; @41
