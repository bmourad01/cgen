  mov ecx, dword ptr [rsp + 0xc] ; @207
  add ecx, edx ; @118
  add eax, ecx ; @119
  lea ecx, qword ptr [r8 + rax*1] ; @120
  mov eax, dword ptr [rsp + 0x8] ; @202
  add eax, ecx ; @128
  lea ecx, qword ptr [rdi + rax*1] ; @129
  mov eax, dword ptr [rsp + 0x4] ; @203
  add eax, ecx ; @139
  add eax, esi ; @140
  add rsp, 0x10_l ; @214
  pop rbx ; @215
  pop r15 ; @216
  pop r14 ; @217
  pop r13 ; @218
  pop r12 ; @219
  ret ; @150
}
