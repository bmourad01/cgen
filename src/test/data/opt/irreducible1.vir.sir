module irreducible1

export function w $foo(w %2) {
start:
  %4 = copy.w 0x0_w;
  %5 = copy.w %4;
  loop {
    if slt.w %5, %2 {
      %13 = copy.w %5;
      @5:
        %14 = add.w %13, 0x1_w;
        if eq.w %14, %2 {
          %7 = copy.w %14
        } else {
          %10 = copy.w %14;
          %11 = sub.w %10, 0x1_w;
          if eq.w %11, 0x0_w {
            %7 = copy.w %11
          } else {
            %13 = copy.w %11;
            goto @5
          }
        }
    } else {
      %10 = copy.w %5;
      %11 = sub.w %10, 0x1_w;
      if eq.w %11, 0x0_w {
        %7 = copy.w %11
      } else {
        %13 = copy.w %11;
        goto @5
      }
    };
    %8 = and.w %2, 0x1_w;
    if eq.w %8, 0x0_w {
      break
    } else {
      %5 = copy.w %7
    }
  };
  ret %7
}
