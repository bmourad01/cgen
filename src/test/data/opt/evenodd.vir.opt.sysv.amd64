module evenodd

function $abs { ; returns: rax
@2:
  mov %1:w, edi ; @25
  mov %23:w, %1:w ; @26
  neg %23:w ; @36
  mov %24:w, %1:w ; @27
  test %1:w, %1:w ; @34
  cmovs %24:w, %23:w ; @35
  mov eax, %24:w ; @32
  ret ; @33
}

export function $even { ; returns: rax
@7:
  mov %2:w, edi ; @10
  mov edi, %2:w ; @47
  call $abs ; rdi ; @48
  mov %10:w, eax ; @49
  test %10:w, %10:w ; @44
  je @23 ; @45
  jmp @9 ; @46
@23:
  mov eax, 0x1_w ; @42
  ret ; @43
@9:
  lea %26:w, qword ptr [%10 - 0x1] ; @29
  mov edi, %26:w ; @40
  tailcall $odd ; rdi ; @41
}

export function $odd { ; returns: rax
@14:
  mov %5:w, edi ; @17
  mov edi, %5:w ; @57
  call $abs ; rdi ; @58
  mov %14:w, eax ; @59
  test %14:w, %14:w ; @54
  je @24 ; @55
  jmp @16 ; @56
@24:
  xor eax, eax ; @52
  ret ; @53
@16:
  lea %28:w, qword ptr [%14 - 0x1] ; @31
  mov edi, %28:w ; @50
  tailcall $even ; rdi ; @51
}
