module foo

export function w $foo(w %1, w %2, w %3) {
@14:
  jmp @2(%1, %2, %3)
@2(%15, %16, %17):
  %18 = eq.w %15, 0x0_w ; @15
  br %18, @13(%16), @4
@4:
  %19 = eq.w %15, 0x1_w ; @16
  br %19, @13(%17), @7
@7:
  %20 = sub.w %15, 0x1_w ; @17
  %21 = add.w %16, %17 ; @18
  jmp @2(%20, %17, %21)
@13(%14):
