module evenodd

function $abs(w %1/rdi) {
@2:
  %22 = slt.w %1, 0x0_w ; @25
  %23 = neg.w %1 ; @26
  %24 = sel.w %22, %23, %1 ; @27
  ret rax/%24
}

export function $even(w %2/rdi) {
@7:
  %10/w/rax = call $abs(%2/rdi) ; @10
  %25 = eq.w %10, 0x0_w ; @28
  br %25, @23, @9
@9:
  %26 = sub.w %10, 0x1_w ; @29
  tailcall $odd(%26/rdi)
@23:
  ret rax/0x1_b
}

export function $odd(w %5/rdi) {
@14:
  %14/w/rax = call $abs(%5/rdi) ; @17
  %27 = eq.w %14, 0x0_w ; @30
  br %27, @24, @16
@16:
  %28 = sub.w %14, 0x1_w ; @31
  tailcall $even(%28/rdi)
@24:
  ret rax/0x0_b
}
