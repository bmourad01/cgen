module prime_main_licm

const data $fmt = {
  "prime(%d) = %d\n",
  0x0_b
}

export function w $main(w %8, l %1) {
@2:
  %26 = add.l %1, 0x8_l ; @21
  %10 = ld.l %26 ; @5
  %11 = call.w $atoi(%10) ; @6
  jmp @3(0x1_w, 0x1_w, %11)
@3(%14, %15, %16):
  %27 = sle.w %16, 0x0_w ; @22
  br %27, @9, @10(%14)
@10(%18):
  %19 = call.w $is_prime(%18) ; @14
  %28 = eq.w %19, 0x0_w ; @23
  %29 = add.w %18, 0x1_w ; @24
  br %28, @10(%29), @13
@13:
  %22 = call.w $printf($fmt, ..., %15, %18) ; @16
  %30 = sub.w %16, 0x1_w ; @25
  %31 = add.w %15, 0x1_w ; @26
  jmp @3(%29, %31, %30)
@9:
  ret 0x0_w
}
