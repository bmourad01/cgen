module tailcall

export function $ping(w %1/rdi) {
@2:
  %98 = sle.w %1, 0x0_w ; @69
  br %98, @60, @4
@4:
  %99 = sub.w %1, 0x1_w ; @70
  tailcall $pong(%99/rdi)
@60:
  ret rax/0x0_w
}

export function $pong(w %5/rdi) {
@8:
  %100 = sle.w %5, 0x0_w ; @71
  br %100, @61, @10
@10:
  %101 = sub.w %5, 0x1_w ; @72
  tailcall $ping(%101/rdi)
@61:
  ret rax/0x1_w
}

export function $ping_nontail(w %9/rdi) {
@14:
  %102 = sle.w %9, 0x0_w ; @73
  br %102, @62(0x0_w), @16
@16:
  %103 = sub.w %9, 0x1_w ; @74
  %64/w/rax = call $pong(%103/rdi) ; @19
  jmp @62(%64)
@62(%90):
  ret rax/%90
}

export function $call_and_ignore(w %13/rdi) {
@20:
  %104 = sle.w %13, 0x0_w ; @75
  br %104, @63, @22
@22:
  %105 = sub.w %13, 0x1_w ; @76
  %67/w/rax = call $pong(%105/rdi) ; @25
  jmp @63
@63:
  ret rax/%13
}

export function $dispatch(w %17/rdi, w %18/rsi) {
@26:
  %106 = slt.w %17, %18 ; @77
  br %106, @27, @28
@27:
  tailcall $ping(%17/rdi)
@28:
  tailcall $pong(%18/rdi)
}

export function $mixed_tail(w %21/rdi, w %23/rsi) {
@32:
  %107 = eq.w %21, 0x0_w ; @78
  br %107, @33, @34
@33:
  %72/w/rax = call $pong(%23/rdi) ; @36
  jmp @65
@34:
  %108 = sub.w %21, 0x1_w ; @79
  tailcall $ping(%108/rdi)
@65:
  ret rax/%72
}

export function $gcd_tc(w %27/rdi, w %26/rsi) {
@67:
  jmp @39(%27, %26)
@39(%95, %96):
  %109 = eq.w %96, 0x0_w ; @80
  br %109, @66, @41
@41:
  %76 = rem.w %95, %96 ; @43
  jmp @39(%96, %76)
@66:
  ret rax/%95
}

export function $sum7(w %31/rdi, w %32/rsi, w %34/rdx, w %35/rcx, w %37/r8, w %38/r9, w %42/+0) {
@45:
  %110 = add.w %31, %32 ; @81
  %111 = add.w %34, %35 ; @82
  %112 = add.w %37, %38 ; @83
  %113 = add.w %110, %111 ; @84
  %116 = add.w %112, %42 ; @87
  %117 = add.w %113, %116 ; @88
  ret rax/%117
}

export function $tail_sum7_stk(w %44/rdi, w %45/rsi, w %46/rdx, w %47/rcx, w %48/r8, w %49/r9, w %50/+0) {
@52:
  %84/w/rax = call $sum7(%44/rdi, %45/rsi, %46/rdx, %47/rcx, %48/r8, %49/r9, %50/+0)
  ; @53
  ret rax/%84
}

export function $gcd_nt(w %53/rdi, w %52/rsi) {
@54:
  %119 = eq.w %52, 0x0_w ; @90
  br %119, @68(%53), @56
@56:
  %86 = rem.w %53, %52 ; @58
  %87/w/rax = call $gcd_nt(%52/rdi, %86/rsi) ; @59
  jmp @68(%87)
@68(%97):
  ret rax/%97
}
