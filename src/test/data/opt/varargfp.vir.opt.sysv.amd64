export function $six { ; returns: xmm0
@13:
  mov edi, 0x3_w ; @14
  movsd xmm0, qword ptr [rip + @121] ; @122
  .fp64 @121, 1. ; @123
  movsd xmm1, qword ptr [rip + @120] ; @124
