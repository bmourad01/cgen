module palindrome

export function $palindrome { ; returns: rax
@2:
  xor esi, esi ; @54
  mov eax, edi ; @55
@3:
  test eax, eax ; @48
  jne @6 ; @49
@7:
  xor eax, eax ; @33
  cmp edi, esi ; @46
  sete al ; @47
  ret ; @45
@6:
  movsxd rcx, eax ; @16
  imul rcx, rcx, 0x66666667 ; @42
  sar rcx, 0x20_b ; @43
  mov edx, ecx ; @17
  sar edx, 0x2_b ; @41
  shr ecx, 0x1f_b ; @40
  add ecx, edx ; @19
  imul edx, ecx, 0xa ; @20
  sub eax, edx ; @39
  lea edx, qword ptr [rsi + rsi*1] ; @28
  lea edx, qword ptr [rdx + rsi*8] ; @29
  lea esi, qword ptr [rdx + rax*1] ; @30
  mov eax, ecx ; @36
  jmp @3 ; @37
}
