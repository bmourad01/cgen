export function sw $count_pos(l %131, w %132) {
  %129 = slot 8, align 8
  %130 = slot 4, align 4
  %133 = slot 4, align 4
  %134 = slot 4, align 4
start:
  st.l %131, %129;
  st.w %132, %130;
  st.w 0x0_w, %133;
  st.w 0x0_w, %134;
  loop {
    %149 = ld.w %134;
    %150 = ld.w %130;
    %151 = slt.w %149, %150;
    %152 = flag.w %151;
    unless ne.w %152, 0x0_w {
      break
    };
    %135 = ld.w %133;
    %136 = ld.l %129;
    %137 = ld.w %134;
    %138 = sext.l %137;
    %139 = mul.l %138, 0x4_l;
    %140 = add.l %136, %139;
    %141 = ld.w %140;
    %142 = sgt.w %141, 0x0_w;
    %143 = flag.w %142;
    %144 = ne.w %143, 0x0_w;
    %145 = sel.w %144, 0x1_w, 0x0_w;
    %146 = add.w %135, %145;
    st.w %146, %133
  } step {
    %147 = ld.w %134;
    %148 = add.w %147, 0x1_w;
    st.w %148, %134
  };
  %153 = ld.w %133;
  ret %153
}

export function sw $first_is_pos(l %156, w %157) {
