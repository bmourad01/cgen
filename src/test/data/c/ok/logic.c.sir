    %164 = mul.l %163, 0x4_l;
    %165 = add.l %162, %164;
    %166 = ld.w %165;
    %167 = sgt.w %166, 0x0_w;
    %168 = flag.w %167;
    %169 = ne.w %168, 0x0_w;
    %170 = flag.w %169;
    st.w %170, %158
  } else {
    st.w 0x0_w, %158
  };
  %171 = ld.w %158;
  ret %171
}

export function sw $guarded(w %174, l %175) {
  %172 = slot 4, align 4
