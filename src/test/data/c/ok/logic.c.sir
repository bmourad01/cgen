module logic

export function sw $land(w %2, w %3) {
  %0 = slot 4, align 4
  %1 = slot 4, align 4
start:
  st.w %2, %0;
  st.w %3, %1;
  %4 = ld.w %0;
  %5 = ld.w %1;
  %6 = ne.w %5, 0x0_w;
  %7 = flag.w %6;
  %8 = ne.w %4, 0x0_w;
  %9 = sel.w %8, %7, 0x0_w;
  ret %9
}

