export function sw $c_b(l %82) {
  %81 = slot 8, align 8
start:
  st.l %82, %81;
  %83 = ld.l %81;
  %84 = add.l %83, 0x4_l;
  %85 = ld.b %84;
  %86 = sext.w %85;
  ret %86
}

export function l $size_e() {
start:
  ret 0x8_l
}

export function sw $ia_a() {
start:
  %87 = ld.b $init_a;
  %88 = sext.w %87;
  ret %88
}

export function sw $ia_b() {
start:
  %89 = add.l $init_a, 0x1_l;
  %90 = ld.b %89;
  %91 = zext.w %90;
  %92 = lsl.w %91, 0x1c_w;
  %93 = asr.w %92, 0x1c_w;
  ret %93
}

export function w $ia_c() {
start:
  %94 = ld.w $init_a;
  %95 = lsl.w %94, 0x0_w;
  %96 = lsr.w %95, 0xc_w;
  ret %96
}

export function sw $ia_d() {
start:
  %97 = add.l $init_a, 0x4_l;
  %98 = ld.h %97;
  %99 = sext.w %98;
  ret %99
}

export function l $ie_x() {
start:
  %100 = ld.b $init_e;
  %101 = zext.l %100;
  %102 = lsl.l %101, 0x3c_l;
  %103 = asr.l %102, 0x3c_l;
  %104 = itrunc.w %103;
  %105 = sext.l %104;
  ret %105
}

export function sw $ie_arr(w %107) {
  %106 = slot 4, align 4
start:
  st.w %107, %106;
  %108 = add.l $init_e, 0x1_l;
  %109 = ld.w %106;
  %110 = sext.l %109;
  %111 = add.l %108, %110;
  %112 = ld.b %111;
  %113 = sext.w %112;
  ret %113
}

export function sw $ie_y() {
start:
  %114 = add.l $init_e, 0x5_l;
  %115 = ld.b %114;
  %116 = zext.w %115;
  %117 = lsl.w %116, 0x18_w;
  %118 = asr.w %117, 0x18_w;
