typedef unsigned long my_size_t;

typedef int *my_intptr;

struct padded {
  char used[4];
  char pad[32 - 4 - sizeof(my_size_t)];
};

unsigned long size_of_typedef(void) {
  return sizeof(my_size_t);
}

unsigned long size_of_pointer_typedef(void) {
  return sizeof(my_intptr);
}

unsigned long size_of_padded_struct(void) {
  return sizeof(struct padded);
}
