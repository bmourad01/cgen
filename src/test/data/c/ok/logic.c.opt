export function sw $is_leap(w %108) {
@102:
  %714 = and.w %108, 0x3_w ; @321
  %715 = eq.w %714, 0x0_w ; @322
  %725 = mul.w %108, 0xc28f5c29_w ; @332
  %726 = add.w %725, 0x51eb850_w ; @333
