export function sw $count_pos(l %131, w %132) {
@151:
  jmp @126(0x0_w, 0x0_w)
@126(%548, %549):
  %742 = slt.w %548, %132 ; @349
  br %742, @131, @124
@131:
  %744 = sext.l %548 ; @351
  %745 = lsl.l %744, 0x2_l ; @352
  %746 = add.l %131, %745 ; @353
  %562 = ld.w %746 ; @138
  %747 = sgt.w %562, 0x0_w ; @354
  %748 = flag.w %747 ; @355
  %749 = add.w %549, %748 ; @356
  %750 = add.w %548, 0x1_w ; @357
  jmp @126(%750, %749)
@124:
  ret %549
}

