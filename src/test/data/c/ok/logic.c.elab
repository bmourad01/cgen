int land(int a, int b) {
  return a ? b != (int)0 : 0;
}

int lor(int a, int b) {
  return a ? 1 : b != (int)0;
}

int between(int x, int lo, int hi) {
  return lo <= x ? x <= hi != (int)0 : 0;
}

int imax(int a, int b) {
  return a > b ? a : b;
}

int iabs(int x) {
  return x < 0 ? -x : x;
}

int clamp(int x, int lo, int hi) {
  return x < lo ? lo : x > hi ? hi : x;
}

int is_alpha(int c) {
  return (c >= 'a' ? c <= 'z' != (int)0 : 0) ? 1 : (c >= 'A' ? c <= 'Z' != (int)0 : 0) != (int)0;
}

int is_leap(int y) {
  return (y % 4 == 0 ? y % 100 != 0 != (int)0 : 0) ? 1 : y % 400 == 0 != (int)0;
}

int count_pos(const int *a, int n) {
  int count = 0;
  {
    int i = 0;
    for (; i < n; i = i + 1)
      count = count + (a[i] > 0 ? 1 : 0);
  }
  return count;
}

int first_is_pos(const int *a, int n) {
  int %0;
  {
    if (n > 0)
      %0 = a[0] > 0 != (int)0;
    else
      %0 = 0;
    return %0;
  }
}

int guarded(int c, int (*f)(void)) {
  int %0;
  int %1;
  {
    if (c) {
      %0 = f();
      %1 = %0 != (int)0;
    } else
      %1 = 0;
    return %1;
  }
}

int max_if(int a, int b) {
  if (a > b)
    return a;
  else
    return b;
}

int sign_if(int x) {
  if (x > 0)
    return 1;
  else if (x < 0)
    return -1;
  else
    return 0;
}

int choose(int c, int a, int b) {
  int r;
  if (c)
    r = a;
  else
    r = b;
  return r + 1;
}

int count_pos_if(const int *a, int n) {
  int count = 0;
  {
    int i = 0;
    for (; i < n; i = i + 1)
      if (a[i] > 0)
        count = count + 1;
  }
  return count;
}
