export function sw $scoped(w %142, w %143) {
@227:
  switch.w %142, @14(0xffffffff_w) [0x0_w -> @202(0x0_w, 0x0_w),
                                    0x1_w -> @12(0x0_w, 0x0_w)]
@202(%515, %516):
  %559 = slt.w %515, %143 ; @263
  br %559, @215, @196(%516)
@215:
  %561 = add.w %515, 0x1_w ; @265
