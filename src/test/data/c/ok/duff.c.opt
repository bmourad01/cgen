  %543 = add.l %405, 0x4_l ; @257
  %422 = ld.w %405 ; @107
  st.w %422, %406 ; @106
  jmp @6(%404, %543, %542)
@6(%385, %386, %387):
  %540 = add.l %387, 0x4_l ; @254
  st.l %386, %21 ; @96
  %541 = add.l %386, 0x4_l ; @255
  %403 = ld.w %386 ; @88
  st.w %403, %387 ; @87
  jmp @7(%385, %541, %540)
@7(%366, %367, %368):
  %538 = add.l %368, 0x4_l ; @252
  st.l %367, %21 ; @77
  %539 = add.l %367, 0x4_l ; @253
  %384 = ld.w %367 ; @69
  st.w %384, %368 ; @68
  jmp @8(%366, %539, %538)
@8(%347, %348, %349):
  %536 = add.l %349, 0x4_l ; @250
  st.l %348, %21 ; @58
  %537 = add.l %348, 0x4_l ; @251
  %365 = ld.w %348 ; @50
  st.w %365, %349 ; @49
  jmp @9(%347, %537, %536)
@9(%319, %320, %321):
  %531 = add.l %321, 0x4_l ; @245
  st.l %320, %21 ; @39
  %532 = add.l %320, 0x4_l ; @246
  %337 = ld.w %320 ; @31
  st.w %337, %321 ; @30
  st.w %319, %21 ; @27
  %533 = sub.w %319, 0x1_w ; @247
  %534 = sgt.w %533, 0x0_w ; @248
  br %534, @16(%533, %532, %531), @10
@10:
  ret
}

export function sw $scoped(w %142, w %143) {
@227:
  switch.w %142, @14(0xffffffff_w) [0x0_w -> @202(0x0_w, 0x0_w),
                                    0x1_w -> @12(0x0_w, 0x0_w)]
@202(%505, %506):
  %549 = slt.w %505, %143 ; @263
  br %549, @215, @196(%506)
@215:
  %551 = add.w %505, 0x1_w ; @265
  jmp @12(%551, %506)
@12(%493, %494):
  %552 = add.w %494, %493 ; @266
  %553 = eq.w %493, 0x3_w ; @267
  br %553, @196(%552), @202(%493, %552)
@196(%487):
  %548 = add.w %487, 0x1_w ; @262
  jmp @14(%548)
@14(%485):
  ret %485
}
