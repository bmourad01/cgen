module duff

export function $copy(l %3, l %4, w %5) {
  %21 = slot 8, align 8
@181:
  st.w %5, %21 ; @188
  %519 = add.w %5, 0x7_w ; @233
  %520 = slt.w %519, 0x0_w ; @234
  %521 = add.w %5, 0xe_w ; @235
  %522 = sel.w %520, %521, %519 ; @236
  %523 = asr.w %5, 0x1f_w ; @237
  %524 = lsr.w %523, 0x1d_w ; @238
  %525 = add.w %5, %524 ; @239
  %526 = and.w %525, 0x7_w ; @240
  %527 = sub.w %526, %524 ; @241
  %528 = asr.w %522, 0x3_w ; @242
  switch.w %527, @10 [0x0_w -> @16(%528, %4, %3),
                      0x1_w -> @9(%528, %4, %3),
                      0x2_w -> @8(%528, %4, %3),
                      0x3_w -> @7(%528, %4, %3),
                      0x4_w -> @6(%528, %4, %3),
                      0x5_w -> @5(%528, %4, %3),
                      0x6_w -> @4(%528, %4, %3),
                      0x7_w -> @3(%528, %4, %3)]
@16(%461, %462, %463):
  %529 = add.l %463, 0x4_l ; @243
  st.l %462, %21 ; @172
  %530 = add.l %462, 0x4_l ; @244
  %479 = ld.w %462 ; @164
  st.w %479, %463 ; @163
  jmp @3(%461, %530, %529)
@3(%442, %443, %444):
  %546 = add.l %444, 0x4_l ; @260
  st.l %443, %21 ; @153
  %547 = add.l %443, 0x4_l ; @261
  %460 = ld.w %443 ; @145
  st.w %460, %444 ; @144
  jmp @4(%442, %547, %546)
@4(%423, %424, %425):
  %544 = add.l %425, 0x4_l ; @258
  st.l %424, %21 ; @134
  %545 = add.l %424, 0x4_l ; @259
  %441 = ld.w %424 ; @126
  st.w %441, %425 ; @125
  jmp @5(%423, %545, %544)
@5(%404, %405, %406):
