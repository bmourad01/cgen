export function w $u_mod7(w %37) {
@38:
  %166 = umulh.w %37, 0x24924925_w ; @104
  %167 = sub.w %37, %166 ; @105
  %168 = lsr.w %167, 0x1_w ; @106
  %169 = add.w %168, %166 ; @107
  %170 = lsr.w %169, 0x2_w ; @108
  %172 = mul.w %170, 0x7_w ; @110
  %173 = sub.w %37, %172 ; @111
