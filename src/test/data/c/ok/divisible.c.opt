module divisible

export function sw $s_div3(w %1) {
@2:
  %113 = mul.w %1, 0xaaaaaaab_w ; @51
  %114 = add.w %113, 0x2aaaaaaa_w ; @52
  %115 = le.w %114, 0x55555554_w ; @53
  %116 = flag.w %115 ; @54
  ret %116
}

