struct flags {
  unsigned int ready : 1;
  unsigned int mode : 3;
  int sign : 4;
  unsigned int wide : 20;
};

unsigned int get_ready(struct flags *f) {
  return f->ready;
}

unsigned int get_mode(struct flags *f) {
  return f->mode;
}

int get_sign(struct flags *f) {
  return f->sign;
}

unsigned int get_wide(struct flags *f) {
  return f->wide;
}

void set_mode(struct flags *f, unsigned int v) {
  f->mode = v;
}

void set_sign(struct flags *f, int v) {
  f->sign = v;
}

void set_wide(struct flags *f, unsigned int v) {
  f->wide = v;
}

int packed_sum(void) {
  struct flags f = {1, 5, -3, 1000};
  return f.ready + f.mode + f.sign + (int)f.wide;
}

unsigned int assign_value_unsigned(struct flags *f) {
  return f->mode = 13;
}

int assign_value_signed(struct flags *f) {
  return f->sign = 13;
}

unsigned int compound_value(struct flags *f) {
  f->mode = 6;
  return f->mode += 5;
}

int signed_compare(struct flags *f) {
  short s = -1;
  return s < f->mode;
}
