struct point {
  int x;
  int y;
};

struct point mkpoint(int x, int y) {
  struct point p;
  p.x = x;
  p.y = y;
  return p;
}

int dot(struct point a, struct point b) {
  return a.x * b.x + a.y * b.y;
}

int sum_array(int *a, int n) {
  int %0;
  int %1;
  int s = 0;
  {
    int i = 0;
    for (; i < n; %1 = i, i = %1 + 1)
      (%0 = s, s = %0 + a[i]);
  }
  return s;
}
