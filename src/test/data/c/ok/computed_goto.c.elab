int classify(int x) {
  void *target;
  if (x < 0)
    target = 0;
  else if (x > 0)
    target = 1;
  else
    target = 2;
  goto *target;
  neg: return -1;
  zero: return 0;
  pos: return 1;
}

int interp(const int *code) {
  int %0;
  int %1;
  int %2;
  int %3;
  void *table[3];
  table[0] = 0;
  table[1] = 1;
  table[2] = 2;
  int acc = 0;
  int pc = 0;
  goto *((void **)table)[code[pc]];
  op_add: (%0 = acc, acc = %0 + code[pc + 1]);
  (%1 = pc, pc = %1 + 2);
  goto *((void **)table)[code[pc]];
  op_sub: (%2 = acc, acc = %2 - code[pc + 1]);
  (%3 = pc, pc = %3 + 2);
  goto *((void **)table)[code[pc]];
  op_halt: return acc;
}
