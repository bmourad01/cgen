module designators

type :Inner = {
  w,
  w
}

type :Outer = {
  :Inner,
  w
}

const data $go = {
  0x4_w,
  0x6_w,
  0x7_w
}

export function sw $single_chain() {
  %0 = slot 12, align 4
start:
  st.l 0x0_l, %0;
  %1 = add.l %0, 0x8_l;
  st.w 0x0_w, %1;
  st.w 0x0_w, %0;
  %2 = add.l %0, 0x4_l;
  st.w 0x5_w, %2;
  %3 = ld.w %0;
  %4 = mul.w %3, 0x64_w;
  %5 = add.l %0, 0x4_l;
  %6 = ld.w %5;
  %7 = mul.w %6, 0xa_w;
  %8 = add.w %4, %7;
  %9 = add.l %0, 0x8_l;
  %10 = ld.w %9;
  %11 = add.w %8, %10;
  ret %11
}

