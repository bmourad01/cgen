export function :Inner $make_inner() {
  %154 = slot 8, align 4
start:
  st.w 0x7_w, %154;
  %155 = add.l %154, 0x4_l;
  st.w 0x8_w, %155;
  %156 = ld:Inner %154;
  ret %156
}

export function sw $overlay_call() {
  %157 = slot 8, align 4
  %159 = slot 12, align 4
start:
  %158 = call:Inner $make_inner();
  st:Inner %158, %157;
  st.l 0x0_l, %159;
  %160 = add.l %159, 0x8_l;
  st.w 0x0_w, %160;
  %161 = ld:Inner %157;
