export function sw $enum_consts() {
start:
  %0 = add.w 0x1_w, 0x2_w;
  %1 = add.w %0, 0x4_w;
  %2 = add.w %1, 0x7_w;
  ret %2
}

export function sw $anon_struct() {
  %3 = slot 8, align 4
start:
  st.w 0x3_w, %3;
  %4 = add.l %3, 0x4_l;
  st.w 0x4_w, %4;
  %5 = ld.w %3;
  %6 = mul.w %5, 0xa_w;
  %7 = add.l %3, 0x4_l;
  %8 = ld.w %7;
  %9 = add.w %6, %8;
  ret %9
}

