typedef unsigned long bits;

enum __anon_enum_1 {
  Pob = 3,
  Pbi1 = 5,
};

bits masks[] = {[4] = (bits)1 << Pob, [5] = (bits)1 << Pbi1, [6] = (bits)1 << Pob | (bits)1 << Pbi1};

bits mask_of(int n) {
  return masks[n];
}

int third(void) {
  int *p = (int []){10, 20, 30};
  return p[2];
}

typedef unsigned char uchar;

static uchar *matcher[] = {[1] = (uchar []){1, 3, 1, 3, 2, 0}, [2] = (uchar []){9, 9, 9}};

int matcher_elt(int i, int j) {
  return matcher[i][j];
}
