module shift

export function l $shl(l %2, w %3) {
  %0 = slot 8, align 8
  %1 = slot 4, align 4
start:
  st.l %2, %0;
  st.w %3, %1;
  %4 = ld.l %0;
  %5 = ld.w %1;
  %6 = sext.l %5;
  %7 = lsl.l %4, %6;
  ret %7
}

export function l $sar(l %10, w %11) {
  %8 = slot 8, align 8
  %9 = slot 4, align 4
start:
  st.l %10, %8;
  st.w %11, %9;
  %12 = ld.l %8;
  %13 = ld.w %9;
  %14 = sext.l %13;
  %15 = asr.l %12, %14;
  ret %15
}

export function l $shr(l %18, w %19) {
  %16 = slot 8, align 8
  %17 = slot 4, align 4
start:
  st.l %18, %16;
  st.w %19, %17;
  %20 = ld.l %16;
  %21 = ld.w %17;
  %22 = sext.l %21;
  %23 = lsr.l %20, %22;
  ret %23
}

export function sw $shl_wide(w %26, l %27) {
  %24 = slot 4, align 4
  %25 = slot 8, align 8
start:
  st.w %26, %24;
  st.l %27, %25;
  %28 = ld.w %24;
  %29 = ld.l %25;
  %30 = itrunc.w %29;
  %31 = lsl.w %28, %30;
  ret %31
}

export function sw $sar_wide(w %34, l %35) {
  %32 = slot 4, align 4
  %33 = slot 8, align 8
start:
  st.w %34, %32;
  st.l %35, %33;
  %36 = ld.w %32;
  %37 = ld.l %33;
  %38 = itrunc.w %37;
  %39 = asr.w %36, %38;
  ret %39
}

export function w $shr_wide(w %42, l %43) {
  %40 = slot 4, align 4
  %41 = slot 8, align 8
start:
  st.w %42, %40;
  st.l %43, %41;
  %44 = ld.w %40;
  %45 = ld.l %41;
  %46 = itrunc.w %45;
  %47 = lsr.w %44, %46;
  ret %47
}
