module declspec_order

export const data $a = {
  0x1_b
}

export const data $b = {
  0x2_b
}

export const data $c = {
  0x3_b
}

export const data $d = {
  0x4_l
}

const data $e = {
  0x5_l
}

export data $f = {
  z 4
}

export function sw $sum() {
start:
  %0 = ld.b $a;
  %1 = zext.w %0;
  %2 = ld.b $b;
  %3 = zext.w %2;
  %4 = add.w %1, %3;
  %5 = ld.b $c;
  %6 = zext.w %5;
  %7 = add.w %4, %6;
  %8 = ld.l $d;
  %9 = itrunc.w %8;
  %10 = add.w %7, %9;
  %11 = ld.l $e;
  %12 = itrunc.w %11;
  %13 = add.w %10, %12;
  ret %13
}
