int classify(int n) {
  int r = 0;
  if (n < 0)
    r = -1;
  else if (n == 0)
    goto done;
  else
    r = 1;
  while (n > 0) {
    n -= 1;
    r += n;
  }
  for (int i = 0; i < 10; i++) {
    if (i == 5)
      continue;
    r += i;
  }
  switch (r) {
    case 0: r = 100;
    break;
    default: r = -100;
  }
  done: return r;
}
