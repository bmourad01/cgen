module assign_value

export data $g = {
  0x9_w
}

export data $p = {
  $g
}

export data $g2 = {
  0x5_w
}

export data $q = {
  $g2
}

export function sw $self_ref() {
  %0 = slot 4, align 4
  %7 = slot 4, align 4
start:
  %1 = ld.l $p;
  %2 = ld.w %1;
  %3 = slt.w 0x1_w, %2;
  %4 = flag.w %3;
  st.w %4, %0;
  %5 = ld.l $p;
  %6 = ld.w %0;
  st.w %6, %5;
  %8 = ld.w %0;
  st.w %8, %7;
  %9 = ld.w %7;
  when ne.w %9, 0x0_w {
    %10 = ld.l $p;
    st.w 0x0_w, %10
  };
  %11 = ld.l $p;
  %12 = ld.w %11;
  ret %12
}

export function sw $compound_self() {
  %13 = slot 4, align 4
  %14 = slot 4, align 4
start:
  %15 = ld.l $q;
  %16 = ld.w %15;
  st.w %16, %13;
  %17 = ld.w %13;
  %18 = ld.l $q;
  %19 = ld.w %18;
  %20 = add.w %17, %19;
  st.w %20, %14;
  %21 = ld.l $q;
  %22 = ld.w %14;
  st.w %22, %21;
  %23 = ld.w %14;
  ret %23
}

export function sw $incdec() {
  %24 = slot 4, align 4
  %25 = slot 4, align 4
  %26 = slot 4, align 4
  %30 = slot 4, align 4
  %35 = slot 4, align 4
start:
  st.w 0x6_w, %26;
  %27 = ld.w %26;
  st.w %27, %24;
  %28 = ld.w %24;
  %29 = add.w %28, 0x1_w;
  st.w %29, %26;
  %31 = ld.w %24;
  st.w %31, %30;
  %32 = ld.w %26;
  st.w %32, %25;
  %33 = ld.w %25;
  %34 = add.w %33, 0x1_w;
  st.w %34, %26;
  %36 = ld.w %25;
  %37 = add.w %36, 0x1_w;
  st.w %37, %35;
  %38 = ld.w %30;
  %39 = mul.w %38, 0x64_w;
  %40 = ld.w %35;
  %41 = mul.w %40, 0xa_w;
  %42 = add.w %39, %41;
  %43 = ld.w %26;
  %44 = add.w %42, %43;
  ret %44
}

export function sw $chain() {
  %45 = slot 4, align 4
  %46 = slot 4, align 4
  %47 = slot 4, align 4
  %48 = slot 4, align 4
  %49 = slot 4, align 4
start:
  st.w 0x7_w, %45;
  %50 = ld.w %45;
  st.w %50, %49;
  %51 = ld.w %45;
  st.w %51, %46;
  %52 = ld.w %46;
  st.w %52, %48;
  %53 = ld.w %46;
  st.w %53, %47;
  %54 = ld.w %47;
  %55 = ld.w %48;
  %56 = add.w %54, %55;
  %57 = ld.w %49;
  %58 = add.w %56, %57;
  ret %58
}

export function sw $cond_assign() {
  %59 = slot 4, align 4
  %60 = slot 4, align 4
start:
  st.w 0x0_w, %60;
  st.w 0x5_w, %59;
  %61 = ld.w %59;
  st.w %61, %60;
  %62 = ld.w %59;
  when ne.w %62, 0x0_w {
    %63 = ld.w %60;
    ret %63
  };
  %64 = neg.w 0x1_w;
  ret %64
}
