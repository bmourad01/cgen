int s_div3(int x) {
  return x % 3 == 0;
}

int s_div4(int x) {
  return x % 4 == 0;
}

int s_div100(int x) {
  return x % 100 == 0;
}

int s_ndiv7(int x) {
  return x % 7 != 0;
}

unsigned int u_div6(unsigned int x) {
  return (unsigned int)(x % (unsigned int)6 == (unsigned int)0);
}

unsigned int u_div10(unsigned int x) {
  return (unsigned int)(x % (unsigned int)10 == (unsigned int)0);
}

unsigned int u_mod7(unsigned int x) {
  return x % (unsigned int)7;
}

unsigned int u_mod641(unsigned int x) {
  return x % (unsigned int)641;
}
