module loops

export function sw $sum_odds(w %1) {
@26:
  jmp @4(0x0_w, 0x0_w)
@4(%172, %173):
  %285 = slt.w %172, %1 ; @139
  br %285, @14, @2
@14:
  %291 = and.w %172, 0x1_w ; @145
  %292 = eq.w %291, 0x0_w ; @146
  %294 = add.w %173, %172 ; @148
  %295 = add.w %172, 0x1_w ; @149
  %296 = sel.w %292, %173, %294 ; @150
  jmp @4(%295, %296)
@2:
  ret %173
}

export function sw $count_down(w %19) {
@51:
  jmp @32(0x0_w, %19)
@32(%195, %196):
  %297 = sgt.w %196, 0x0_w ; @151
  br %297, @37, @30
@37:
  %299 = sub.w %196, 0x1_w ; @153
  %306 = mul.w %299, 0xaaaaaaab_w ; @160
  %307 = add.w %306, 0x2aaaaaaa_w ; @161
  %308 = le.w %307, 0x55555554_w ; @162
  br %308, @32(%195, %299), @33
@33:
  %310 = add.w %195, 0x1_w ; @164
  jmp @32(%310, %299)
@30:
  ret %195
}

export function sw $do_at_least_once(w %34) {
@67:
  jmp @56(0x0_w)
@56(%215):
  %311 = add.w %215, 0x1_w ; @165
  %312 = slt.w %311, %34 ; @166
  br %312, @56(%311), @54
@54:
  ret %311
}

export function sw $do_count(w %44) {
@92:
  jmp @72(0x0_w, 0x0_w)
@72(%228, %229):
  %314 = add.w %229, 0x1_w ; @168
  %320 = and.w %314, 0x3_w ; @174
  %321 = eq.w %320, 0x0_w ; @175
  %323 = add.w %228, 0x1_w ; @177
  %324 = slt.w %314, %44 ; @178
  %326 = sel.w %321, %228, %323 ; @180
  br %324, @72(%326, %314), @70
@70:
  ret %326
}

export function sw $grid(w %62, w %63) {
@131:
  jmp @98(0x0_w, 0x0_w)
@98(%252, %253):
  %327 = slt.w %252, %62 ; @181
  br %327, @103(0x0_w, %253), @96
@103(%261, %262):
  %329 = slt.w %261, %63 ; @183
  br %329, @112, @99
@112:
  %332 = eq.w %261, 0x1_w ; @186
  %334 = add.w %262, 0x1_w ; @188
  %335 = add.w %261, 0x1_w ; @189
  %336 = sel.w %332, %262, %334 ; @190
  jmp @103(%335, %336)
@99:
  %331 = add.w %252, 0x1_w ; @185
  jmp @98(%331, %262)
@96:
  ret %253
}
