module alignas

export data $g32 = align 32 {
  0x1_l,
  0x2_l,
  0x3_l,
  0x4_l
}

export data $cbuf = align 16 {
  z 8
}

export data $adbl = align 8 {
  z 1
}

data $s.0 = align 16 {
  z 8
}

export function sw $local_aligned() {
  %0 = slot 4, align 4
  %1 = slot 16, align 16
start:
  %2 = sext.l 0x0_w;
  %3 = mul.l %2, 0x4_l;
  %4 = add.l %1, %3;
  st.w 0x5_w, %4;
  %5 = sext.l 0x0_w;
  %6 = add.l $s.0, %5;
  %7 = itrunc.b 0x6_w;
  st.b %7, %6;
  %8 = sext.l 0x10_w;
  %9 = urem.l %1, %8;
  %10 = sext.l 0x0_w;
  %11 = eq.l %9, %10;
  %12 = flag.w %11;
  %13 = sext.l 0x10_w;
  %14 = urem.l $s.0, %13;
  %15 = sext.l 0x0_w;
  %16 = eq.l %14, %15;
  %17 = flag.w %16;
  %18 = ne.w %17, 0x0_w;
  %19 = flag.w %18;
  %20 = ne.w %12, 0x0_w;
  %21 = sel.w %20, %19, 0x0_w;
  if ne.w %21, 0x0_w {
    %22 = sext.l 0x0_w;
    %23 = mul.l %22, 0x4_l;
    %24 = add.l %1, %23;
    %25 = ld.w %24;
    %26 = sext.l 0x0_w;
    %27 = add.l $s.0, %26;
    %28 = ld.b %27;
    %29 = sext.w %28;
    %30 = add.w %25, %29;
    st.w %30, %0
  } else {
    st.w 0x0_w, %0
  };
  %31 = ld.w %0;
  ret %31
}
