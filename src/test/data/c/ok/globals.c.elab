  return *g_pconst;
}

int deref_pcelem(void) {
  return *g_pcelem;
}

int pcarr_get(int i) {
  int %0;
  const int *p = ((const int **)g_pcarr)[i];
  {
    if (p)
      %0 = *p;
    else
      %0 = -1;
    return %0;
  }
}
